    .btn-whatsapp:hover {
        background: #1ebe5d;
    }
    /* Efeito de hover nos eventos do calendário */
    .cal-event {
        background: var(--bg3) !important;
        border: 1px solid var(--border) !important;
        border-radius: 4px !important;
        transition: transform 0.2s, border-color 0.2s;
