<link rel="stylesheet" href="/css/admin.css?v=2">
<!-- ── Header ── -->
<div class="adm-header">
    <div class="adm-header-left">
        <a href="/loginAdmin" class="adm-back"><i class="fa-solid fa-arrow-left"></i></a>
        <a href="/" class="adm-logo">{{empresa.segmento}}</a>
    </div>
    <div class="adm-header-center">Painel Administrativo</div>
    <div style="display:flex;align-items:center;gap:8px;">
        <div class="config-menu-wrap">
            <button class="btn-config-menu" id="btn-config-menu">
                <span class="menu-icon"><span></span><span></span><span></span></span>
                Menu
            </button>
            <div class="config-dropdown" id="config-dropdown">
                <div class="config-dropdown-label">Compartilhar</div>
                <div class="config-dropdown-item link-agendamento-item">
                    <div class="link-header">
                        <span class="item-icon">🔗</span>
                        <div class="item-label">
                            <span>Link de Agendamento</span>
                            <small>Envie para seus clientes</small>
                        </div>
                    </div>
                    <div class="link-actions">
                        <input type="text" id="input-link-agendamento" readonly />
                        <button id="btn-copiar-link">Copiar</button>
                    </div>
                    <button id="btn-whatsapp-link" class="btn-whatsapp"> WhatsApp </button>
                </div>
                {{#if empresa.site}}
                <a href="/site/{{empresa.site}}" target="_blank" class="config-dropdown-item">
                    <span class="item-icon">🌐</span>
                    <span class="item-label">
                        <span>Meu Site</span>
                        <small>Abrir página pública</small>
                    </span>
                </a>
                {{/if}}
                <div class="config-dropdown-label">Sistema</div>
                <button class="config-dropdown-item" id="menu-dashboard">
                    <span class="item-icon">📊</span>
                    <span class="item-label"><span>Dashboard</span><small>Análises e relatórios</small></span>
                    <span class="item-badge">Novo</span>
                </button>
                <button class="config-dropdown-item" id="menu-dashboard-vendas">
                    <span class="item-icon">🛒</span>
                    <span class="item-label"><span>Dashboard Vendas</span><small>Relatórios de vendas</small></span>
                    <span class="item-badge">Novo</span>
                </button>
                <button class="config-dropdown-item" id="menu-vendas">
                    <span class="item-icon">🛍️</span>
                    <span class="item-label"><span>Vendas</span><small>Área de vendas</small></span>
                    <span class="item-badge">Novo</span>
                </button>
                <button class="config-dropdown-item" id="menu-estoque">
                    <span class="item-icon">📦</span>
                    <span class="item-label"><span>Estoque</span><small>Lançamentos e movimentações</small></span>
                    <span class="item-badge">Novo</span>
                </button>
                <div class="config-dropdown-sep"></div>
                <div class="config-dropdown-label">Cadastros</div>
                <button class="config-dropdown-item" id="menu-empresa">
                    <span class="item-icon">🏢</span>
                    <span class="item-label"><span>Empresa</span><small>Dados e identidade visual</small></span>
                </button>
                <button class="config-dropdown-item" id="menu-admins">
                    <span class="item-icon">👤</span>
                    <span class="item-label"><span>Admins</span><small>Usuários e acessos</small></span>
                    <span class="item-badge">Novo</span>
                </button>
                <button class="config-dropdown-item" id="menu-clientes">
                    <span class="item-icon">👥</span>
                    <span class="item-label"><span>Clientes</span><small>Ranking e histórico</small></span>
                    <span class="item-badge">Novo</span>
                </button>
                <button class="config-dropdown-item" id="menu-servicos">
                    <span class="item-icon">✂️</span>
                    <span class="item-label"><span>Serviços</span><small>Preços e catálogo</small></span>
                </button>
                <button class="config-dropdown-item" id="menu-produtos">
                    <span class="item-icon">📦</span>
                    <span class="item-label"><span>Produtos</span><small>Produtos</small></span>
                    <span class="item-badge">Novo</span>
                </button>
                <div class="config-dropdown-sep"></div>
                <div class="config-dropdown-label">Agenda</div>
                <button class="config-dropdown-item" id="menu-feriados">
                    <span class="item-icon">📅</span>
                    <span class="item-label"><span>Feriados</span><small>Datas bloqueadas</small></span>
                </button>
                <button class="config-dropdown-item" id="menu-horarios">
                    <span class="item-icon">🕐</span>
                    <span class="item-label"><span>Horários</span><small>Funcionamento por dia</small></span>
                </button>
            </div>
        </div>
        <button class="btn-sair" id="btn-sair">Sair</button>
    </div>
</div>

<!-- ── Body ── -->
<div class="adm-body">

    <!-- Chips de barbeiros no topo -->
    <div class="barber-chips-bar" id="barber-chips-bar">
        <button class="barber-chip-top active" data-barbeiro="todos">
            <i class="fa-solid fa-users" style="font-size:11px;opacity:.6"></i> Todos
            <span class="barber-chip-count" id="chip-count-todos">0</span>
        </button>
        {{#each barbeiros}}
        <button class="barber-chip-top" data-barbeiro="{{nome}}">
            <span class="barber-chip-avatar">{{substr nome 0 1}}</span>
            {{nome}}
            <span class="barber-chip-count" data-count-barbeiro="{{nome}}">0</span>
        </button>
        {{/each}}
    </div>

    <main class="adm-content">
        <div class="stats-bar">
            <div class="stat-item">
                <div class="stat-label">Total hoje</div>
                <div class="stat-value gold" id="stat-hoje">0</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">Esta semana</div>
                <div class="stat-value" id="stat-semana">0</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">Este mês</div>
                <div class="stat-value" id="stat-total">0</div>
            </div>
        </div>

        <div class="cal-nav">
            <button class="date-nav-btn" id="prev-week"><i class="fa-solid fa-chevron-left"></i></button>
            <span class="cal-nav-label" id="cal-nav-label"></span>
            <button class="date-nav-btn" id="btn-hoje">Hoje</button>
            <button class="date-nav-btn" id="next-week"><i class="fa-solid fa-chevron-right"></i></button>
            <button class="btn-novo" id="btn-novo" title="Novo agendamento">+</button>
        </div>

        <div class="cal-wrap">
            <div class="cal-grid" id="cal-grid"></div>
        </div>

        <div class="empty-state" id="empty-state">
            <div class="empty-icon">✂️</div>
            <p>Nenhum agendamento para esta semana</p>
        </div>
    </main>
</div>

<!-- MODAL NOVO AGENDAMENTO -->
<div class="modal-overlay" id="modal-overlay">
    <div class="modal">
        <button class="modal-close" id="modal-close">✕</button>
        <div class="modal-title">Novo Agendamento</div>
        <p class="modal-sub">Cadastro rápido pelo admin</p>
        <div style="display:flex; gap:8px; margin-bottom:16px;">
            <button type="button" id="btnTipoAgendamento" class="btn-tipo ativo"
                onclick="alternarTipo('agendamento')">Agendamento</button>
            <button type="button" id="btnTipoCompromisso" class="btn-tipo"
                onclick="alternarTipo('compromisso')">Compromisso</button>
        </div>
        <form action="/admin/agendar" method="post" id="form-admin" novalidate>
            <input type="hidden" name="tipo" id="inputTipo" value="agendamento">
            <div class="modal-grid">
                <div id="campoMotivo" style="display:none;" class="modal-grid">
                    <div class="modal-field full">
                        <label>Motivo</label>
                        <input type="text" name="motivo" id="inputMotivo" placeholder="Ex: Almoço, Reunião...">
                    </div>
                    <div class="modal-field">
                        <label>Hora Início</label>
                        <input type="time" name="compromisso_inicio" id="compromisso-inicio">
                    </div>
                    <div class="modal-field">
                        <label>Hora Fim</label>
                        <input type="time" name="compromisso_fim" id="compromisso-fim">
                    </div>
                </div>
                <div id="campoNome" class="modal-field full" style="position:relative;">
                    <label>Nome do cliente</label>
                    <div style="display:flex;gap:6px;">
                        <input type="text" name="nome" id="modal-nome" placeholder="Nome completo" autocomplete="off"
                            style="flex:1;" oninput="onNomeInput(this.value)">
                        <button type="button" title="Buscar cliente cadastrado" onclick="toggleBuscaCliente()" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;
           width:36px;height:36px;cursor:pointer;font-size:13px;color:var(--gold);
           flex-shrink:0;display:flex;align-items:center;justify-content:center;
           transition:border-color .2s;" onmouseover="this.style.borderColor='var(--gold)'"
                            onmouseout="this.style.borderColor='var(--border)'">🔍</button>
                    </div>
                    <!-- dropdown de sugestões -->
                    <div id="cliente-suggestions" style="display:none;position:absolute;top:100%;left:0;right:36px;z-index:999;
                background:var(--bg2);border:1px solid var(--gold);border-radius:8px;
                overflow:hidden;box-shadow:0 8px 24px rgba(0,0,0,0.4);margin-top:2px;">
                    </div>
                </div>
                <div id="campoTelefone" class="modal-field full">
                    <label>Telefone</label>
                    <input type="tel" name="telefone" id="modal-telefone" placeholder="(00) 00000-0000">
                </div>
                <div class="modal-field full">
                    <label>Funcionário</label>
                    <select name="barbeiro" id="modal-barbeiro" required>
                        <option value="">Selecione</option>
                        {{#each barbeiros}}<option value="{{nome}}" data-id="{{id}}">{{nome}}</option>{{/each}}
                    </select>
                </div>
                <div id="campoServico" class="modal-field full">
                    <label>Serviço</label>
                    <select name="servico" id="modal-servico">
                        <option value="">Selecione</option>
                        {{#each servicos}}<option value="{{nome}}" data-id="{{id}}" data-sessoes="{{qtd_sessoes}}">
                            {{nome}} — R$ {{valor}}</option>
                        {{/each}}
                    </select>
                </div>
                <div id="campoPacote" style="display:none;" class="modal-field full">
                    <label
                        style="font-size:10px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;margin-bottom:8px;display:block;">Sessões
                        do Pacote</label>
                    <div id="lista-sessoes" style="display:flex;flex-direction:column;gap:10px;"></div>
                </div>
                <div class="modal-field"><label>Data</label><input type="date" name="data" id="modal-data" required>
                </div>
                <div class="modal-field">
                    <label>Horário</label>
                    <select name="horario" id="modal-horario">
                        <option value="">Selecione Funcionário, serviço e data</option>
                    </select>
                </div>
                <input type="hidden" name="profissional_id" id="modal-profissional-id">
                <input type="hidden" name="hora_inicio" id="modal-hora-inicio">
                <input type="hidden" name="hora_fim" id="modal-hora-fim">
                <input type="hidden" name="servico_id" id="modal-servico-id">
            </div>
            <div class="modal-erro" id="modal-erro"></div>
            <div class="modal-actions">
                <button type="button" class="btn-cancelar" id="btn-cancelar">Cancelar</button>
                <button type="submit" class="btn-confirmar">Salvar</button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL FERIADOS -->
<div class="modal-overlay" id="modal-feriados-overlay">
    <div class="modal">
        <button class="modal-close" id="modal-feriados-close">✕</button>
        <div class="modal-title">Feriados</div>
        <p class="modal-sub">Datas bloqueadas para agendamento</p>
        <div class="modal-grid">
            <div class="modal-field"><label>Data</label><input type="date" id="feriado-data"></div>
            <div class="modal-field"><label>Descrição</label><input type="text" id="feriado-desc"
                    placeholder="Ex: Natal"></div>
        </div>
        <div style="margin-top:12px;"><button class="btn-confirmar" id="btn-add-feriado"
                style="width:100%;font-size:15px;padding:10px;">+ Adicionar Feriado</button></div>
        <div class="modal-erro" id="feriado-erro"></div>
        <div class="feriados-sep"></div>
        <p style="font-size:10px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:8px;">
            Feriados cadastrados</p>
        <div class="feriado-lista" id="feriado-lista">
            <div class="feriados-empty">Carregando...</div>
        </div>
    </div>
</div>

<!-- MODAL SERVIÇOS -->
<div class="modal-overlay" id="modal-servicos-overlay">
    <div class="modal">
        <button class="modal-close" id="modal-servicos-close">✕</button>
        <div class="modal-title">Serviços</div>
        <p class="modal-sub">Gerencie os serviços e valores</p>
        <div class="modal-grid">
            <div class="modal-field full"><label>Nome do serviço</label><input type="text" id="servico-nome-input"
                    placeholder="Ex: Corte + Barba"></div>
            <div class="modal-field full"><label>Descrição</label><input type="text" id="servico-descricao-input"
                    placeholder="Ex: Corte social com acabamento"></div>
            <div class="modal-field"><label>Valor (R$)</label><input type="number" id="servico-valor-input"
                    placeholder="0,00" step="0.01" min="0"></div>
            <div class="modal-field"><label>Duração (min)</label><input type="number" id="servico-duracao-input"
                    placeholder="Ex: 30" min="1"></div>
            <div class="modal-field"><label>Sessões (pacote)</label><input type="number" id="servico-sessoes-input"
                    placeholder="Ex: 4 (deixe vazio se não for pacote)" min="2"></div>
            <div class="form-group">
                <label>Observação</label>
                <textarea name="observacao" rows="3"
                    style="width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px 12px;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--text);outline:none;resize:vertical;"
                    onfocus="this.style.borderColor='var(--gold)'" onblur="this.style.borderColor='var(--border)'"
                    placeholder="Anotações sobre este agendamento...">{{agendamento.observacao}}</textarea>
            </div>
            <div class="modal-field" style="justify-content:flex-end;"><label>&nbsp;</label><button
                    class="btn-confirmar" id="btn-add-servico" style="padding:10px 16px;font-size:15px;">+
                    Adicionar</button></div>
        </div>
        <div class="modal-erro" id="servico-erro"></div>
        <div class="servicos-sep"></div>
        <p style="font-size:10px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:8px;">
            Serviços cadastrados</p>
        <div class="servico-lista" id="servico-lista">
            <div class="servicos-empty">Carregando...</div>
        </div>
    </div>
</div>

<!-- MODAL EMPRESA -->
<div class="modal-overlay" id="modal-empresa-overlay">
    <div class="modal">
        <button class="modal-close" id="modal-empresa-close">✕</button>
        <div class="modal-title">Dados da Empresa</div>
        <p class="modal-sub">Informações cadastrais e identidade visual</p>
        <div class="modal-grid">
            <div class="modal-field full">
                <label>Logo da Empresa</label>
                <div style="display:flex;align-items:center;gap:12px;">
                    <div id="empresa-logo-preview"
                        style="width:56px;height:56px;border-radius:8px;background:var(--bg3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--muted);overflow:hidden;flex-shrink:0;">
                        Logo</div>
                    <div style="display:flex;flex-direction:column;gap:4px;">
                        <label for="empresa-logo-input"
                            style="cursor:pointer;font-size:12px;padding:6px 12px;border:1px solid var(--border);border-radius:6px;color:var(--muted);transition:all .2s;"
                            onmouseover="this.style.borderColor='var(--gold)';this.style.color='var(--gold)'"
                            onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--muted)'">Escolher
                            imagem</label>
                        <span style="font-size:10px;color:var(--muted);">PNG, JPG ou SVG · máx. 2MB</span>
                    </div>
                    <div id="campoObservacao" class="modal-field full">
                        <label>Observação / Aviso para clientes</label>
                        <textarea id="empresa-observacao-input"
                            placeholder="Ex: Cancelamentos com menos de 2 dias terão cobrança de 50% no próximo atendimento."
                            style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px 12px;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--text);outline:none;transition:border-color .2s;width:100%;resize:vertical;min-height:80px;"
                            onfocus="this.style.borderColor='var(--gold)'"
                            onblur="this.style.borderColor='var(--border)'"></textarea>
                    </div>
                    <input type="file" id="empresa-logo-input" accept="image/*" style="display:none" onchange="
                        const f=this.files[0]; if(!f) return;
                        const r=new FileReader(); r.onload=e=>{
                            const p=document.getElementById('empresa-logo-preview');
                            p.innerHTML='<img src=\''+e.target.result+'\' style=\'width:100%;height:100%;object-fit:contain;border-radius:6px;padding:4px;\'>';
                        }; r.readAsDataURL(f);">
                </div>
            </div>
            <div class="modal-field full"><label>Razão Social</label><input type="text" id="empresa-nome-input"
                    placeholder="Ex: Silva Ltda"></div>
            <div class="modal-field"><label>Nome Fantasia</label><input type="text" id="empresa-fantasia-input"
                    placeholder="Ex: Silva"></div>
            <div class="modal-field"><label>CNPJ</label><input type="text" id="empresa-cnpj-input"
                    placeholder="00.000.000/0001-00" maxlength="18" oninput="
                let v=this.value.replace(/\D/g,'');
                v=v.replace(/^(\d{2})(\d)/,'$1.$2');
                v=v.replace(/^(\d{2})\.(\d{3})(\d)/,'$1.$2.$3');
                v=v.replace(/\.(\d{3})(\d)/,'.$1/$2');
                v=v.replace(/(\d{4})(\d)/,'$1-$2');
                this.value=v;"></div>
            <div class="modal-field"><label>Celular / WhatsApp</label><input type="tel" id="empresa-celular-input"
                    placeholder="(00) 00000-0000" maxlength="15" oninput="
                let v=this.value.replace(/\D/g,'');
                v=v.replace(/^(\d{2})(\d)/,'($1) $2');
                v=v.replace(/(\d{5})(\d{4})$/,'$1-$2');
                this.value=v;"></div>
            <div class="modal-field"><label>Segmento</label><input type="text" id="empresa-segmento-input"
                    placeholder="Ex: Barbearia, Salão, Clínica..."></div>
            <div class="modal-field full"><label>Endereço</label><input type="text" id="empresa-endereco-input"
                    placeholder="Rua, Avenida..."></div>
            <div class="modal-field" style="max-width:120px;"><label>Número</label><input type="text"
                    id="empresa-numero-input" placeholder="123"></div>
            <div class="modal-field"><label>Bairro</label><input type="text" id="empresa-bairro-input"
                    placeholder="Centro"></div>
            <div class="modal-field"><label>Cidade</label><input type="text" id="empresa-cidade-input"
                    placeholder="São Paulo"></div>
            <div class="modal-field full">
                <label>Estilo / Tema</label>
                <select id="empresa-estilo-input"
                    style="width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px 12px;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--text);outline:none;">
                    <option value="1">🟡 Clássico (dourado)</option>
                    <option value="2">🌸 Claro (rosa e branco)</option>
                </select>
            </div>
        </div>
        <div style="margin-top:16px;">
            <button class="btn-confirmar" id="btn-salvar-empresa" style="width:100%;font-size:15px;padding:10px;">Salvar
                Dados da Empresa</button>
        </div>
        <div class="modal-erro" id="empresa-erro"></div>
    </div>
</div>

<!-- MODAL ADMINS -->
<div class="modal-overlay" id="modal-admins-overlay">
    <div class="modal" style="max-height: 90vh; overflow-y: auto;">
        <button class="modal-close" id="modal-admins-close">✕</button>
        <div class="modal-title">Administradores</div>
        <p class="modal-sub">Gerencie os usuários com acesso ao painel</p>
        <div class="modal-grid">
            <div class="modal-field full"><label>Nome</label><input type="text" id="admin-nome-input"
                    placeholder="Ex: João Silva"></div>
            <div class="modal-field full"><label>E-mail</label><input type="email" id="admin-email-input"
                    placeholder="joao@gmail.com"></div>
            <div class="modal-field full"><label>Telefone</label><input type="tel" id="admin-tel-input"
                    placeholder="(00) 00000-0000"></div>
            <div class="modal-field">
                <label>Senha</label>
                <div class="input-pass-wrap">
                    <input type="password" id="admin-senha-input" placeholder="Mínimo 6 caracteres">
                    <button class="btn-toggle-pass" id="btn-toggle-pass" type="button">👁</button>
                </div>
            </div>
            <div class="modal-field">
                <label>Perfil</label>
                <select id="admin-role-select">
                    <option value="admin">Admin</option>
                    <option value="owner">Owner (acesso total)</option>
                </select>
            </div>
            <div class="modal-field full">
                <label>Foto (opcional)</label>
                <div style="display:flex;align-items:center;gap:10px;">
                    <div id="admin-foto-preview"
                        style="width:36px;height:36px;border-radius:50%;background:var(--bg3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--muted);overflow:hidden;flex-shrink:0;">
                        ?</div>
                    <label for="admin-foto-input"
                        style="cursor:pointer;font-size:12px;padding:6px 12px;border:1px solid var(--border);border-radius:6px;color:var(--muted);transition:all .2s;"
                        onmouseover="this.style.borderColor='var(--gold)';this.style.color='var(--gold)'"
                        onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--muted)'">Escolher
                        foto</label>
                    <input type="file" id="admin-foto-input" accept="image/*" style="display:none" onchange="
                        const f=this.files[0]; if(!f) return;
                        const r=new FileReader(); r.onload=e=>{
                            const p=document.getElementById('admin-foto-preview');
                            p.innerHTML='<img src=\''+e.target.result+'\' style=\'width:100%;height:100%;object-fit:cover;border-radius:50%;\'>';
                        }; r.readAsDataURL(f);">
                </div>
            </div>
        </div>
        <div style="margin-top:4px;"><button class="btn-confirmar" id="btn-add-admin"
                style="width:100%;font-size:15px;padding:10px;">+ Adicionar Admin</button></div>
        <div class="modal-erro" id="admin-erro"></div>
        <div class="admins-sep"></div>
        <p style="font-size:10px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:8px;">
            Admins cadastrados</p>
        <div class="admin-lista" id="admin-lista">
            <div class="admins-empty">Carregando...</div>
        </div>
    </div>
</div>

<!-- MODAL EMPRESA -->
<div class="modal-overlay" id="modal-empresa-overlay">
    <div class="modal">
        <button class="modal-close" id="modal-empresa-close">✕</button>
        <div class="modal-title">Dados da Empresa</div>
        <p class="modal-sub">Informações cadastrais e identidade visual</p>

        <div class="modal-grid">

            <!-- LOGO -->
            <div class="modal-field full">
                <label>Logo da Empresa</label>
                <div style="display:flex;align-items:center;gap:12px;">
                    <div id="empresa-logo-preview"
                        style="width:56px;height:56px;border-radius:8px;background:var(--bg3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--muted);overflow:hidden;flex-shrink:0;">
                        Logo
                    </div>
                    <div style="display:flex;flex-direction:column;gap:4px;">
                        <label for="empresa-logo-input"
                            style="cursor:pointer;font-size:12px;padding:6px 12px;border:1px solid var(--border);border-radius:6px;color:var(--muted);transition:all .2s;"
                            onmouseover="this.style.borderColor='var(--gold)';this.style.color='var(--gold)'"
                            onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--muted)'">Escolher
                            imagem</label>
                        <span style="font-size:10px;color:var(--muted);">PNG, JPG ou SVG · máx. 2MB</span>
                    </div>
                    <input type="file" id="empresa-logo-input" accept="image/*" style="display:none" onchange="
                        const f=this.files[0]; if(!f) return;
                        const r=new FileReader(); r.onload=e=>{
                            const p=document.getElementById('empresa-logo-preview');
                            p.innerHTML='<img src=\''+e.target.result+'\' style=\'width:100%;height:100%;object-fit:contain;border-radius:6px;padding:4px;\'>';
                        }; r.readAsDataURL(f);">
                </div>
            </div>

            <!-- IDENTIFICAÇÃO -->
            <div class="modal-field full">
                <label>Razão Social</label>
                <input type="text" id="empresa-nome-input" placeholder="Ex: Barbearia Silva Ltda">
            </div>
            <div class="modal-field">
                <label>Nome Fantasia</label>
                <input type="text" id="empresa-fantasia-input" placeholder="Ex: Barbearia Silva">
            </div>
            <div class="modal-field">
                <label>CNPJ</label>
                <input type="text" id="empresa-cnpj-input" placeholder="00.000.000/0001-00" maxlength="18" oninput="
                    let v=this.value.replace(/\D/g,'');
                    v=v.replace(/^(\d{2})(\d)/,'$1.$2');
                    v=v.replace(/^(\d{2})\.(\d{3})(\d)/,'$1.$2.$3');
                    v=v.replace(/\.(\d{3})(\d)/,'.$1/$2');
                    v=v.replace(/(\d{4})(\d)/,'$1-$2');
                    this.value=v;">
            </div>

            <!-- CONTATO -->
            <div class="modal-field">
                <label>Celular / WhatsApp</label>
                <input type="tel" id="empresa-celular-input" placeholder="(00) 00000-0000" maxlength="15" oninput="
                    let v=this.value.replace(/\D/g,'');
                    v=v.replace(/^(\d{2})(\d)/,'($1) $2');
                    v=v.replace(/(\d{5})(\d{4})$/,'$1-$2');
                    this.value=v;">
            </div>
            <div class="modal-field">
                <label>Segmento</label>
                <input type="text" id="empresa-segmento-input" placeholder="Ex: Barbearia, Salão, Clínica...">
            </div>

            <!-- ENDEREÇO -->
            <div class="modal-field full">
                <label>Endereço</label>
                <input type="text" id="empresa-endereco-input" placeholder="Rua, Avenida...">
            </div>
            <div class="modal-field" style="max-width:120px;">
                <label>Número</label>
                <input type="text" id="empresa-numero-input" placeholder="123">
            </div>
            <div class="modal-field">
                <label>Bairro</label>
                <input type="text" id="empresa-bairro-input" placeholder="Centro">
            </div>
            <div class="modal-field">
                <label>Cidade</label>
                <input type="text" id="empresa-cidade-input" placeholder="São Paulo">
            </div>

        </div>

        <div style="margin-top:16px;">
            <button class="btn-confirmar" id="btn-salvar-empresa" style="width:100%;font-size:15px;padding:10px;">
                Salvar Dados da Empresa
            </button>
        </div>
        <div class="modal-erro" id="empresa-erro"></div>
    </div>
</div>

<!-- MODAL HORÁRIOS -->
<div class="modal-overlay" id="modal-horarios-overlay">
    <div class="modal">
        <button class="modal-close" id="modal-horarios-close">✕</button>
        <div class="modal-title">Horários</div>
        <p class="modal-sub">Configure os horários de atendimento por profissional</p>
        <p style="font-size:10px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:10px;">
            Profissional</p>
        <div class="horario-prof-select" id="horario-prof-select">
            {{#each barbeiros}}<button class="horario-prof-chip" data-id="{{id}}"
                data-nome="{{nome}}">{{nome}}</button>{{/each}}
        </div>
        <p style="font-size:10px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:10px;">Dia
            da semana</p>
        <div class="horario-dias-grid">
            <button class="horario-dia-btn" data-dia="0">Dom</button>
            <button class="horario-dia-btn" data-dia="1">Seg</button>
            <button class="horario-dia-btn" data-dia="2">Ter</button>
            <button class="horario-dia-btn" data-dia="3">Qua</button>
            <button class="horario-dia-btn" data-dia="4">Qui</button>
            <button class="horario-dia-btn" data-dia="5">Sex</button>
            <button class="horario-dia-btn" data-dia="6">Sáb</button>
        </div>
        <div class="modal-grid">
            <div class="modal-field"><label>Hora início</label><input type="time" id="horario-inicio-input"></div>
            <div class="modal-field"><label>Hora fim</label><input type="time" id="horario-fim-input"></div>
        </div>
        <div style="margin-top:12px;"><button class="btn-confirmar" id="btn-add-horario"
                style="width:100%;font-size:15px;padding:10px;">+ Adicionar Horário</button></div>
        <div class="modal-erro" id="horario-erro"></div>
        <div class="horarios-sep"></div>
        <p style="font-size:10px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:8px;">
            Horários cadastrados</p>
        <div class="horario-lista" id="horario-lista">
            <div class="horarios-empty">Selecione um profissional acima</div>
        </div>
    </div>
</div>

<script>
    // ── Dados do backend ──────────────────────────────────
    const todosAgendamentos = [
        {{#each agendamentos}}
    {id: {{id}}, nome: "{{nome}}", telefone: "{{telefone}}", data: "{{data}}", horario: "{{horario}}", hora_fim: "{{hora_fim}}", servico: "{{servico}}", barbeiro: "{{barbeiro}}", pago: {{#if pago}} 1{{else}} 0{{/if}}, pacote_id: "{{pacote_id}}" },
    {{/each}}
    ];

    const DIAS = ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'];
    const MESES_FULL = ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'];
    const HORAS = Array.from({ length: 19 }, (_, i) => `${String(i + 5).padStart(2, '0')}:00`);
    const DIAS_NOMES = ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'];

    let weekOffset = 0;
    let filtroBarbeiro = 'todos';
    let horarioProfSelecionado = null;
    let horarioDiaSelecionado = null;
    let mobileDayOffset = 0;

    const isMobile = () => window.innerWidth <= 900;

    function fmtDate(d) {
        return `${String(d.getDate()).padStart(2, '0')}/${String(d.getMonth() + 1).padStart(2, '0')}/${d.getFullYear()}`;
    }

    const currentMonth = fmtDate(new Date()).slice(3, 10);

    const tokenAgendamento = "{{empresa.token_agendamento}}";
    const linkAgendamento = `https://lpsolutions.online/loginUsuario/${tokenAgendamento}`;

    const inputLink = document.getElementById("input-link-agendamento");
    const btnCopiar = document.getElementById("btn-copiar-link");
    const btnWhatsapp = document.getElementById("btn-whatsapp-link");

    inputLink.value = linkAgendamento;

    btnCopiar.addEventListener("click", () => {
        navigator.clipboard.writeText(linkAgendamento);
        btnCopiar.innerText = "Copiado ✓";
        btnCopiar.style.background = "#16a34a";

        setTimeout(() => {
            btnCopiar.innerText = "Copiar";
            btnCopiar.style.background = "linear-gradient(135deg,#4f46e5,#7c3aed)";
        }, 2000);
    });

    btnWhatsapp.addEventListener("click", () => {
        const mensagem = `Olá! Faça seu agendamento online pelo link:\n${linkAgendamento}`;
        window.open(`https://wa.me/?text=${encodeURIComponent(mensagem)}`, "_blank");
    });


    // ── Popup ──────────────────────────────────────────────
    const popup = document.createElement('div');
    popup.className = 'cal-popup';
    popup.innerHTML = `
        <div class="cal-popup-header">
            <div>
                <div class="cal-popup-nome" id="popup-nome"></div>
                <div class="cal-popup-meta" id="popup-meta"></div>
            </div>
            <button id="popup-pago" class="btn-pago-mini nao-pago" title="Não pago — clique para marcar"></button>
        </div>
        <div class="cal-popup-actions">
            <a id="popup-editar" href="#" class="btn-edit"><i class="fa-solid fa-pen"></i> Editar</a>
            <a id="popup-whatsapp" href="#" target="_blank" class="btn-whatsapp">
                <i class="fa-brands fa-whatsapp"></i> Confirmar
            </a>
            <a id="popup-excluir" href="#" class="btn-del" onclick="return confirm('Excluir este agendamento?')">
                <i class="fa-solid fa-trash"></i> Excluir
            </a>
        </div>`;
    document.body.appendChild(popup);

    document.addEventListener('click', e => {
        if (e.target.closest('#popup-pago')) return;
        if (!popup.contains(e.target) && !e.target.closest('.cal-event') && !e.target.closest('.cal-mobile-event')) {
            popup.classList.remove('open');
        }
    });

    async function abrirPopup(e, a) {
        e.stopPropagation();
        const target = e.currentTarget; // 👈 salva aqui

        document.getElementById('popup-nome').textContent = a.nome;
        const horaFim = a.hora_fim ? a.hora_fim.substring(0, 5) : '';
        const intervalo = horaFim ? `${a.horario} – ${horaFim}` : a.horario;
        document.getElementById('popup-meta').textContent = `${intervalo} · ${a.servico} · ${a.barbeiro}`;
        document.getElementById('popup-editar').href = `/editar/${a.id}`;
        document.getElementById('popup-excluir').href = `/deletar/${a.id}`;

        // Busca observação da empresa
        const resp = await fetch('/admin/empresa-observacao');
        const dados = await resp.json();
        const observacao = dados.observacao || '';

        // 👇 Botão pago
        const btnPago = document.getElementById('popup-pago');
        btnPago.dataset.id = a.id;
        btnPago.className = `btn-pago-mini ${a.pago ? 'pago' : 'nao-pago'}`;
        btnPago.title = a.pago ? 'Pago ✅' : 'Não pago — clique para marcar';

        // Monta link WhatsApp
        const tel = a.telefone.replace(/\D/g, '');
        const mensagem = encodeURIComponent(
            `Olá ${a.nome}! 👋\n\nPassando para confirmar seu agendamento:\n📅 Data: ${a.data}\n🕐 Horário: ${a.horario}\n✂️ Serviço: ${a.servico}\n💈 Profissional: ${a.barbeiro}` +
            (observacao ? `\n📝  ${observacao}` : '') +
            `\n\nPor favor, confirme sua presença. Até lá!`
        );
        document.getElementById('popup-whatsapp').href = `https://wa.me/55${tel}?text=${mensagem}`;

        popup.classList.add('open');
        const rect = target.getBoundingClientRect(); // 👈 usa target aqui
        popup.style.top = (rect.bottom + 8 + window.scrollY) + 'px';
        popup.style.left = (rect.left + window.scrollX) + 'px';
        requestAnimationFrame(() => {
            const pr = popup.getBoundingClientRect();
            if (pr.right > window.innerWidth - 8) popup.style.left = (window.innerWidth - pr.width - 8) + 'px';
            if (pr.bottom > window.innerHeight - 8) popup.style.top = (rect.top + window.scrollY - pr.height - 8) + 'px';
        });
    }
    //Marcar como pago
    document.body.addEventListener('click', async e => {
        const btn = e.target.closest('#popup-pago');
        if (!btn) return;
        e.stopPropagation();
        e.preventDefault();
        const id = btn.dataset.id;
        if (!id) return;

        const res = await fetch(`/agendamentos/${id}/pago`, { method: 'PATCH' });
        const json = await res.json();
        if (json.sucesso) {
            const ag = todosAgendamentos.find(a => a.id == id);

            if (ag?.pacote_id) {
                // Atualiza todos do mesmo pacote no array
                todosAgendamentos
                    .filter(a => a.pacote_id == ag.pacote_id)
                    .forEach(a => a.pago = json.pago);
            } else {
                if (ag) ag.pago = json.pago;
            }

            btn.className = `btn-pago-mini ${json.pago ? 'pago' : 'nao-pago'}`;
            btn.title = json.pago ? 'Pago ✅' : 'Não pago — clique para marcar';
            popup.classList.remove('open');
            renderCalendar();
        }
    });
    // Agendamento / compromisso 
    function alternarTipo(tipo) {
        const isCompromisso = tipo === 'compromisso';
        document.getElementById('inputTipo').value = tipo;

        document.getElementById('campoNome').style.display = isCompromisso ? 'none' : '';
        document.getElementById('campoTelefone').style.display = isCompromisso ? 'none' : '';
        document.getElementById('campoServico').style.display = isCompromisso ? 'none' : '';
        document.getElementById('campoObservacao').style.display = isCompromisso ? 'none' : '';
        document.getElementById('campoMotivo').style.display = isCompromisso ? '' : 'none';

        document.querySelector('[name="horario"]').closest('.modal-field').style.display = isCompromisso ? 'none' : '';

        document.querySelector('[name="horario"]').required = !isCompromisso;
        document.querySelector('[name="nome"]').required = !isCompromisso;
        document.querySelector('[name="telefone"]').required = !isCompromisso;
        document.querySelector('[name="servico"]').required = !isCompromisso;
        document.getElementById('compromisso-inicio').required = isCompromisso;
        document.getElementById('compromisso-fim').required = isCompromisso;

        document.getElementById('btnTipoAgendamento').classList.toggle('ativo', !isCompromisso);
        document.getElementById('btnTipoCompromisso').classList.toggle('ativo', isCompromisso);
        // 👆 fim da função — listener do barbeiro foi para fora
    }

    // 👇 Listener do barbeiro fora da função, registrado uma única vez
    document.getElementById('modal-barbeiro').addEventListener('change', function () {
        const opt = this.selectedOptions[0];
        document.getElementById('modal-profissional-id').value = opt?.dataset.id || '';
        if (document.getElementById('inputTipo').value !== 'compromisso') {
            buscarSlotsAdmin();
        }
    });

    // ── Calendário ────────────────────────────────────────
    function getWeekDates() {
        const today = new Date(); today.setHours(0, 0, 0, 0);
        const monday = new Date(today);
        monday.setDate(today.getDate() - today.getDay() + 1 + weekOffset * 7);
        return Array.from({ length: 7 }, (_, i) => { const d = new Date(monday); d.setDate(monday.getDate() + i); return d; });
    }

    function updateNavLabel(dates) {
        const label = document.getElementById('cal-nav-label');
        const ini = dates[0], fim = dates[6];
        label.textContent = ini.getMonth() === fim.getMonth()
            ? `${ini.getDate()} – ${fim.getDate()} ${MESES_FULL[ini.getMonth()]} ${ini.getFullYear()}`
            : `${ini.getDate()} ${MESES_FULL[ini.getMonth()].slice(0, 3)} – ${fim.getDate()} ${MESES_FULL[fim.getMonth()].slice(0, 3)} ${fim.getFullYear()}`;
    }

    function renderCalendar() {
        const grid = document.getElementById('cal-grid');
        grid.innerHTML = '';
        const weekDates = getWeekDates(); updateNavLabel(weekDates);
        const todayStr = fmtDate(new Date());
        const weekStrs = weekDates.map(d => fmtDate(d));
        const agendsSemana = todosAgendamentos.filter(a => weekStrs.includes(a.data));
        document.getElementById('empty-state').classList.toggle('visible', agendsSemana.length === 0);
        isMobile() ? renderMobile(grid, weekDates, todayStr) : renderDesktop(grid, weekDates, todayStr);
    }


    function renderDesktop(grid, weekDates, todayStr) {
        grid.style.gridTemplateColumns = `56px repeat(7, minmax(120px, 1fr))`;

        // Cabeçalho
        const thTime = document.createElement('div');
        thTime.className = 'cal-head-time';
        grid.appendChild(thTime);

        weekDates.forEach(d => {
            const isToday = fmtDate(d) === todayStr;
            const th = document.createElement('div');
            th.className = 'cal-head-cell' + (isToday ? ' today' : '');
            th.innerHTML = `<span class="cal-head-day">${DIAS[d.getDay()]} ${d.getDate()}</span>`;
            grid.appendChild(th);
        });

        // Linhas de horas
        HORAS.forEach(hora => {
            const timeCell = document.createElement('div');
            timeCell.className = 'cal-time-cell';
            timeCell.textContent = hora;
            grid.appendChild(timeCell);

            weekDates.forEach(d => {
                const str = fmtDate(d);
                const isToday = str === todayStr;
                const cell = document.createElement('div');
                cell.className = 'cal-cell' + (isToday ? ' hoje-col' : '');

                const eventos = todosAgendamentos.filter(a =>
                    a.data === str &&
                    a.horario.startsWith(hora.substring(0, 2)) &&
                    (filtroBarbeiro === 'todos' || a.barbeiro === filtroBarbeiro)
                );

                if (eventos.length > 0) {
                    eventos.forEach(a => {
                        const ev = document.createElement('div');
                        const isPacote = a.pacote_id && a.pacote_id !== 'undefined' && a.pacote_id !== '';
                        const cor = isPacote ? (a.pago ? '#27ae60' : '#e74c3c') : 'var(--gold)';

                        ev.className = 'cal-event' + (isPacote ? (a.pago ? ' pacote-pago' : ' pacote') : '');
                        ev.innerHTML = `
                        <div style="border-left: 3px solid ${cor}; padding-left: 5px; display: flex; flex-direction: column; position: relative;">
                            ${isPacote && !a.pago ? `<span style="position:absolute;top:-4px;right:-4px;width:8px;height:8px;background:#e74c3c;border-radius:50%;"></span>` : ''}
                            <span style="font-weight:bold;color:${cor};font-size:11px;text-transform:uppercase;">${a.barbeiro}</span>
                            <span style="color:#fff;font-size:13px;">${a.nome}</span>
                            <span style="font-size:10px;opacity:0.6;">${a.servico}${isPacote ? ' 📦' : ''}</span>
                        </div>`;
                        ev.addEventListener('click', e => abrirPopup(e, a));
                        cell.appendChild(ev);
                    });
                } else {
                    const vazio = document.createElement('div');
                    vazio.className = 'cal-slot-vazio';
                    vazio.textContent = '+';
                    cell.addEventListener('click', () => {
                        const [dd, mm, yy] = str.split('/');
                        document.getElementById('modal-data').value = `${yy}-${mm}-${dd}`;
                        if (filtroBarbeiro !== 'todos') {
                            const sel = document.getElementById('modal-barbeiro');
                            [...sel.options].forEach(o => { o.selected = o.value === filtroBarbeiro; });
                        }
                        overlay.classList.add('open');
                        buscarSlotsAdmin();
                    });
                    cell.appendChild(vazio);
                }
                grid.appendChild(cell);
            });
        });
    }

    function renderMobile(grid, weekDates, todayStr) {
        // Salva quais dias estão expandidos antes de limpar
        const expandidos = new Set();
        grid.querySelectorAll('.cal-mobile-day').forEach((day, i) => {
            const body = day.querySelector('div:last-child');
            if (body && body.style.maxHeight !== '0px' && body.style.maxHeight !== '') {
                expandidos.add(i);
            }
        });

        weekDates.forEach((d, index) => {
            const str = fmtDate(d);
            const isToday = str === todayStr;
            const eventos = todosAgendamentos.filter(a =>
                a.data === str && (filtroBarbeiro === 'todos' || a.barbeiro === filtroBarbeiro)
            ).sort((a, b) => a.horario.localeCompare(b.horario));

            const day = document.createElement('div');
            day.className = 'cal-mobile-day';
            day.style.cssText = 'border-radius:10px;overflow:hidden;border:1px solid var(--border);margin-bottom:6px;';

            const header = document.createElement('div');
            header.className = 'cal-mobile-day-header' + (isToday ? ' today' : '');
            header.style.cssText = `
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 10px 14px;
                cursor: pointer;
                user-select: none;
                background: ${isToday ? 'var(--bg3)' : 'var(--bg2)'};
            `;

            const leftInfo = document.createElement('div');
            leftInfo.style.cssText = 'display:flex;align-items:center;gap:12px;';

            const dateLabel = document.createElement('span');
            dateLabel.style.cssText = 'font-family:"Bebas Neue",sans-serif;font-size:1.1rem;letter-spacing:1px;color:' + (isToday ? 'var(--gold)' : 'var(--text)') + ';min-width:80px;';
            dateLabel.textContent = `${DIAS[d.getDay()]}, ${d.getDate()}`;

            const badge = document.createElement('span');
            badge.style.cssText = `
                font-size: 11px;
                padding: 2px 8px;
                border-radius: 20px;
                font-weight: 600;
                background: ${eventos.length > 0 ? 'rgba(184,134,11,0.18)' : 'transparent'};
                color: ${eventos.length > 0 ? 'var(--gold-light)' : 'var(--muted)'};
                border: ${eventos.length > 0 ? '1px solid var(--gold-dim)' : 'none'};
            `;
            badge.textContent = eventos.length > 0 ? `${eventos.length} agend.` : 'livre';

            leftInfo.appendChild(dateLabel);
            leftInfo.appendChild(badge);

            const arrow = document.createElement('span');
            arrow.style.cssText = 'font-size:13px;color:var(--muted);transition:transform 0.25s;display:inline-block;';
            arrow.textContent = '▼';

            header.appendChild(leftInfo);
            header.appendChild(arrow);

            const body = document.createElement('div');
            body.style.cssText = `
                max-height: 0;
                overflow: hidden;
                transition: max-height 0.3s ease, padding 0.2s;
                background: var(--bg1);
                padding: 0 14px;
            `;

            // Expande se era hoje OU se estava aberto antes do re-render
            let expanded = isToday || expandidos.has(index);

            function toggleDay() {
                expanded = !expanded;
                if (expanded) {
                    body.style.maxHeight = eventos.length > 0 ? '2000px' : '48px';
                    body.style.padding = '10px 14px';
                    arrow.style.transform = 'rotate(180deg)';
                } else {
                    body.style.maxHeight = '0';
                    body.style.padding = '0 14px';
                    arrow.style.transform = 'rotate(0deg)';
                }
            }

            if (expanded) {
                body.style.maxHeight = eventos.length > 0 ? '2000px' : '48px';
                body.style.padding = '10px 14px';
                arrow.style.transform = 'rotate(180deg)';
            }

            header.addEventListener('click', toggleDay);

            if (eventos.length === 0) {
                const empty = document.createElement('div');
                empty.style.cssText = 'font-size:12px;color:var(--muted);padding:4px 0 8px;';
                empty.textContent = 'Sem agendamentos';
                body.appendChild(empty);
            } else {
                eventos.forEach(a => {
                    const isPacote = a.pacote_id && a.pacote_id !== 'undefined' && a.pacote_id !== '';
                    const cor = isPacote ? (a.pago ? '#27ae60' : '#e74c3c') : 'var(--gold-dim)';
                    const corBorda = isPacote ? (a.pago ? '#27ae60' : '#e74c3c') : 'var(--border)';

                    const ev = document.createElement('div');
                    ev.className = 'cal-mobile-event';
                    ev.style.cssText = 'display:flex;align-items:stretch;margin-bottom:10px;cursor:pointer;';
                    ev.innerHTML = `
                        <div style="font-family:'Bebas Neue';font-size:1.15rem;color:${isPacote ? cor : 'var(--gold-light)'};min-width:52px;padding-top:2px;">${a.horario}</div>
                        <div style="width:2px;background:${cor};margin:0 12px;position:relative;">
                            <div style="width:7px;height:7px;background:${isPacote ? cor : 'var(--gold)'};border-radius:50%;position:absolute;left:-3px;top:5px;"></div>
                        </div>
                        <div style="flex:1;background:var(--bg3);padding:8px 10px;border-radius:8px;border:1px solid ${corBorda};">
                            <div style="font-weight:bold;color:var(--text);font-size:13px;">
                                ${a.nome} ${isPacote ? '📦' : ''}
                            </div>
                            <div style="font-size:11px;color:var(--muted);margin-top:2px;">
                                ✂️ ${a.servico} &nbsp;·&nbsp; 👤 ${a.barbeiro}
                            </div>
                        </div>`;
                    ev.addEventListener('click', e => {
                        e.preventDefault();
                        e.stopPropagation();
                        abrirPopup(e, a);
                    }, { passive: false });
                    body.appendChild(ev);
                });
            }

            day.appendChild(header);
            day.appendChild(body);
            grid.appendChild(day);
        });
    }

    function renderStats() {
        const today = fmtDate(new Date());
        const weekStrs = getWeekDates().map(d => fmtDate(d));
        document.getElementById('stat-hoje').textContent = todosAgendamentos.filter(a => a.data === today).length;
        document.getElementById('stat-semana').textContent = todosAgendamentos.filter(a => weekStrs.includes(a.data)).length;
        document.getElementById('stat-total').textContent = todosAgendamentos.filter(a => a.data.slice(3, 10) === currentMonth).length;
    }

    function renderCounts() {
        const weekStrs = getWeekDates().map(d => fmtDate(d));
        document.querySelectorAll('[data-count-barbeiro]').forEach(el => {
            el.textContent = todosAgendamentos.filter(a => a.barbeiro === el.dataset.countBarbeiro && weekStrs.includes(a.data)).length;
        });
        const totalEl = document.getElementById('chip-count-todos');
        if (totalEl) totalEl.textContent = todosAgendamentos.filter(a => weekStrs.includes(a.data)).length;
    }

    // ── Navegação ─────────────────────────────────────────
    document.getElementById('prev-week').addEventListener('click', () => { weekOffset--; renderCalendar(); renderCounts(); });
    document.getElementById('next-week').addEventListener('click', () => { weekOffset++; renderCalendar(); renderCounts(); });
    document.getElementById('btn-hoje').addEventListener('click', () => { weekOffset = 0; renderCalendar(); renderCounts(); });
    document.getElementById('btn-sair').addEventListener('click', () => { window.location.href = '/logout'; });
    document.getElementById('menu-clientes').addEventListener('click', () => { window.location.href = '/clientes'; });
    document.getElementById('menu-estoque').addEventListener('click', () => { toggleDropdown(false); window.location.href = '/admin/estoque'; });
    let _lastWidth = window.innerWidth;
    window.addEventListener('resize', () => {
        if (window.innerWidth !== _lastWidth) {
            _lastWidth = window.innerWidth;
            renderCalendar();
        }
    });
    // ── Filtro barbeiros ──────────────────────────────────
    document.querySelectorAll('.barber-chip-top').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.barber-chip-top').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            filtroBarbeiro = btn.dataset.barbeiro;
            renderCalendar();
            renderCounts();
        });
    });

    // ── Menu Configurações ────────────────────────────────
    const btnMenu = document.getElementById('btn-config-menu');
    const dropdown = document.getElementById('config-dropdown');

    function toggleDropdown(force) {
        const next = force !== undefined ? force : !dropdown.classList.contains('open');
        dropdown.classList.toggle('open', next);
        btnMenu.classList.toggle('open', next);
    }

    btnMenu.addEventListener('click', e => { e.stopPropagation(); toggleDropdown(); });
    document.addEventListener('click', e => { if (!btnMenu.contains(e.target) && !dropdown.contains(e.target)) toggleDropdown(false); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') { toggleDropdown(false); fecharModal(); } });

    function bindMenuItemToModal(itemId, overlayId, onOpen) {
        document.getElementById(itemId).addEventListener('click', () => {
            toggleDropdown(false);
            document.getElementById(overlayId).classList.add('open');
            if (onOpen) onOpen();
        });
