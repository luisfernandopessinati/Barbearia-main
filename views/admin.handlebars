    const adminsOverlay = document.getElementById('modal-admins-overlay');
    const adminLista = document.getElementById('admin-lista');
    const adminErro = document.getElementById('admin-erro');
    const btnAddAdmin = document.getElementById('btn-add-admin');
    const btnTogglePass = document.getElementById('btn-toggle-pass');
    const adminSenhaInput = document.getElementById('admin-senha-input');

    btnTogglePass.addEventListener('click', () => {
        const show = adminSenhaInput.type === 'password';
        adminSenhaInput.type = show ? 'text' : 'password';
        btnTogglePass.textContent = show ? '🙈' : '👁';
    });

    // ── Modal Empresa ─────────────────────────────────────
    const empresaOverlay = document.getElementById('modal-empresa-overlay');
    const empresaErro = document.getElementById('empresa-erro');
    const btnSalvarEmpresa = document.getElementById('btn-salvar-empresa');

    const camposEmpresa = {
        nome: document.getElementById('empresa-nome-input'),
        fantasia: document.getElementById('empresa-fantasia-input'),
        cnpj: document.getElementById('empresa-cnpj-input'),
        celular: document.getElementById('empresa-celular-input'),
        segmento: document.getElementById('empresa-segmento-input'),
        endereco: document.getElementById('empresa-endereco-input'),
        numero: document.getElementById('empresa-numero-input'),
        bairro: document.getElementById('empresa-bairro-input'),
        cidade: document.getElementById('empresa-cidade-input'),
        observacao: document.getElementById('empresa-observacao-input'),
        estilo: document.getElementById('empresa-estilo-input'),
    };

    async function carregarDadosEmpresa() {
        empresaErro.textContent = '';
        try {
            const res = await fetch('/api/empresa');
            if (!res.ok) throw new Error('Erro ao carregar dados.');
            const data = await res.json();

            camposEmpresa.nome.value = data.nome || '';
            camposEmpresa.fantasia.value = data.fantasia || '';
            camposEmpresa.cnpj.value = (data.cnpj || '').replace(/^(\d{2})(\d{3})(\d{3})(\d{4})(\d{2})$/, '$1.$2.$3/$4-$5');
            camposEmpresa.celular.value = data.celular || '';
            camposEmpresa.segmento.value = data.segmento || '';
            camposEmpresa.endereco.value = data.endereco || '';
            camposEmpresa.numero.value = data.numero || '';
            camposEmpresa.bairro.value = data.bairro || '';
            camposEmpresa.cidade.value = data.cidade || '';
            camposEmpresa.observacao.value = data.observacao || '';
            camposEmpresa.estilo.value = data.estilo || '1';

            const preview = document.getElementById('empresa-logo-preview');
            preview.innerHTML = data.logo
                ? `<img src="${data.logo}" style="width:100%;height:100%;object-fit:contain;border-radius:6px;padding:4px;">`
                : 'Logo';

        } catch (err) {
            empresaErro.textContent = '⚠ ' + err.message;
        }
    }

    btnSalvarEmpresa.addEventListener('click', async () => {
        empresaErro.textContent = '';
        btnSalvarEmpresa.textContent = 'Salvando...';
        btnSalvarEmpresa.disabled = true;
        try {
            const formData = new FormData();
            Object.entries(camposEmpresa).forEach(([k, el]) => formData.append(k, el.value.trim()));

            const logoInput = document.getElementById('empresa-logo-input');
            if (logoInput.files[0]) formData.append('logo', logoInput.files[0]);

            const res = await fetch('/api/empresa', { method: 'PUT', body: formData });
            const data = await res.json();
            if (!res.ok) throw new Error(data.erro || 'Erro ao salvar.');

            empresaOverlay.classList.remove('open');
        } catch (err) {
            empresaErro.textContent = '⚠ ' + err.message;
        } finally {
            btnSalvarEmpresa.textContent = 'Salvar Dados da Empresa';
            btnSalvarEmpresa.disabled = false;
        }
    });

    document.getElementById('modal-empresa-close').addEventListener('click', () => empresaOverlay.classList.remove('open'));
    empresaOverlay.addEventListener('click', e => { if (e.target === empresaOverlay) empresaOverlay.classList.remove('open'); });

    // ── Helpers ──
    function setErro(msg) { adminErro.textContent = msg ? '⚠ ' + msg : ''; }

    async function uploadFoto(id, file) {
        const fd = new FormData();
        fd.append('foto', file);
        const res = await fetch(`/admins/${id}/foto`, { method: 'POST', body: fd });
        return res.json();
    }

    // ── Abrir file picker para foto de admin existente ──
    adminLista.addEventListener('change', async e => {
        const input = e.target.closest('.admin-foto-input');
        if (!input || !input.files[0]) return;
        const id = input.dataset.id;
        try {
            const json = await uploadFoto(id, input.files[0]);
            if (json.sucesso) carregarAdmins();
            else setErro(json.erro || 'Erro ao salvar foto.');
        } catch { setErro('Erro de conexão.'); }
    });

    // ── Painel de edição inline (nome + telefone juntos) ──
    adminLista.addEventListener('click', async e => {
        // Abrir/fechar painel
        if (e.target.closest('.admin-edit-btn')) {
            const btn = e.target.closest('.admin-edit-btn');
            const id = btn.dataset.id;
            const panel = document.getElementById(`edit-panel-${id}`);
            const aberto = panel.style.display !== 'none';
            panel.style.display = aberto ? 'none' : 'flex';
            btn.textContent = aberto ? '✎' : '✕';
            return;
        }

        // Salvar edição
        if (e.target.closest('.admin-save-btn')) {
            const btn = e.target.closest('.admin-save-btn');
            const id = btn.dataset.id;
            const nome = document.getElementById(`ep-nome-${id}`).value.trim();
            const tel = document.getElementById(`ep-tel-${id}`).value.trim();
            if (!nome) { setErro('Nome não pode ser vazio.'); return; }
            setErro('');
            try {
                const promises = [
                    fetch(`/admins/${id}/nome`, { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ nome }) })
                ];
                if (tel) {
                    promises.push(fetch(`/admins/${id}/telefone`, { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ telefone: tel }) }));
                }
                const results = await Promise.all(promises);
                const jsons = await Promise.all(results.map(r => r.json()));
                const erro = jsons.find(j => !j.sucesso);
                if (erro) setErro(erro.erro || 'Erro ao salvar.');
                else carregarAdmins();
            } catch { setErro('Erro de conexão.'); }
            return;
        }

        // Inativar
        if (e.target.closest('.admin-del')) {
            const btn = e.target.closest('.admin-del');
            if (!confirm('Inativar este admin?')) return;
            try {
                const res = await fetch(`/admins/${btn.dataset.id}`, { method: 'DELETE' });
                const json = await res.json();
                if (json.sucesso) carregarAdmins();
                else setErro(json.erro || 'Erro ao inativar.');
            } catch { setErro('Erro de conexão.'); }
            return;
        }

        // Reativar
        if (e.target.closest('.admin-reativar')) {
            const btn = e.target.closest('.admin-reativar');
            if (!confirm('Reativar este admin?')) return;
            try {
                const res = await fetch(`/admins/${btn.dataset.id}/reativar`, { method: 'PATCH' });
                const json = await res.json();
                if (json.sucesso) carregarAdmins();
                else setErro(json.erro || 'Erro ao reativar.');
            } catch { setErro('Erro de conexão.'); }
        }
    });

    // ── Renderizar lista ──
    async function carregarAdmins() {
        adminLista.innerHTML = '<div class="admins-empty">Carregando...</div>';
        setErro('');
        try {
            const res = await fetch('/admins');
            const json = await res.json();
            if (!json.admins?.length) {
                adminLista.innerHTML = '<div class="admins-empty">Nenhum admin cadastrado</div>';
                return;
            }
            adminLista.innerHTML = '';
            json.admins.forEach(a => {
                const ativo = a.ativo === 'S';
                const inicial = a.nome.charAt(0).toUpperCase();
                const avatarEl = a.foto
                    ? `<img src="${a.foto}" alt="" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">`
                    : inicial;

                const item = document.createElement('div');
                item.className = `admin-card${ativo ? '' : ' admin-inativo'}`;
                item.innerHTML = `
              <div class="admin-avatar-wrap" title="${ativo ? 'Trocar foto' : ''}" ${ativo ? `onclick="document.getElementById('foto-${a.id}').click()"` : ''}>
                <div class="admin-avatar">${avatarEl}</div>
                ${ativo ? `<div class="admin-avatar-overlay">foto</div>` : ''}
                ${ativo ? `<input class="admin-foto-input" id="foto-${a.id}" data-id="${a.id}" type="file" accept="image/*" style="display:none">` : ''}
              </div>

              <div class="admin-info">
                <div class="admin-info-top">
                  <span class="admin-nome">${a.nome}</span>
                  <span class="admin-badge${a.role === 'owner' ? ' owner' : ''}">${a.role}</span>
                  ${!ativo ? '<span class="admin-badge inativo">inativo</span>' : ''}
                </div>
                <div class="admin-meta">${a.email}&nbsp;·&nbsp;${a.telefone || '—'}</div>

                <div class="admin-edit-panel" id="edit-panel-${a.id}" style="display:none;flex-direction:column;gap:6px;margin-top:8px;padding-top:8px;border-top:0.5px solid var(--border)">
                  <input id="ep-nome-${a.id}" value="${a.nome}" placeholder="Nome">
                  <input id="ep-tel-${a.id}"  value="${a.telefone || ''}" placeholder="Telefone" type="tel">
                  <button class="admin-save-btn" data-id="${a.id}">Salvar</button>
                </div>
              </div>

              <div class="admin-actions">
                ${ativo ? `<button class="admin-edit-btn icon-btn" data-id="${a.id}" title="Editar">✎</button>` : ''}
                ${a.role !== 'owner'
                        ? ativo
                            ? `<button class="admin-del icon-btn danger" data-id="${a.id}" title="Inativar">✕</button>`
                            : `<button class="admin-reativar icon-btn success" data-id="${a.id}" title="Reativar">↺</button>`
                        : ''}
              </div>`;
                adminLista.appendChild(item);
            });
        } catch { adminLista.innerHTML = '<div class="admins-empty">Erro ao carregar.</div>'; }
    }

    // ── Adicionar admin ──
    const fotoNewInput = document.getElementById('admin-foto-input'); // novo input no HTML

    btnAddAdmin.addEventListener('click', async () => {
        setErro('');
        const nome = document.getElementById('admin-nome-input').value.trim();
        const email = document.getElementById('admin-email-input').value.trim();
        const senha = adminSenhaInput.value;
        const role = document.getElementById('admin-role-select').value;
        const telefone = document.getElementById('admin-tel-input').value.trim();
        if (!nome || !email || !senha || !telefone) { setErro('Preencha todos os campos.'); return; }
        if (senha.length < 6) { setErro('Senha mínima de 6 caracteres.'); return; }

        btnAddAdmin.textContent = 'Salvando...';
        btnAddAdmin.disabled = true;
        try {
            const res = await fetch('/admins', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ nome, email, senha, role, telefone }) });
            const json = await res.json();
            if (json.sucesso) {
                // Upload de foto se selecionada
                if (fotoNewInput?.files[0]) await uploadFoto(json.id, fotoNewInput.files[0]);

                ['admin-nome-input', 'admin-email-input', 'admin-tel-input'].forEach(id => document.getElementById(id).value = '');
                adminSenhaInput.value = '';
                document.getElementById('admin-role-select').value = 'admin';
                if (fotoNewInput) fotoNewInput.value = '';
                carregarAdmins();
            } else setErro(json.erro || 'Erro ao salvar.');
        } catch { setErro('Erro de conexão.'); }
        finally { btnAddAdmin.textContent = '+ Adicionar Admin'; btnAddAdmin.disabled = false; }
    });

    document.getElementById('modal-admins-close').addEventListener('click', () => adminsOverlay.classList.remove('open'));
    adminsOverlay.addEventListener('click', e => { if (e.target === adminsOverlay) adminsOverlay.classList.remove('open'); });

    // ── Modal Horários ────────────────────────────────────
    const horariosOverlay = document.getElementById('modal-horarios-overlay');
    const horarioLista = document.getElementById('horario-lista');
    const horarioErro = document.getElementById('horario-erro');
    const btnAddHorario = document.getElementById('btn-add-horario');

    document.querySelectorAll('.horario-prof-chip').forEach(chip => {
        chip.addEventListener('click', () => {
            document.querySelectorAll('.horario-prof-chip').forEach(c => c.classList.remove('active'));
            chip.classList.add('active');
            horarioProfSelecionado = chip.dataset.id;
            carregarHorarios();
        });
    });

    document.querySelectorAll('.horario-dia-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.horario-dia-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            horarioDiaSelecionado = btn.dataset.dia;
        });
    });

    async function carregarHorarios() {
        if (!horarioProfSelecionado) { horarioLista.innerHTML = '<div class="horarios-empty">Selecione um profissional acima</div>'; return; }
        horarioLista.innerHTML = '<div class="horarios-empty">Carregando...</div>';
        try {
            const res = await fetch(`/horarios-funcionamento?profissional_id=${horarioProfSelecionado}`);
            const json = await res.json();
            if (!json.horarios?.length) { horarioLista.innerHTML = '<div class="horarios-empty">Nenhum horário cadastrado</div>'; return; }
            horarioLista.innerHTML = '';
            json.horarios.sort((a, b) => a.dia_semana - b.dia_semana).forEach(h => {
                const item = document.createElement('div');
                item.className = 'horario-item';
                item.innerHTML = `<span class="horario-item-dia">${DIAS_NOMES[h.dia_semana]}</span><span class="horario-item-range">${h.hora_inicio.substring(0, 5)} – ${h.hora_fim.substring(0, 5)}</span><span class="horario-item-prof">${h.ativo ? 'Ativo' : 'Inativo'}</span><button class="horario-del" data-id="${h.id}">✕</button>`;
                horarioLista.appendChild(item);
            });
            horarioLista.querySelectorAll('.horario-del').forEach(btn => {
                btn.addEventListener('click', async () => {
                    if (!confirm('Remover este horário?')) return;
                    await fetch(`/horarios-funcionamento/${btn.dataset.id}`, { method: 'DELETE' });
                    carregarHorarios();
                });
            });
        } catch (e) { horarioLista.innerHTML = '<div class="horarios-empty">Erro ao carregar.</div>'; }
    }

    btnAddHorario.addEventListener('click', async () => {
        horarioErro.textContent = '';
        const inicio = document.getElementById('horario-inicio-input').value;
        const fim = document.getElementById('horario-fim-input').value;
        if (!horarioProfSelecionado) { horarioErro.textContent = '⚠ Selecione um profissional.'; return; }
        if (horarioDiaSelecionado === null) { horarioErro.textContent = '⚠ Selecione um dia da semana.'; return; }
        if (!inicio || !fim) { horarioErro.textContent = '⚠ Preencha hora início e fim.'; return; }
        if (inicio >= fim) { horarioErro.textContent = '⚠ Hora início deve ser menor que hora fim.'; return; }
        btnAddHorario.textContent = 'Salvando...'; btnAddHorario.disabled = true;
        try {
            const res = await fetch('/horarios-funcionamento', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ profissional_id: horarioProfSelecionado, dia_semana: horarioDiaSelecionado, hora_inicio: inicio, hora_fim: fim }) });
            const json = await res.json();
            if (json.sucesso) {
                document.getElementById('horario-inicio-input').value = '';
                document.getElementById('horario-fim-input').value = '';
                document.querySelectorAll('.horario-dia-btn').forEach(b => b.classList.remove('active'));
                horarioDiaSelecionado = null;
                carregarHorarios();
            } else horarioErro.textContent = '⚠ ' + (json.erro || 'Erro ao salvar.');
        } catch (e) { horarioErro.textContent = '⚠ Erro de conexão.'; }
        finally { btnAddHorario.textContent = '+ Adicionar Horário'; btnAddHorario.disabled = false; }
    });

    document.getElementById('modal-horarios-close').addEventListener('click', () => horariosOverlay.classList.remove('open'));
    horariosOverlay.addEventListener('click', e => { if (e.target === horariosOverlay) horariosOverlay.classList.remove('open'); });

    // ── Slots dinâmicos ───────────────────────────────────
    async function buscarSlotsAdmin() {
        const barbeiro = document.getElementById('modal-barbeiro');
        const servico = document.getElementById('modal-servico');
        const data = document.getElementById('modal-data').value;
        const selectHorario = document.getElementById('modal-horario');
        const profId = barbeiro.selectedOptions[0]?.dataset.id;
        const servicoId = servico.selectedOptions[0]?.dataset.id;
        if (!profId || !servicoId || !data) { selectHorario.innerHTML = '<option value="">Selecione barbeiro, serviço e data</option>'; return; }
        selectHorario.innerHTML = '<option value="">Carregando...</option>';
        try {
            const res = await fetch(`/admin/slots?profissional_id=${profId}&servico_id=${servicoId}&data=${data}`);
            const json = await res.json();
            const slots = (json.slots || []).filter(s => s.status === 'disponivel');
            selectHorario.innerHTML = slots.length ? '<option value="">Selecione</option>' : '<option value="">Nenhum horário disponível</option>';
            slots.forEach(s => {
                const opt = document.createElement('option');
                opt.value = s.hora_inicio.substring(0, 5);
                opt.dataset.horaInicio = s.hora_inicio;
                opt.dataset.horaFim = s.hora_fim;
                opt.textContent = `${s.hora_inicio.substring(0, 5)} – ${s.hora_fim.substring(0, 5)}`;
                selectHorario.appendChild(opt);
            });
        } catch (e) { selectHorario.innerHTML = '<option value="">Erro ao carregar horários</option>'; }
    }

    document.getElementById('modal-horario').addEventListener('change', function () {
        const opt = this.selectedOptions[0];
        document.getElementById('modal-profissional-id').value = document.getElementById('modal-barbeiro').selectedOptions[0]?.dataset.id || '';
        document.getElementById('modal-hora-inicio').value = opt?.dataset.horaInicio || '';
        document.getElementById('modal-hora-fim').value = opt?.dataset.horaFim || '';
        document.getElementById('modal-servico-id').value = document.getElementById('modal-servico').selectedOptions[0]?.dataset.id || '';
    });

    async function gerarCamposSessoes(qtd) {
        const lista = document.getElementById('lista-sessoes');
        lista.innerHTML = '';

        for (let i = 0; i < qtd; i++) {
            const sessao = document.createElement('div');
            sessao.style.cssText = 'background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px;display:flex;flex-direction:column;gap:8px;';
            sessao.innerHTML = `
                <span style="font-size:10px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;">Sessão ${i + 1}</span>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
                    <div class="modal-field">
                        <label>Data</label>
                        <input type="date" class="sessao-data" data-index="${i}">
                    </div>
                    <div class="modal-field">
                        <label>Horário</label>
                        <select class="sessao-horario" data-index="${i}">
                            <option value="">Selecione a data</option>
                        </select>
                    </div>
                </div>
                <input type="hidden" class="sessao-hora-inicio" data-index="${i}">
                <input type="hidden" class="sessao-hora-fim" data-index="${i}">
            `;
            lista.appendChild(sessao);

            sessao.querySelector('.sessao-data').addEventListener('change', async function () {
                const data = this.value;
                const selectHorario = sessao.querySelector('.sessao-horario');
                const profId = document.getElementById('modal-barbeiro').selectedOptions[0]?.dataset.id;
                const servicoId = document.getElementById('modal-servico').selectedOptions[0]?.dataset.id;

                if (!profId || !servicoId || !data) return;

                selectHorario.innerHTML = '<option value="">Carregando...</option>';
                try {
                    const res = await fetch(`/admin/slots?profissional_id=${profId}&servico_id=${servicoId}&data=${data}`);
                    const json = await res.json();
                    const slots = (json.slots || []).filter(s => s.status === 'disponivel');
                    selectHorario.innerHTML = slots.length
                        ? '<option value="">Selecione</option>'
                        : '<option value="">Nenhum horário disponível</option>';
                    slots.forEach(s => {
                        const opt = document.createElement('option');
                        opt.value = s.hora_inicio.substring(0, 5);
                        opt.dataset.horaInicio = s.hora_inicio;
                        opt.dataset.horaFim = s.hora_fim;
                        opt.textContent = `${s.hora_inicio.substring(0, 5)} – ${s.hora_fim.substring(0, 5)}`;
                        selectHorario.appendChild(opt);
                    });
                } catch {
                    selectHorario.innerHTML = '<option value="">Erro ao carregar</option>';
                }
            });

            sessao.querySelector('.sessao-horario').addEventListener('change', function () {
                const opt = this.selectedOptions[0];
                sessao.querySelector('.sessao-hora-inicio').value = opt?.dataset.horaInicio || '';
                sessao.querySelector('.sessao-hora-fim').value = opt?.dataset.horaFim || '';
            });
        }
    }

    document.getElementById('modal-servico').addEventListener('change', function () {
        const opt = this.selectedOptions[0];
        const qtdSessoes = opt?.dataset.sessoes;
        const campoPacote = document.getElementById('campoPacote');
        const campoData = document.getElementById('modal-data').closest('.modal-field');
        const campoHorario = document.getElementById('modal-horario').closest('.modal-field');

        if (qtdSessoes && qtdSessoes !== 'null' && qtdSessoes !== '') {
            campoPacote.style.display = '';
            campoData.style.display = 'none';
            campoHorario.style.display = 'none';
            document.getElementById('modal-data').required = false;    // 👈
            document.getElementById('modal-horario').required = false; // 👈
            gerarCamposSessoes(parseInt(qtdSessoes));
        } else {
            campoPacote.style.display = 'none';
            campoData.style.display = '';
            campoHorario.style.display = '';
            document.getElementById('modal-data').required = true;    // 👈
            document.getElementById('modal-horario').required = false; // horário não tem required
            buscarSlotsAdmin();
        }
    });
    document.getElementById('modal-data').addEventListener('change', buscarSlotsAdmin);

    async function recarregarAgendamentos() {
        try {
            const res = await fetch('/admin/agendamentos-json');
            const json = await res.json();
            todosAgendamentos.length = 0;
            todosAgendamentos.push(...json.agendamentos);
            renderStats();
            renderCalendar();
            renderCounts();
        } catch (e) {
            console.error('Erro ao recarregar:', e);
        }
    }

    // ── Busca de clientes cadastrados ─────────────────────
    let _buscaTimeout = null;

    function onNomeInput(valor) {
        clearTimeout(_buscaTimeout);
        const box = document.getElementById('cliente-suggestions');
        if (valor.length < 2) { box.style.display = 'none'; return; }
        _buscaTimeout = setTimeout(() => buscarClientes(valor), 300);
    }

    function toggleBuscaCliente() {
        const box = document.getElementById('cliente-suggestions');
        if (box.style.display !== 'none') { box.style.display = 'none'; return; }
        const q = document.getElementById('modal-nome').value.trim();
        if (q.length >= 2) {
            buscarClientes(q);
        } else {
            box.innerHTML = `<div style="padding:10px 14px;font-size:12px;color:var(--muted);">
            Digite ao menos 2 letras para buscar</div>`;
            box.style.display = '';
        }
    }

    async function buscarClientes(q) {
        const box = document.getElementById('cliente-suggestions');
        box.innerHTML = `<div style="padding:10px 14px;font-size:12px;color:var(--muted);">Buscando...</div>`;
        box.style.display = '';
        try {
            const res = await fetch(`/admin/clientes/buscar?q=${encodeURIComponent(q)}`);
            const json = await res.json();

            if (!json.clientes?.length) {
                box.innerHTML = `<div style="padding:10px 14px;font-size:12px;color:var(--muted);">
                Nenhum cliente encontrado — será criado ao salvar</div>`;
                return;
            }

            box.innerHTML = '';
            json.clientes.forEach(c => {
                const item = document.createElement('div');
                item.style.cssText = `padding:10px 14px;cursor:pointer;display:flex;
                justify-content:space-between;align-items:center;
                border-bottom:1px solid var(--border);font-size:13px;transition:background .15s;`;
                item.innerHTML = `
                <div>
                    <div style="font-weight:600;color:var(--text);">${c.nome}</div>
                    <div style="font-size:11px;color:var(--muted);">${c.telefone}</div>
                </div>
                <span style="font-size:10px;color:var(--gold);letter-spacing:1px;">USAR</span>`;
                item.addEventListener('mouseenter', () => item.style.background = 'var(--bg3)');
                item.addEventListener('mouseleave', () => item.style.background = '');
                item.addEventListener('click', () => {
                    document.getElementById('modal-nome').value = c.nome;
                    document.getElementById('modal-telefone').value = c.telefone;
                    box.style.display = 'none';
                });
                box.appendChild(item);
            });
        } catch {
            box.innerHTML = `<div style="padding:10px 14px;font-size:12px;color:var(--muted);">Erro ao buscar</div>`;
        }
    }

    // Fecha sugestões ao clicar fora
    document.addEventListener('click', e => {
        if (!e.target.closest('#campoNome')) {
            const box = document.getElementById('cliente-suggestions');
            if (box) box.style.display = 'none';
        }
    });
    // ── Vincular dropdown aos modais ──────────────────────
    bindMenuItemToModal('menu-feriados', 'modal-feriados-overlay', carregarFeriados);
    bindMenuItemToModal('menu-servicos', 'modal-servicos-overlay', carregarServicos);
    bindMenuItemToModal('menu-admins', 'modal-admins-overlay', carregarAdmins);
    bindMenuItemToModal('menu-horarios', 'modal-horarios-overlay', carregarHorarios);
    bindMenuItemToModal('menu-empresa', 'modal-empresa-overlay', carregarDadosEmpresa);

    document.getElementById('menu-dashboard').addEventListener('click', () => { toggleDropdown(false); window.location.href = '/admin/dashboard'; });
    document.getElementById('menu-dashboard-vendas').addEventListener('click', () => { toggleDropdown(false); window.location.href = '/admin/dashboard/vendas'; });
    document.getElementById('menu-produtos').addEventListener('click', () => { toggleDropdown(false); window.location.href = '/admin/produtos'; });
    document.getElementById('menu-vendas').addEventListener('click', () => { toggleDropdown(false); window.location.href = '/admin/vendas'; });

    // ── Init ──────────────────────────────────────────────
    renderStats();
    renderCalendar();
    renderCounts();
</script>