<script>
    // ── Dados do backend ──────────────────────────────────
    const todosAgendamentos = [
        {{#each agendamentos}}
    { id: {{id}}, nome: "{{nome}}", telefone: "{{telefone}}", data: "{{data}}", horario: "{{horario}}", servico: "{{servico}}", barbeiro: "{{barbeiro}}" },
    {{/each}}
    ];

    const DIAS = ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'];
    const MESES_FULL = ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'];
    const HORAS = Array.from({ length: 19 }, (_, i) => `${String(i + 5).padStart(2, '0')}:00`);
    const DIAS_NOMES = ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'];

    let weekOffset = 0;
    let filtroBarbeiro = 'todos';
    let horarioProfSelecionado = null;
    let horarioDiaSelecionado = null;
    let mobileDayOffset = 0;

    const isMobile = () => window.innerWidth <= 900;

    function fmtDate(d) {
        return `${String(d.getDate()).padStart(2, '0')}/${String(d.getMonth() + 1).padStart(2, '0')}/${d.getFullYear()}`;
    }

    const currentMonth = fmtDate(new Date()).slice(3, 10);

    const tokenAgendamento = "{{empresa.token_agendamento}}";
    const linkAgendamento = `https://lpsolutions.online/loginUsuario/${tokenAgendamento}`;

    const inputLink = document.getElementById("input-link-agendamento");
    const btnCopiar = document.getElementById("btn-copiar-link");
    const btnWhatsapp = document.getElementById("btn-whatsapp-link");

    inputLink.value = linkAgendamento;

    btnCopiar.addEventListener("click", () => {
        navigator.clipboard.writeText(linkAgendamento);
        btnCopiar.innerText = "Copiado ✓";
        btnCopiar.style.background = "#16a34a";

        setTimeout(() => {
            btnCopiar.innerText = "Copiar";
            btnCopiar.style.background = "linear-gradient(135deg,#4f46e5,#7c3aed)";
        }, 2000);
    });

    btnWhatsapp.addEventListener("click", () => {
        const mensagem = `Olá! Faça seu agendamento online pelo link:\n${linkAgendamento}`;
        window.open(`https://wa.me/?text=${encodeURIComponent(mensagem)}`, "_blank");
    });


    // ── Popup ──────────────────────────────────────────────
    const popup = document.createElement('div');
    popup.className = 'cal-popup';
    popup.innerHTML = `
        <div class="cal-popup-nome" id="popup-nome"></div>
        <div class="cal-popup-meta" id="popup-meta"></div>
        <div class="cal-popup-actions">
            <a id="popup-editar" href="#" class="btn-edit"><i class="fa-solid fa-pen"></i> Editar</a>
            <a id="popup-whatsapp" href="#" target="_blank" class="btn-whatsapp">
                <i class="fa-brands fa-whatsapp"></i> Confirmar
            </a>
            <a id="popup-excluir" href="#" class="btn-del" onclick="return confirm('Excluir este agendamento?')">
                <i class="fa-solid fa-trash"></i> Excluir
            </a>
        </div>`;
    document.body.appendChild(popup);

    document.addEventListener('click', e => {
        if (!popup.contains(e.target) && !e.target.closest('.cal-event') && !e.target.closest('.cal-mobile-event')) {
            popup.classList.remove('open');
        }
    });

    function abrirPopup(e, a) {
        e.stopPropagation();
        document.getElementById('popup-nome').textContent = a.nome;
        document.getElementById('popup-meta').textContent = `${a.horario} · ${a.servico} · ${a.barbeiro}`;
        document.getElementById('popup-editar').href = `/editar/${a.id}`;
        document.getElementById('popup-excluir').href = `/deletar/${a.id}`;

        // Monta link WhatsApp
        const tel = a.telefone.replace(/\D/g, ''); // remove tudo que não é número
        const mensagem = encodeURIComponent(
            `Olá ${a.nome}! 👋\n\nPassando para confirmar seu agendamento:\n📅 Data: ${a.data}\n🕐 Horário: ${a.horario}\n✂️ Serviço: ${a.servico}\n💈 Profissional: ${a.barbeiro}\n\nPor favor, confirme sua presença. Até lá!`
        );
        document.getElementById('popup-whatsapp').href = `https://wa.me/55${tel}?text=${mensagem}`;

        popup.classList.add('open');
        const rect = e.currentTarget.getBoundingClientRect();
        popup.style.top = (rect.bottom + 8 + window.scrollY) + 'px';
        popup.style.left = (rect.left + window.scrollX) + 'px';
        requestAnimationFrame(() => {
            const pr = popup.getBoundingClientRect();
            if (pr.right > window.innerWidth - 8) popup.style.left = (window.innerWidth - pr.width - 8) + 'px';
            if (pr.bottom > window.innerHeight - 8) popup.style.top = (rect.top + window.scrollY - pr.height - 8) + 'px';
        });
    }

    // ── Calendário ────────────────────────────────────────
    function getWeekDates() {
        const today = new Date(); today.setHours(0, 0, 0, 0);
        const monday = new Date(today);
        monday.setDate(today.getDate() - today.getDay() + 1 + weekOffset * 7);
        return Array.from({ length: 7 }, (_, i) => { const d = new Date(monday); d.setDate(monday.getDate() + i); return d; });
    }

    function updateNavLabel(dates) {
        const label = document.getElementById('cal-nav-label');
        const ini = dates[0], fim = dates[6];
        label.textContent = ini.getMonth() === fim.getMonth()
            ? `${ini.getDate()} – ${fim.getDate()} ${MESES_FULL[ini.getMonth()]} ${ini.getFullYear()}`
            : `${ini.getDate()} ${MESES_FULL[ini.getMonth()].slice(0, 3)} – ${fim.getDate()} ${MESES_FULL[fim.getMonth()].slice(0, 3)} ${fim.getFullYear()}`;
    }

    function renderCalendar() {
        const grid = document.getElementById('cal-grid');
        grid.innerHTML = '';
        const weekDates = getWeekDates();
        updateNavLabel(weekDates);
        const todayStr = fmtDate(new Date());
        const weekStrs = weekDates.map(d => fmtDate(d));
        const agendsSemana = todosAgendamentos.filter(a => weekStrs.includes(a.data));
        document.getElementById('empty-state').classList.toggle('visible', agendsSemana.length === 0);
        isMobile() ? renderMobile(grid, weekDates, todayStr) : renderDesktop(grid, weekDates, todayStr);
    }

    function renderDesktop(grid, weekDates, todayStr) {
        grid.style.gridTemplateColumns = `56px repeat(7, minmax(120px, 1fr))`;

        // Cabeçalho
        const thTime = document.createElement('div');
        thTime.className = 'cal-head-time';
        grid.appendChild(thTime);

        weekDates.forEach(d => {
            const isToday = fmtDate(d) === todayStr;
            const th = document.createElement('div');
            th.className = 'cal-head-cell' + (isToday ? ' today' : '');
            th.innerHTML = `<span class="cal-head-day">${DIAS[d.getDay()]} ${d.getDate()}</span>`;
            grid.appendChild(th);
        });

        // Linhas de horas
        HORAS.forEach(hora => {
            const timeCell = document.createElement('div');
            timeCell.className = 'cal-time-cell';
            timeCell.textContent = hora;
            grid.appendChild(timeCell);

            weekDates.forEach(d => {
                const str = fmtDate(d);
                const isToday = str === todayStr;
                const cell = document.createElement('div');
                cell.className = 'cal-cell' + (isToday ? ' hoje-col' : '');

                const eventos = todosAgendamentos.filter(a =>
                    a.data === str &&
                    a.horario.startsWith(hora.substring(0, 2)) &&
                    (filtroBarbeiro === 'todos' || a.barbeiro === filtroBarbeiro)
                );

                if (eventos.length > 0) {
                    eventos.forEach(a => {
                        const ev = document.createElement('div');
                        ev.className = 'cal-event';
                        ev.innerHTML = `
                                <div style="border-left: 3px solid var(--gold); padding-left: 5px; display: flex; flex-direction: column;">
                                    <span class="cal-event-nome" style="font-weight: bold; color: var(--gold-light); font-size: 11px; text-transform: uppercase;">${a.barbeiro}</span>
                                    <span class="cal-event-nome" style="color: #fff; font-size: 13px;">${a.nome}</span>
                                    <span class="cal-event-tel" style="font-size: 10px; opacity: 0.6;">${a.servico}</span>
                                </div>`;
                        ev.addEventListener('click', e => abrirPopup(e, a));
                        cell.appendChild(ev);
                    });
                } else {
                    const vazio = document.createElement('div');
                    vazio.className = 'cal-slot-vazio';
                    vazio.textContent = '+';
                    cell.addEventListener('click', () => {
                        const [dd, mm, yy] = str.split('/');
                        document.getElementById('modal-data').value = `${yy}-${mm}-${dd}`;
                        if (filtroBarbeiro !== 'todos') {
                            const sel = document.getElementById('modal-barbeiro');
                            [...sel.options].forEach(o => { o.selected = o.value === filtroBarbeiro; });
                        }
                        overlay.classList.add('open');
                        buscarSlotsAdmin();
                    });
                    cell.appendChild(vazio);
                }
                grid.appendChild(cell);
            });
        });
    }

    /*function renderMobile(grid, weekDates, todayStr) {
        weekDates.forEach(d => {
            const str = fmtDate(d);
            const isToday = str === todayStr;
            const eventos = todosAgendamentos.filter(a =>
                a.data === str && (filtroBarbeiro === 'todos' || a.barbeiro === filtroBarbeiro)
            ).sort((a, b) => a.horario.localeCompare(b.horario));

            const day = document.createElement('div');
            day.className = 'cal-mobile-day';

            const header = document.createElement('div');
            header.className = 'cal-mobile-day-header' + (isToday ? ' today' : '');
            header.innerHTML = `<span>${DIAS[d.getDay()]}, ${d.getDate()}</span><span style="font-size:11px;color:var(--muted)">${eventos.length > 0 ? eventos.length + ' agend.' : ''}</span>`;
            day.appendChild(header);

            if (eventos.length === 0) {
                const empty = document.createElement('div');
                empty.className = 'cal-mobile-empty';
                empty.textContent = 'Sem agendamentos';
                day.appendChild(empty);
            } else {
                eventos.forEach(a => {
                    const ev = document.createElement('div');
                    ev.className = 'cal-mobile-event';
                    ev.innerHTML = `
                        <div class="cal-mobile-time" style="font-family: 'Bebas Neue'; font-size: 1.2rem; color: var(--gold-light); min-width: 50px;">
                            ${a.horario}
                        </div>
                        <div style="width: 2px; background: var(--gold-dim); margin: 0 15px; position: relative;">
                            <div style="width: 8px; height: 8px; background: var(--gold); border-radius: 50%; position: absolute; left: -3px; top: 5px;"></div>
                        </div>
                        <div class="cal-mobile-info" style="flex: 1; background: var(--bg3); padding: 10px; border-radius: 8px; border: 1px solid var(--border);">
                            <div class="cal-mobile-nome" style="font-weight: bold; color: var(--text);">${a.nome}</div>
                            <div class="cal-mobile-meta" style="font-size: 12px; color: var(--muted);">
                                <i class="fas fa-cut" style="font-size: 10px;"></i> ${a.servico} <br>
                                <i class="fas fa-user" style="font-size: 10px;"></i> ${a.barbeiro}
                            </div>
                        </div>`;
                    // Adicione este ajuste de estilo na linha do elemento pai (ev):
                    ev.style.display = "flex";
                    ev.style.marginBottom = "15px";
                    ev.style.alignItems = "stretch";
                    ev.addEventListener('click', e => {
                            e.preventDefault(); // Impede o comportamento padrão do navegador
                            e.stopPropagation(); // Evita que o clique "vaze" para elementos de baixo
                            abrirPopup(e, a);
                        }, { passive: false });
                    day.appendChild(ev);
                });
            }
            grid.appendChild(day);
        });
    }*/
        function renderMobile(grid, weekDates, todayStr) {
        grid.innerHTML = '';

        const baseDate = new Date();
        baseDate.setHours(0,0,0,0);
        baseDate.setDate(baseDate.getDate() + mobileDayOffset);

        const str = fmtDate(baseDate);
        const isToday = str === todayStr;

        const eventos = todosAgendamentos
            .filter(a =>
                a.data === str &&
                (filtroBarbeiro === 'todos' || a.barbeiro === filtroBarbeiro)
            )
            .sort((a, b) => a.horario.localeCompare(b.horario));

        const day = document.createElement('div');
        day.className = 'cal-mobile-day';

        // Header com navegação
        const header = document.createElement('div');
        header.className = 'cal-mobile-day-header' + (isToday ? ' today' : '');
        header.innerHTML = `
            <button id="mobile-prev-day">⬅</button>
            <span>${DIAS[baseDate.getDay()]}, ${baseDate.getDate()}</span>
            <button id="mobile-next-day">➡</button>
        `;
        day.appendChild(header);

        if (eventos.length === 0) {
            const empty = document.createElement('div');
            empty.className = 'cal-mobile-empty';
            empty.textContent = 'Sem agendamentos';
            day.appendChild(empty);
        } else {
            eventos.forEach(a => {
                const ev = document.createElement('div');
                ev.className = 'cal-mobile-event';
                ev.innerHTML = `
                    <div style="font-weight:bold">${a.horario}</div>
                    <div>${a.nome}</div>
                    <div style="font-size:12px;opacity:.6">${a.servico} · ${a.barbeiro}</div>
                `;
                ev.addEventListener('click', e => abrirPopup(e, a));
                day.appendChild(ev);
            });
        }

        grid.appendChild(day);

        // Navegação
        document.getElementById('mobile-prev-day').addEventListener('click', () => {
            mobileDayOffset--;
            renderCalendar();
        });

        document.getElementById('mobile-next-day').addEventListener('click', () => {
            mobileDayOffset++;
            renderCalendar();
        });
    }

    function renderStats() {
        const today = fmtDate(new Date());
        const weekStrs = getWeekDates().map(d => fmtDate(d));
        document.getElementById('stat-hoje').textContent = todosAgendamentos.filter(a => a.data === today).length;
        document.getElementById('stat-semana').textContent = todosAgendamentos.filter(a => weekStrs.includes(a.data)).length;
        document.getElementById('stat-total').textContent = todosAgendamentos.filter(a => a.data.slice(3, 10) === currentMonth).length;
    }

    function renderCounts() {
        const weekStrs = getWeekDates().map(d => fmtDate(d));
        document.querySelectorAll('[data-count-barbeiro]').forEach(el => {
            el.textContent = todosAgendamentos.filter(a => a.barbeiro === el.dataset.countBarbeiro && weekStrs.includes(a.data)).length;
        });
        const totalEl = document.getElementById('chip-count-todos');
        if (totalEl) totalEl.textContent = todosAgendamentos.filter(a => weekStrs.includes(a.data)).length;
    }

    // ── Navegação ─────────────────────────────────────────
    document.getElementById('prev-week').addEventListener('click', () => { weekOffset--; renderCalendar(); renderCounts(); });
    document.getElementById('next-week').addEventListener('click', () => { weekOffset++; renderCalendar(); renderCounts(); });
    document.getElementById('btn-hoje').addEventListener('click', () => { weekOffset = 0; renderCalendar(); renderCounts(); });
    document.getElementById('btn-sair').addEventListener('click', () => { window.location.href = '/logout'; });
    window.addEventListener('resize', renderCalendar);

    // ── Filtro barbeiros ──────────────────────────────────
    document.querySelectorAll('.barber-chip-top').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.barber-chip-top').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            filtroBarbeiro = btn.dataset.barbeiro;
            renderCalendar();
            renderCounts();
        });
    });

    // ── Menu Configurações ────────────────────────────────
    const btnMenu = document.getElementById('btn-config-menu');
    const dropdown = document.getElementById('config-dropdown');

    function toggleDropdown(force) {
        const next = force !== undefined ? force : !dropdown.classList.contains('open');
        dropdown.classList.toggle('open', next);
        btnMenu.classList.toggle('open', next);
    }

    btnMenu.addEventListener('click', e => { e.stopPropagation(); toggleDropdown(); });
    document.addEventListener('click', e => { if (!btnMenu.contains(e.target) && !dropdown.contains(e.target)) toggleDropdown(false); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') { toggleDropdown(false); fecharModal(); } });

    function bindMenuItemToModal(itemId, overlayId, onOpen) {
        document.getElementById(itemId).addEventListener('click', () => {
            toggleDropdown(false);
            document.getElementById(overlayId).classList.add('open');
            if (onOpen) onOpen();
        });
    }

    // ── Modal Novo Agendamento ────────────────────────────
    const overlay = document.getElementById('modal-overlay');
    const modalErro = document.getElementById('modal-erro');
    const modalData = document.getElementById('modal-data');
    const formAdmin = document.getElementById('form-admin');
    const btnConfirmar = formAdmin.querySelector('.btn-confirmar');

    const hoje = new Date();
    modalData.setAttribute('min', `${hoje.getFullYear()}-${String(hoje.getMonth() + 1).padStart(2, '0')}-${String(hoje.getDate()).padStart(2, '0')}`);

    function fecharModal() { overlay.classList.remove('open'); formAdmin.reset(); modalErro.textContent = ''; }

    document.getElementById('btn-novo').addEventListener('click', () => { modalErro.textContent = ''; overlay.classList.add('open'); });
    document.getElementById('modal-close').addEventListener('click', fecharModal);
    document.getElementById('btn-cancelar').addEventListener('click', fecharModal);
    overlay.addEventListener('click', e => { if (e.target === overlay) fecharModal(); });

    formAdmin.addEventListener('submit', async (e) => {
        e.preventDefault();
        modalErro.textContent = '';
        btnConfirmar.textContent = 'Salvando...'; btnConfirmar.disabled = true;
        try {
            const res = await fetch('/admin/agendar/', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: new URLSearchParams(new FormData(formAdmin)).toString() });
            const json = await res.json();
            if (res.ok && json.sucesso) { fecharModal(); window.location.reload(); }
            else modalErro.textContent = '⚠ ' + (json.erro || 'Erro ao salvar agendamento.');
        } catch (err) { modalErro.textContent = '⚠ Erro de conexão.'; }
        finally { btnConfirmar.textContent = 'Salvar'; btnConfirmar.disabled = false; }
    });

    // ── Modal Feriados ────────────────────────────────────
    const feriadosOverlay = document.getElementById('modal-feriados-overlay');
    const feriadoLista = document.getElementById('feriado-lista');
    const feriadoErro = document.getElementById('feriado-erro');
    const feriadoDataInput = document.getElementById('feriado-data');
    const feriadoDescInput = document.getElementById('feriado-desc');
    const btnAddFeriado = document.getElementById('btn-add-feriado');

    function fmtFeriadoData(str) { const [y, m, d] = str.split('-'); return `${d}/${m}/${y}`; }

    async function carregarFeriados() {
        feriadoLista.innerHTML = '<div class="feriados-empty">Carregando...</div>';
        try {
            const res = await fetch('/feriados');
            const json = await res.json();
            if (!json.feriados?.length) { feriadoLista.innerHTML = '<div class="feriados-empty">Nenhum feriado cadastrado</div>'; return; }
            feriadoLista.innerHTML = '';
            json.feriados.sort((a, b) => a.data.localeCompare(b.data)).forEach(f => {
                const item = document.createElement('div');
                item.className = 'feriado-item';
                item.innerHTML = `<div class="feriado-item-info"><span class="feriado-item-data">${fmtFeriadoData(f.data)}</span><span class="feriado-item-desc">${f.descricao}</span></div><button class="feriado-del" data-data="${f.data}">✕</button>`;
                feriadoLista.appendChild(item);
            });
            feriadoLista.querySelectorAll('.feriado-del').forEach(btn => {
                btn.addEventListener('click', async () => {
                    if (!confirm('Remover este feriado?')) return;
                    await fetch(`/feriados/${btn.dataset.data}`, { method: 'DELETE' });
                    carregarFeriados();
                });
            });
        } catch (e) { feriadoLista.innerHTML = '<div class="feriados-empty">Erro ao carregar.</div>'; }
    }

    btnAddFeriado.addEventListener('click', async () => {
        feriadoErro.textContent = '';
        const data = feriadoDataInput.value, descricao = feriadoDescInput.value.trim();
        if (!data || !descricao) { feriadoErro.textContent = '⚠ Preencha a data e a descrição.'; return; }
        btnAddFeriado.textContent = 'Salvando...'; btnAddFeriado.disabled = true;
        try {
            const res = await fetch('/feriados', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: `data=${data}&descricao=${encodeURIComponent(descricao)}` });
            const json = await res.json();
            if (json.sucesso) { feriadoDataInput.value = ''; feriadoDescInput.value = ''; carregarFeriados(); }
            else feriadoErro.textContent = '⚠ ' + (json.erro || 'Erro ao salvar.');
        } catch (e) { feriadoErro.textContent = '⚠ Erro de conexão.'; }
        finally { btnAddFeriado.textContent = '+ Adicionar Feriado'; btnAddFeriado.disabled = false; }
    });

    document.getElementById('modal-feriados-close').addEventListener('click', () => feriadosOverlay.classList.remove('open'));
    feriadosOverlay.addEventListener('click', e => { if (e.target === feriadosOverlay) feriadosOverlay.classList.remove('open'); });

    // ── Modal Serviços ────────────────────────────────────
    const servicosOverlay = document.getElementById('modal-servicos-overlay');
    const servicoLista = document.getElementById('servico-lista');
    const servicoErro = document.getElementById('servico-erro');
    const servicoNomeInput = document.getElementById('servico-nome-input');
    const servicoValorInput = document.getElementById('servico-valor-input');
    const btnAddServico = document.getElementById('btn-add-servico');

    async function carregarServicos() {
        servicoLista.innerHTML = '<div class="servicos-empty">Carregando...</div>';
        try {
            const res = await fetch('/servicos/admin');
            const json = await res.json();
            if (!json.servicos?.length) { servicoLista.innerHTML = '<div class="servicos-empty">Nenhum serviço cadastrado</div>'; return; }
            servicoLista.innerHTML = '';
            json.servicos.forEach(s => {
                const item = document.createElement('div');
                item.className = 'servico-item' + (s.ativo ? '' : ' inativo');
                item.innerHTML = `
                    <span class="servico-item-nome">${s.nome}</span>
                    <span class="servico-item-valor">R$ ${parseFloat(s.valor).toFixed(2).replace('.', ',')}</span>
                    <div class="servico-item-actions">
                        <button class="btn-servico-edit" data-id="${s.id}" data-nome="${s.nome}" data-valor="${s.valor}">✏️</button>
                        <button class="btn-servico-toggle ${s.ativo ? '' : 'inativo'}" data-id="${s.id}">${s.ativo ? 'Ativo' : 'Inativo'}</button>
                    </div>`;
                servicoLista.appendChild(item);
            });
            servicoLista.querySelectorAll('.btn-servico-edit').forEach(btn => {
                btn.addEventListener('click', () => {
                    const item = btn.closest('.servico-item');
                    const jaEditando = item.querySelector('.servico-edit-row');
                    if (jaEditando) { jaEditando.remove(); return; }
                    const row = document.createElement('div');
                    row.className = 'servico-edit-row';
                    row.innerHTML = `<input type="number" value="${btn.dataset.valor}" step="0.01" min="0"><button style="background:var(--gold);border:none;color:#000;padding:5px 12px;border-radius:6px;cursor:pointer;font-size:12px;">Salvar</button><button style="background:none;border:1px solid var(--border);color:var(--muted);padding:5px 10px;border-radius:6px;cursor:pointer;font-size:12px;">✕</button>`;
                    item.appendChild(row);
                    const [inputVal, btnSalvar, btnCancelar] = row.querySelectorAll('input, button');
                    btnCancelar.addEventListener('click', () => row.remove());
                    btnSalvar.addEventListener('click', async () => {
                        const novoValor = parseFloat(inputVal.value);
                        if (isNaN(novoValor) || novoValor < 0) return;
                        try {
                            const res = await fetch(`/servicos/${btn.dataset.id}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ valor: novoValor, nome: btn.dataset.nome }) });
                            const json = await res.json();
                            if (json.sucesso) carregarServicos();
                        } catch (e) { servicoErro.textContent = '⚠ Erro de conexão.'; }
                    });
                });
            });
            servicoLista.querySelectorAll('.btn-servico-toggle').forEach(btn => {
                btn.addEventListener('click', async () => {
                    try {
                        const res = await fetch(`/servicos/${btn.dataset.id}/toggle`, { method: 'PUT' });
                        const json = await res.json();
                        if (json.sucesso) carregarServicos();
                    } catch (e) { servicoErro.textContent = '⚠ Erro ao atualizar.'; }
                });
            });
        } catch (e) { servicoLista.innerHTML = '<div class="servicos-empty">Erro ao carregar.</div>'; }
    }

    btnAddServico.addEventListener('click', async () => {
        servicoErro.textContent = '';
        const nome = servicoNomeInput.value.trim(), valor = parseFloat(servicoValorInput.value);
        if (!nome || isNaN(valor) || valor < 0) { servicoErro.textContent = '⚠ Preencha nome e valor.'; return; }
        btnAddServico.textContent = 'Salvando...'; btnAddServico.disabled = true;
        try {
            const res = await fetch('/servicos', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ nome, valor }) });
            const json = await res.json();
            if (json.sucesso) { servicoNomeInput.value = ''; servicoValorInput.value = ''; carregarServicos(); }
            else servicoErro.textContent = '⚠ ' + (json.erro || 'Erro ao salvar.');
        } catch (e) { servicoErro.textContent = '⚠ Erro de conexão.'; }
        finally { btnAddServico.textContent = '+ Adicionar'; btnAddServico.disabled = false; }
    });

    document.getElementById('modal-servicos-close').addEventListener('click', () => servicosOverlay.classList.remove('open'));
    servicosOverlay.addEventListener('click', e => { if (e.target === servicosOverlay) servicosOverlay.classList.remove('open'); });

    // ── Modal Admins ──────────────────────────────────────
    const adminsOverlay = document.getElementById('modal-admins-overlay');
    const adminLista = document.getElementById('admin-lista');
    const adminErro = document.getElementById('admin-erro');
    const btnAddAdmin = document.getElementById('btn-add-admin');
    const btnTogglePass = document.getElementById('btn-toggle-pass');
    const adminSenhaInput = document.getElementById('admin-senha-input');

    btnTogglePass.addEventListener('click', () => {
        const show = adminSenhaInput.type === 'password';
        adminSenhaInput.type = show ? 'text' : 'password';
        btnTogglePass.textContent = show ? '🙈' : '👁';
    });

    async function carregarAdmins() {
        adminLista.innerHTML = '<div class="admins-empty">Carregando...</div>';
        try {
            const res = await fetch('/admins');
            const json = await res.json();
            if (!json.admins?.length) { adminLista.innerHTML = '<div class="admins-empty">Nenhum admin cadastrado</div>'; return; }
            adminLista.innerHTML = '';
            json.admins.forEach(a => {
                const item = document.createElement('div');
                item.className = `admin-item ${a.ativo === 'S' ? '' : 'admin-inativo'}`;
                item.innerHTML = `
                    <div class="admin-avatar" style="${a.ativo !== 'S' ? 'opacity:.4;filter:grayscale(1)' : ''}">${a.nome.charAt(0).toUpperCase()}</div>
                    <div class="admin-item-info">
                        <span class="admin-item-nome" id="nome-label-${a.id}">${a.nome}${a.ativo !== 'S' ? ' <span style="font-size:10px;color:#c0392b;letter-spacing:1px;text-transform:uppercase;">● Inativo</span>' : ''}</span>
                        <input id="nome-input-${a.id}" value="${a.nome}" style="display:none;background:#181818;border:1px solid #b8860b;border-radius:6px;padding:4px 8px;color:#e8e8e8;font-size:14px;width:140px;">
                        <span class="admin-item-email">${a.email}</span>
                    </div>
                    <span class="admin-item-role ${a.role === 'owner' ? 'owner' : ''}">${a.role}</span>
                    <button class="admin-edit-nome" data-id="${a.id}" style="background:none;border:none;color:#555;font-size:16px;cursor:pointer;">✎</button>
                    ${a.role !== 'owner' ? (a.ativo !== 'S'
                        ? `<button class="admin-reativar" data-id="${a.id}" style="background:none;border:1px solid #b8860b;color:#b8860b;border-radius:6px;padding:4px 10px;font-size:11px;cursor:pointer;">↺ Reativar</button>`
                        : `<button class="admin-del" data-id="${a.id}" style="background:none;border:none;color:#555;font-size:16px;cursor:pointer;">✕</button>`
                    ) : ''}`;
                adminLista.appendChild(item);
            });
            adminLista.querySelectorAll('.admin-edit-nome').forEach(btn => {
                btn.addEventListener('click', async () => {
                    const id = btn.dataset.id;
                    const label = document.getElementById(`nome-label-${id}`);
                    const input = document.getElementById(`nome-input-${id}`);
                    if (input.style.display === 'none') {
                        label.style.display = 'none'; input.style.display = 'inline-block'; input.focus();
                        btn.textContent = '✔'; btn.style.color = '#b8860b';
                    } else {
                        const novoNome = input.value.trim();
                        if (!novoNome) return;
                        try {
                            const res = await fetch(`/admins/${id}/nome`, { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ nome: novoNome }) });
                            const json = await res.json();
                            if (json.sucesso) carregarAdmins();
                            else adminErro.textContent = '⚠ ' + (json.erro || 'Erro ao salvar.');
                        } catch (e) { adminErro.textContent = '⚠ Erro de conexão.'; }
                    }
                });
            });
            adminLista.querySelectorAll('.admin-del').forEach(btn => {
                btn.addEventListener('click', async () => {
                    if (!confirm('Inativar este admin?')) return;
                    try {
                        const res = await fetch(`/admins/${btn.dataset.id}`, { method: 'DELETE' });
                        const json = await res.json();
                        if (json.sucesso) carregarAdmins();
                        else adminErro.textContent = '⚠ ' + (json.erro || 'Erro ao inativar.');
                    } catch (e) { adminErro.textContent = '⚠ Erro de conexão.'; }
                });
            });
            adminLista.querySelectorAll('.admin-reativar').forEach(btn => {
                btn.addEventListener('click', async () => {
                    if (!confirm('Reativar este admin?')) return;
                    try {
                        const res = await fetch(`/admins/${btn.dataset.id}/reativar`, { method: 'PATCH' });
                        const json = await res.json();
                        if (json.sucesso) carregarAdmins();
                        else adminErro.textContent = '⚠ ' + (json.erro || 'Erro ao reativar.');
                    } catch (e) { adminErro.textContent = '⚠ Erro de conexão.'; }
                });
            });
        } catch (e) { adminLista.innerHTML = '<div class="admins-empty">Erro ao carregar.</div>'; }
    }

    btnAddAdmin.addEventListener('click', async () => {
        adminErro.textContent = '';
        const nome = document.getElementById('admin-nome-input').value.trim();
        const email = document.getElementById('admin-email-input').value.trim();
        const senha = adminSenhaInput.value;
        const role = document.getElementById('admin-role-select').value;
        if (!nome || !email || !senha) { adminErro.textContent = '⚠ Preencha todos os campos.'; return; }
        if (senha.length < 6) { adminErro.textContent = '⚠ Senha mínima de 6 caracteres.'; return; }
        btnAddAdmin.textContent = 'Salvando...'; btnAddAdmin.disabled = true;
        try {
            const res = await fetch('/admins', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ nome, email, senha, role }) });
            const json = await res.json();
            if (json.sucesso) {
                document.getElementById('admin-nome-input').value = '';
                document.getElementById('admin-email-input').value = '';
                adminSenhaInput.value = '';
                document.getElementById('admin-role-select').value = 'admin';
                carregarAdmins();
            } else adminErro.textContent = '⚠ ' + (json.erro || 'Erro ao salvar.');
        } catch (e) { adminErro.textContent = '⚠ Erro de conexão.'; }
        finally { btnAddAdmin.textContent = '+ Adicionar Admin'; btnAddAdmin.disabled = false; }
    });

    document.getElementById('modal-admins-close').addEventListener('click', () => adminsOverlay.classList.remove('open'));
    adminsOverlay.addEventListener('click', e => { if (e.target === adminsOverlay) adminsOverlay.classList.remove('open'); });

    // ── Modal Horários ────────────────────────────────────
    const horariosOverlay = document.getElementById('modal-horarios-overlay');
    const horarioLista = document.getElementById('horario-lista');
    const horarioErro = document.getElementById('horario-erro');
    const btnAddHorario = document.getElementById('btn-add-horario');

    document.querySelectorAll('.horario-prof-chip').forEach(chip => {
        chip.addEventListener('click', () => {
            document.querySelectorAll('.horario-prof-chip').forEach(c => c.classList.remove('active'));
            chip.classList.add('active');
            horarioProfSelecionado = chip.dataset.id;
            carregarHorarios();
        });
    });

    document.querySelectorAll('.horario-dia-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.horario-dia-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            horarioDiaSelecionado = btn.dataset.dia;
        });
    });

    async function carregarHorarios() {
        if (!horarioProfSelecionado) { horarioLista.innerHTML = '<div class="horarios-empty">Selecione um profissional acima</div>'; return; }
        horarioLista.innerHTML = '<div class="horarios-empty">Carregando...</div>';
        try {
            const res = await fetch(`/horarios-funcionamento?profissional_id=${horarioProfSelecionado}`);
            const json = await res.json();
            if (!json.horarios?.length) { horarioLista.innerHTML = '<div class="horarios-empty">Nenhum horário cadastrado</div>'; return; }
            horarioLista.innerHTML = '';
            json.horarios.sort((a, b) => a.dia_semana - b.dia_semana).forEach(h => {
                const item = document.createElement('div');
                item.className = 'horario-item';
                item.innerHTML = `<span class="horario-item-dia">${DIAS_NOMES[h.dia_semana]}</span><span class="horario-item-range">${h.hora_inicio.substring(0, 5)} – ${h.hora_fim.substring(0, 5)}</span><span class="horario-item-prof">${h.ativo ? 'Ativo' : 'Inativo'}</span><button class="horario-del" data-id="${h.id}">✕</button>`;
                horarioLista.appendChild(item);
            });
            horarioLista.querySelectorAll('.horario-del').forEach(btn => {
                btn.addEventListener('click', async () => {
                    if (!confirm('Remover este horário?')) return;
                    await fetch(`/horarios-funcionamento/${btn.dataset.id}`, { method: 'DELETE' });
                    carregarHorarios();
                });
            });
        } catch (e) { horarioLista.innerHTML = '<div class="horarios-empty">Erro ao carregar.</div>'; }
    }

    btnAddHorario.addEventListener('click', async () => {
        horarioErro.textContent = '';
        const inicio = document.getElementById('horario-inicio-input').value;
        const fim = document.getElementById('horario-fim-input').value;
        if (!horarioProfSelecionado) { horarioErro.textContent = '⚠ Selecione um profissional.'; return; }
        if (horarioDiaSelecionado === null) { horarioErro.textContent = '⚠ Selecione um dia da semana.'; return; }
        if (!inicio || !fim) { horarioErro.textContent = '⚠ Preencha hora início e fim.'; return; }
        if (inicio >= fim) { horarioErro.textContent = '⚠ Hora início deve ser menor que hora fim.'; return; }
        btnAddHorario.textContent = 'Salvando...'; btnAddHorario.disabled = true;
        try {
            const res = await fetch('/horarios-funcionamento', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ profissional_id: horarioProfSelecionado, dia_semana: horarioDiaSelecionado, hora_inicio: inicio, hora_fim: fim }) });
            const json = await res.json();
            if (json.sucesso) {
                document.getElementById('horario-inicio-input').value = '';
                document.getElementById('horario-fim-input').value = '';
                document.querySelectorAll('.horario-dia-btn').forEach(b => b.classList.remove('active'));
                horarioDiaSelecionado = null;
                carregarHorarios();
            } else horarioErro.textContent = '⚠ ' + (json.erro || 'Erro ao salvar.');
        } catch (e) { horarioErro.textContent = '⚠ Erro de conexão.'; }
        finally { btnAddHorario.textContent = '+ Adicionar Horário'; btnAddHorario.disabled = false; }
    });

    document.getElementById('modal-horarios-close').addEventListener('click', () => horariosOverlay.classList.remove('open'));
    horariosOverlay.addEventListener('click', e => { if (e.target === horariosOverlay) horariosOverlay.classList.remove('open'); });

    // ── Slots dinâmicos ───────────────────────────────────
    async function buscarSlotsAdmin() {
        const barbeiro = document.getElementById('modal-barbeiro');
        const servico = document.getElementById('modal-servico');
        const data = document.getElementById('modal-data').value;
        const selectHorario = document.getElementById('modal-horario');
        const profId = barbeiro.selectedOptions[0]?.dataset.id;
        const servicoId = servico.selectedOptions[0]?.dataset.id;
        if (!profId || !servicoId || !data) { selectHorario.innerHTML = '<option value="">Selecione barbeiro, serviço e data</option>'; return; }
        selectHorario.innerHTML = '<option value="">Carregando...</option>';
        try {
            const res = await fetch(`/admin/slots?profissional_id=${profId}&servico_id=${servicoId}&data=${data}`);
            const json = await res.json();
            const slots = (json.slots || []).filter(s => s.status === 'disponivel');
            selectHorario.innerHTML = slots.length ? '<option value="">Selecione</option>' : '<option value="">Nenhum horário disponível</option>';
            slots.forEach(s => {
                const opt = document.createElement('option');
                opt.value = s.hora_inicio.substring(0, 5);
                opt.dataset.horaInicio = s.hora_inicio;
                opt.dataset.horaFim = s.hora_fim;
                opt.textContent = `${s.hora_inicio.substring(0, 5)} – ${s.hora_fim.substring(0, 5)}`;
                selectHorario.appendChild(opt);
            });
        } catch (e) { selectHorario.innerHTML = '<option value="">Erro ao carregar horários</option>'; }
    }

    document.getElementById('modal-horario').addEventListener('change', function () {
        const opt = this.selectedOptions[0];
        document.getElementById('modal-profissional-id').value = document.getElementById('modal-barbeiro').selectedOptions[0]?.dataset.id || '';
        document.getElementById('modal-hora-inicio').value = opt?.dataset.horaInicio || '';
        document.getElementById('modal-hora-fim').value = opt?.dataset.horaFim || '';
        document.getElementById('modal-servico-id').value = document.getElementById('modal-servico').selectedOptions[0]?.dataset.id || '';
    });

    document.getElementById('modal-barbeiro').addEventListener('change', buscarSlotsAdmin);
    document.getElementById('modal-servico').addEventListener('change', buscarSlotsAdmin);
    document.getElementById('modal-data').addEventListener('change', buscarSlotsAdmin);

    // ── Vincular dropdown aos modais ──────────────────────
    bindMenuItemToModal('menu-feriados', 'modal-feriados-overlay', carregarFeriados);
    bindMenuItemToModal('menu-servicos', 'modal-servicos-overlay', carregarServicos);
    bindMenuItemToModal('menu-admins', 'modal-admins-overlay', carregarAdmins);
    bindMenuItemToModal('menu-horarios', 'modal-horarios-overlay', carregarHorarios);

    document.getElementById('menu-dashboard').addEventListener('click', () => { toggleDropdown(false); window.location.href = '/admin/dashboard'; });
    document.getElementById('menu-produtos').addEventListener('click', () => { toggleDropdown(false); window.location.href = '/admin/produtos'; });
    document.getElementById('menu-vendas').addEventListener('click', () => { toggleDropdown(false); window.location.href = '/admin/vendas'; });

    // ── Init ──────────────────────────────────────────────
    renderStats();
    renderCalendar();
    renderCounts();
</script>