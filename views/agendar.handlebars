<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&display=swap');

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
:root {
      {{#if empresa.feminino}}
    --accent:       #c0395a;
    --accent-light: #d4547a;
    --accent-dim:   #d4547a22;
    --bg-main:      #fafafa;
    --bg-panel:     #ffffff;
    --bg-card:      #f5f5f5;
    --border-color: #e8e0e3;
    --text-main:    #1a1a1a;
    --text-muted:   #999999;
    {{else}}
    --accent:       #b8860b;
    --accent-light: #d4a012;
    --accent-dim:   #b8860b33;
    --bg-main:      #0a0a0a;
    --bg-panel:     #111111;
    --bg-card:      #1a1a1a;
    --border-color: #222222;
    --text-main:    #eeeeee;
    --text-muted:   #555555;
    {{/if}}
  }
  body {
    background: var(--bg-main);
    font-family: 'DM Sans', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  .page-agendar {
    min-height: 100vh;
    display: flex;
    background: var(--bg-main);
  }

  .panel-left {
    width: 38%;
    background: var(--bg-panel);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 48px;
  }

  .panel-left::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, var(--accent-dim) 0%, transparent 60%);
    pointer-events: none;
  }

  .big-letter {
    position: absolute;
    top: -40px;
    left: -20px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 380px;
    color: #ffffff06;
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  .barbers-label {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 11px;
    letter-spacing: 4px;
    color: var(--accent);
    margin-bottom: 32px;
    text-transform: uppercase;
  }

  .barbers-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .barber-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 18px;
    border-radius: 10px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    cursor: pointer;
    transition: all 0.25s ease;
    position: relative;
  }

  .barber-card:hover,
  .barber-card.active {
    border-color: var(--accent);
    background: var(--bg-panel);
  }

  .barber-card.active::after {
    content: '✓';
    position: absolute;
    right: 16px;
    color: var(--accent);
    font-size: 14px;
    font-weight: 600;
  }

  .barber-avatar {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--accent-light));
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    color: #fff;
    flex-shrink: 0;
  }

  .barber-info h4 {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-main);
    margin-bottom: 2px;
  }

  .panel-right {
    flex: 1;
    padding: 48px 52px;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
  }

  .top-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 52px;
  }

  .logo-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    color: var(--accent);
    letter-spacing: 3px;
  }

  .sair-link {
    font-size: 12px;
    color: var(--text-muted);
    text-decoration: none;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .sair-link:hover {
    color: var(--accent);
  }

  .form-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 52px;
    color: var(--text-main);
    line-height: 1;
    margin-bottom: 6px;
  }

  .form-subtitle {
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 40px;
  }

  .section-label {
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 14px;
    margin-top: 28px;
  }

  .calendar-wrapper {
    background: var(--bg-panel);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 20px;
  }

  .cal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 18px;
  }

  .cal-nav {
    background: none;
    border: none;
    color: var(--accent);
    font-size: 18px;
    cursor: pointer;
    padding: 4px 10px;
    border-radius: 6px;
    transition: background 0.2s;
  }

  .cal-nav:hover {
    background: var(--accent-dim);
  }

  .cal-month {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    color: var(--text-main);
    letter-spacing: 2px;
  }

  .cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
  }

  .cal-day-name {
    text-align: center;
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 1px;
    padding-bottom: 8px;
    text-transform: uppercase;
  }

  .cal-day {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    font-size: 13px;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s;
    border: 1px solid transparent;
  }

  .cal-day:hover:not(.disabled):not(.empty) {
    background: var(--accent-dim);
    border-color: var(--accent);
    color: var(--text-main);
  }

  .cal-day.today {
    border-color: var(--accent-dim);
    color: var(--accent);
  }

  .cal-day.selected {
    background: var(--accent);
    color: #fff;
    font-weight: 600;
  }

  .cal-day.disabled {
    color: var(--border-color);
    cursor: not-allowed;
  }

  .cal-day.empty {
    cursor: default;
  }

  .horarios-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
  }

  .horarios-loading {
    grid-column: 1 / -1;
    text-align: center;
    font-size: 12px;
    color: var(--text-muted);
    padding: 16px;
    letter-spacing: 1px;
  }

  .horario-btn {
    background: var(--bg-panel);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 10px 4px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'DM Sans', sans-serif;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .horario-btn .slot-hora {
    font-size: 13px;
    color: var(--text-muted);
  }

  .horario-btn .slot-fim {
    font-size: 10px;
    color: var(--border-color);
  }

  .horario-btn:hover:not(.indisponivel) {
    border-color: var(--accent);
    background: var(--accent-dim);
  }

  .horario-btn:hover:not(.indisponivel) .slot-hora {
    color: var(--text-main);
  }

  .horario-btn:hover:not(.indisponivel) .slot-fim {
    color: var(--accent);
  }

  .horario-btn.selected {
    background: var(--accent);
    border-color: var(--accent);
  }

  .horario-btn.selected .slot-hora {
    color: #fff;
    font-weight: 600;
  }

  .horario-btn.selected .slot-fim {
    color: #ffffff77;
  }

  .horario-btn.indisponivel {
    background: var(--bg-main);
    border-color: var(--border-color);
    cursor: not-allowed;
    opacity: 0.4;
  }

  .horario-btn.indisponivel .slot-hora {
    color: var(--text-muted);
    text-decoration: line-through;
  }

  .slots-aviso {
    grid-column: 1 / -1;
    text-align: center;
    font-size: 12px;
    color: var(--text-muted);
    padding: 20px;
    letter-spacing: 1px;
    border: 1px dashed var(--border-color);
    border-radius: 8px;
  }

  .servicos-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
  }

  .servico-card {
    background: var(--bg-panel);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 14px 16px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .servico-card:hover,
  .servico-card.selected {
    border-color: var(--accent);
    background: var(--accent-dim);
  }

  .servico-card.selected .servico-nome {
    color: var(--accent);
  }

  .servico-nome {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-main);
    margin-bottom: 4px;
  }

  .servico-preco {
    font-size: 12px;
    color: var(--text-muted);
  }

  .resumo-bar {
    margin-top: 36px;
    padding: 20px 24px;
    background: var(--bg-panel);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .resumo-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .resumo-info span {
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .resumo-info p {
    font-size: 14px;
    color: var(--text-main);
    min-height: 20px;
  }

  .btn-agendar {
    background: var(--accent);
    color: #fff;
    border: none;
    padding: 14px 36px;
    border-radius: 8px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 2px;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .btn-agendar:hover {
    background: var(--accent-light);
    transform: translateY(-1px);
  }

  .btn-agendar:disabled {
    background: var(--border-color);
    color: var(--text-muted);
    cursor: not-allowed;
    transform: none;
  }

  .msg-erro {
    color: #c0392b;
    font-size: 13px;
    margin-top: 12px;
    text-align: center;
  }

  .msg-sucesso {
    color: #27ae60;
    font-size: 13px;
    margin-top: 12px;
    text-align: center;
  }

  @media (max-width: 768px) {
    .page-agendar {
      flex-direction: column;
    }

    .panel-left {
      width: 100%;
      padding: 24px;
    }

    .big-letter {
      display: none;
    }

    .panel-right {
      padding: 28px 24px;
    }

    .horarios-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .servicos-grid {
      grid-template-columns: 1fr;
    }

    .resumo-bar {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<div class="page-agendar">
 {{#if pedirNascimento}}
<div id="overlay-nascimento" style="position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:9999;display:flex;align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:16px;padding:32px 28px;width:88%;max-width:320px;text-align:center;box-shadow:0 12px 40px rgba(0,0,0,.25);">
    
    <div style="width:44px;height:44px;background:#f5f5f5;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
      </svg>
    </div>

    <p style="font-size:1rem;font-weight:700;color:#111;margin:0 0 6px;">Data de nascimento</p>
    <p style="font-size:.82rem;color:#555;margin:0 0 20px;">Preencha uma única vez para continuar.</p>

    <input type="date" id="input-nascimento" style="width:100%;padding:11px 12px;border:1.5px solid #ddd;border-radius:10px;font-size:.95rem;color:#111;box-sizing:border-box;margin-bottom:14px;outline:none;">

    <button onclick="salvarNascimento()" style="width:100%;padding:12px;background:#111;color:#fff;border:none;border-radius:10px;font-size:.95rem;font-weight:600;cursor:pointer;letter-spacing:.3px;">
      Salvar
    </button>
    <button onclick="fecharNascimento()" style="width:100%;padding:9px;margin-top:6px;background:none;border:none;color:#888;font-size:.82rem;cursor:pointer;">
      Agora não
    </button>

  </div>
</div>

<script>
async function salvarNascimento() {
    const val = document.getElementById('input-nascimento').value;
    if (!val) return alert('Selecione uma data.');
    const res = await fetch('/cliente/nascimento/{{token}}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nascimento: val })
    });
    if ((await res.json()).sucesso) fecharNascimento();
}
function fecharNascimento() {
    document.getElementById('overlay-nascimento').remove();
}
</script>
{{/if}}

  <!-- ── Painel Esquerdo: Profissionais ── -->
  <div class="panel-left">
    <div class="big-letter">B</div>
    <p class="barbers-label">Escolha o Profissional</p>
    <div class="barbers-list" id="barbers-list">
      {{#if barbeiros}}
      {{#each barbeiros}}
      <div class="barber-card" data-id="{{id}}" data-nome="{{nome}}">
        {{#if foto}}
        <div class="barber-avatar" style="background:none;padding:0;overflow:hidden;">
          <img src="{{foto}}" alt="{{nome}}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">
        </div>
        {{else}}
        <div class="barber-avatar">{{substr nome 0 1}}</div>
        {{/if}}
        <div class="barber-info">
          <h4>{{nome}}</h4>
        </div>
      </div>
      {{/each}}
      {{else}}
      <p style="color:#555;font-size:13px;">Nenhum profissional disponível</p>
      {{/if}}
    </div>
  </div>

  <!-- ── Painel Direito: Formulário ── -->
  <div class="panel-right">
    <div class="top-bar">
      <!--  <span class="logo-text">Barbearia</span>-->
      <a href="/" class="sair-link">← Sair</a>
    </div>

    <h1 class="form-title">Novo<br>Agendamento</h1>
    <p class="form-subtitle">Selecione serviço, data e horário</p>

{{!-- ── Painel agendamentos em aberto ── --}}
<div id="painel-agendamentos" style="margin-bottom:32px;">
    <div style="font-size:10px;letter-spacing:3px;text-transform:uppercase;
        color:var(--accent);margin-bottom:12px;display:flex;align-items:center;
        justify-content:space-between;">
        Seus agendamentos
        <span style="font-size:10px;color:var(--text-muted);letter-spacing:1px;">
            futuros
        </span>
    </div>
    <div id="lista-agendamentos-abertos" style="display:flex;flex-direction:column;gap:8px;">
        <div style="font-size:12px;color:var(--text-muted);padding:8px 0;">Carregando...</div>
    </div>
</div>
{{!-- ── fim painel ── --}}
    {{#if erro}}
    <div class="msg-erro">⚠ {{erro}}</div>
    {{/if}}
    {{#if Sucesso}}
    <div class="msg-sucesso">
      ✓ {{Sucesso}}
      <script>
        window.onload = function () {
          const link = "{{{whatsappLink}}}";

          if (link && link !== "null" && link !== "") {
            setTimeout(function () {
              // Redireciona a aba atual para o WhatsApp
              window.location.href = link;
            }, 500); // 1 segundo para o usuário ler a mensagem de sucesso
          }
        };
      </script>
      <a href="{{{whatsappLink}}}" target="_blank" style="display:inline-flex;align-items:center;gap:8px;margin-top:12px;
            background:#25d366;color:#fff;padding:12px 20px;border-radius:8px;
            text-decoration:none;font-size:13px;font-weight:500;">
        <svg width="16" height="16" viewBox="0 0 32 32" fill="currentColor">
          <path
            d="M16 0C7.163 0 0 7.163 0 16c0 2.833.738 5.493 2.031 7.807L0 32l8.406-2.004A15.93 15.93 0 0016 32c8.837 0 16-7.163 16-16S24.837 0 16 0zm0 29.333a13.27 13.27 0 01-6.771-1.854l-.486-.289-5.03 1.198 1.25-4.916-.317-.504A13.226 13.226 0 012.667 16C2.667 8.636 8.636 2.667 16 2.667S29.333 8.636 29.333 16 23.364 29.333 16 29.333zm7.27-9.878c-.398-.199-2.352-1.16-2.717-1.292-.364-.133-.629-.199-.894.199-.265.398-1.027 1.292-1.259 1.557-.232.265-.464.298-.862.1-.398-.2-1.681-.62-3.203-1.977-1.184-1.057-1.983-2.362-2.215-2.76-.232-.398-.025-.613.174-.811.179-.178.398-.464.597-.696.199-.232.265-.398.398-.663.133-.265.066-.497-.033-.696-.1-.199-.894-2.154-1.225-2.95-.322-.774-.65-.669-.894-.681l-.762-.013c-.265 0-.696.1-1.06.497-.364.398-1.392 1.36-1.392 3.314s1.425 3.844 1.624 4.109c.199.265 2.804 4.28 6.793 5.998.95.41 1.69.655 2.268.838.953.303 1.82.26 2.505.158.764-.114 2.352-.961 2.683-1.889.332-.928.332-1.723.232-1.889-.099-.166-.364-.265-.762-.464z" />
        </svg>
        Confirmar pelo WhatsApp
      </a>
    </div>
    {{/if}}

    <form action="/agendar/{{token}}" method="post" id="form-agendar">
      {{!-- Hidden: mantém campos antigos + adiciona novos --}}
      <input type="hidden" name="barbeiro" id="input-barbeiro">
      <input type="hidden" name="data" id="input-data">
      <input type="hidden" name="horario" id="input-horario">
      <input type="hidden" name="servico" id="input-servico">
      <input type="hidden" name="profissional_id" id="input-profissional-id">
      <input type="hidden" name="hora_inicio" id="input-hora-inicio">
      <input type="hidden" name="hora_fim" id="input-hora-fim">
      <input type="hidden" name="servico_id" id="input-servico-id">

      <!-- SERVIÇO — primeiro para já saber a duração antes de mostrar slots -->
      <p class="section-label">Serviço</p>
      <div class="servicos-grid">
        {{#each servicos}}
        <div class="servico-card" data-id="{{id}}" data-nome="{{nome}}" data-duracao="{{duracao_minutos}}"
          data-preco="R$ {{valor}}" data-sessoes="{{qtd_sessoes}}"> {{!-- 👈 adiciona isso --}}
          <div class="servico-nome">{{nome}}</div>
          {{#if descricao}}
          <div style="font-size:11px;color:#666;margin-top:3px;">{{descricao}}</div>
          {{/if}}
          <div class="servico-preco" style="margin-top:6px;">R$ {{valor}}</div>
          {{#if qtd_sessoes}}
          <div style="font-size:10px;color:#b8860b;margin-top:4px;letter-spacing:1px;">📦 PACOTE · {{qtd_sessoes}}
            SESSÕES</div>
          {{/if}}
        </div>
        {{/each}}
      </div>

      <!-- CALENDÁRIO -->
      <p class="section-label" id="secao-data">Data</p>
      <div class="calendar-wrapper">
        <div class="cal-header">
          <button type="button" class="cal-nav" id="prev-month">&#8592;</button>
          <span class="cal-month" id="cal-month-label"></span>
          <button type="button" class="cal-nav" id="next-month">&#8594;</button>
        </div>
        <div class="cal-grid" id="cal-grid"></div>
      </div>

      <!-- SLOTS -->
      <p class="section-label" id="secao-horario">Horário</p>
      <div class="horarios-grid" id="horarios-grid">
        <div class="horarios-loading">Selecione um serviço e uma data</div>
      </div>

      <!-- PACOTE - adiciona após os slots -->
      <div id="secao-pacote" style="display:none;">
        <p class="section-label">Sessões do Pacote</p>
        <div id="lista-sessoes-cliente" style="display:flex;flex-direction:column;gap:12px;"></div>
      </div>

      <!-- RESUMO -->
      <div class="resumo-bar">
        <div class="resumo-info">
          <span>Resumo</span>
          <p id="resumo-texto">Selecione profissional, serviço, data e horário</p>
        </div>
        <textarea id="input-observacao-agendamento" name="observacao"
            placeholder="Observação (opcional)..."
            style="width:100%;background:var(--bg-card);border:1px solid var(--border-color);
                border-radius:8px;padding:10px 12px;font-family:'DM Sans',sans-serif;
                font-size:12px;color:var(--text-main);outline:none;resize:none;
                height:60px;transition:border-color .2s;margin-top:4px;"
            onfocus="this.style.borderColor='var(--accent)'"
            onblur="this.style.borderColor='var(--border-color)'"></textarea>    
        <button type="submit" class="btn-agendar" id="btn-submit" disabled>Confirmar</button>
      </div>
    </form>
  </div>

  {{!-- ── Modal Reagendar ── --}}
<div id="modal-reagendar-overlay" style="
    display:none;position:fixed;inset:0;
    background:#000000cc;backdrop-filter:blur(4px);
    z-index:500;align-items:center;justify-content:center;">
    <div style="
        background:var(--bg-panel);border:1px solid var(--border-color);
        border-radius:14px;padding:28px;width:100%;max-width:380px;
        margin:16px;position:relative;">
        <button id="btn-fechar-reagendar" style="
            position:absolute;top:14px;right:14px;background:none;
            border:none;color:var(--text-muted);font-size:18px;cursor:pointer;">✕</button>
        <div style="font-family:'Bebas Neue',sans-serif;font-size:24px;
            letter-spacing:2px;color:var(--text-main);margin-bottom:4px;">
            Reagendar
        </div>
        <div id="reagendar-info" style="font-size:12px;color:var(--text-muted);margin-bottom:20px;"></div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
            <div>
                <p style="font-size:10px;letter-spacing:2px;color:var(--accent);
                    text-transform:uppercase;margin-bottom:6px;">Nova Data</p>
                <input type="date" id="reagendar-data" style="
                    background:var(--bg-card);border:1px solid var(--border-color);
                    border-radius:8px;padding:10px 12px;font-family:'DM Sans',sans-serif;
                    font-size:13px;color:var(--text-main);outline:none;width:100%;
                    transition:border-color .2s;"
                    onfocus="this.style.borderColor='var(--accent)'"
                    onblur="this.style.borderColor='var(--border-color)'">
            </div>
            <div>
                <p style="font-size:10px;letter-spacing:2px;color:var(--accent);
                    text-transform:uppercase;margin-bottom:6px;">Horário</p>
                <select id="reagendar-horario" style="
                    background:var(--bg-card);border:1px solid var(--border-color);
                    border-radius:8px;padding:10px 12px;font-family:'DM Sans',sans-serif;
                    font-size:13px;color:var(--text-main);outline:none;width:100%;
                    transition:border-color .2s;"
                    onfocus="this.style.borderColor='var(--accent)'"
                    onblur="this.style.borderColor='var(--border-color)'">
                    <option value="">Selecione a data</option>
                </select>
            </div>
        </div>

        <div id="reagendar-erro" style="font-size:12px;color:#c0392b;min-height:16px;margin-bottom:12px;"></div>

        <button id="btn-confirmar-reagendar" style="
            width:100%;background:var(--accent);border:none;color:#000;
            padding:12px;border-radius:8px;font-family:'Bebas Neue',sans-serif;
            font-size:18px;letter-spacing:2px;cursor:pointer;transition:background .2s;"
            onmouseover="this.style.background='var(--accent-light)'"
            onmouseout="this.style.background='var(--accent)'">
            Confirmar
        </button>
    </div>
</div>
</div>

<script>
  const TOKEN = '{{token}}';
  const DIAS_CANCELAMENTO = {{empresa.dias_cancelamento}}; 
  const hoje = new Date();
const state = {
  profissionalId: null,
  profissionalNome: null,
  servicoId: null,
  servicoNome: null,
  servicoPreco: null,
  qtdSessoes: null,
  sessoes: [],
  servicosIds: [],
  servicosNomes: [],
  servicosDuracoes: [],
  servicosPrecos: [],
  data: null,
  horaInicio: null,
  horaFim: null,
  viewYear: hoje.getFullYear(),
  viewMonth: hoje.getMonth(),
};
  let feriadosSet = new Set();
  let slotsCache = [];  // guarda os slots da última busca para re-render sem refetch

  // ── Feriados ─────────────────────────────────────────────
  async function carregarFeriados() {
    try {
      const res = await fetch('/feriados');
      const json = await res.json();
      feriadosSet = new Set((json.feriados || []).map(f => f.data));
    } catch (e) { feriadosSet = new Set(); }
  }

  function toDateStr(d) {
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
  }

  // ── Busca slots ───────────────────────────────────────────
  async function buscarSlots() {
    const grid = document.getElementById('horarios-grid');

    if (!state.profissionalId || !state.servicoId || !state.data) {
      grid.innerHTML = '<div class="horarios-loading">Selecione profissional, serviço e data</div>';
      return;
    }

    grid.innerHTML = '<div class="horarios-loading">Carregando horários...</div>';

    try {
      const duracaoTotal = (state.servicosDuracoes || []).reduce((a,b) => a+b, 0) || null;
      const url = `/slots?profissional_id=${state.profissionalId}&servico_id=${state.servicoId}`
                + `${duracaoTotal ? '&duracao=' + duracaoTotal : ''}`
                + `&data=${toDateStr(state.data)}&token=${TOKEN}`;
      const res = await fetch(url);
      const json = await res.json();
      slotsCache = json.slots || [];

      // Se horário selecionado ficou indisponível, reseta
      if (state.horaInicio) {
        const ainda = slotsCache.find(s => s.hora_inicio === state.horaInicio && s.status === 'disponivel');
        if (!ainda) resetHorario();
      }

      renderSlots(slotsCache);
    } catch (e) {
      slotsCache = [];
      grid.innerHTML = '<div class="slots-aviso">Erro ao carregar horários. Tente novamente.</div>';
    }

    updateResumo();
  }

  // ── Renderiza slots ───────────────────────────────────────
  function renderSlots(slots) {
    const grid = document.getElementById('horarios-grid');
    grid.innerHTML = '';

    if (!slots.length) {
      grid.innerHTML = '<div class="slots-aviso">Nenhum horário disponível neste dia</div>';
      return;
    }

    slots.forEach(slot => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'horario-btn';
      btn.innerHTML = `
        <span class="slot-hora">${slot.hora_inicio.substring(0, 5)}</span>
        <span class="slot-fim">até ${slot.hora_fim.substring(0, 5)}</span>
      `;

      if (slot.status === 'indisponivel') {
        btn.classList.add('indisponivel');
        btn.title = 'Horário indisponível';
      } else {
        if (state.horaInicio === slot.hora_inicio) btn.classList.add('selected');
        btn.addEventListener('click', () => {
          state.horaInicio = slot.hora_inicio;
          state.horaFim = slot.hora_fim;
          document.getElementById('input-horario').value = slot.hora_inicio.substring(0, 5);
          document.getElementById('input-hora-inicio').value = slot.hora_inicio;
          document.getElementById('input-hora-fim').value = slot.hora_fim;
          renderSlots(slotsCache); // re-render para atualizar selected sem novo fetch
          updateResumo();
        });
      }
      grid.appendChild(btn);
    });
  }

  function resetHorario() {
    state.horaInicio = null;
    state.horaFim = null;
    document.getElementById('input-horario').value = '';
    document.getElementById('input-hora-inicio').value = '';
    document.getElementById('input-hora-fim').value = '';
  }

  // ── Calendário ───────────────────────────────────────────
  const MESES = ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'];
  const DIAS_NOM = ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'];

  function renderCalendar() {
    const y = state.viewYear, m = state.viewMonth;
    document.getElementById('cal-month-label').textContent = `${MESES[m]} ${y}`;

    const grid = document.getElementById('cal-grid');
    grid.innerHTML = '';

    DIAS_NOM.forEach(d => {
      const el = document.createElement('div');
      el.className = 'cal-day-name';
      el.textContent = d;
      grid.appendChild(el);
    });

    const firstDay = new Date(y, m, 1).getDay();
    const totalDays = new Date(y, m + 1, 0).getDate();
    const today = new Date(); today.setHours(0, 0, 0, 0);

    for (let i = 0; i < firstDay; i++) {
      const el = document.createElement('div');
      el.className = 'cal-day empty';
      grid.appendChild(el);
    }

    for (let d = 1; d <= totalDays; d++) {
      const date = new Date(y, m, d);
      const el = document.createElement('div');
      el.className = 'cal-day';
      el.textContent = d;

      const feriado = feriadosSet.has(toDateStr(date));

      if (date < today || feriado) {
        el.classList.add('disabled');
        if (feriado) el.title = 'Feriado — sem atendimento';
      } else {
        if (date.getTime() === today.getTime()) el.classList.add('today');
        if (state.data && toDateStr(date) === toDateStr(state.data)) el.classList.add('selected');

        el.addEventListener('click', async () => {
          state.data = date;
          document.getElementById('input-data').value = toDateStr(date);
          resetHorario();
          renderCalendar();
          await buscarSlots();
        });
      }
      grid.appendChild(el);
    }
  }

  document.getElementById('prev-month').addEventListener('click', () => {
    state.viewMonth--;
    if (state.viewMonth < 0) { state.viewMonth = 11; state.viewYear--; }
    renderCalendar();
  });
  document.getElementById('next-month').addEventListener('click', () => {
    state.viewMonth++;
    if (state.viewMonth > 11) { state.viewMonth = 0; state.viewYear++; }
    renderCalendar();
  });

  // ── Profissionais ─────────────────────────────────────────
  document.querySelectorAll('.barber-card').forEach(card => {
    card.addEventListener('click', async () => {
      document.querySelectorAll('.barber-card').forEach(c => c.classList.remove('active'));
      card.classList.add('active');
      state.profissionalId = card.dataset.id;
      state.profissionalNome = card.dataset.nome;
      document.getElementById('input-profissional-id').value = state.profissionalId;
      document.getElementById('input-barbeiro').value = state.profissionalNome;
      resetHorario();
      await buscarSlots();
    });
  });

  // ── Serviços — MULTI-SERVICO ─────────────────────────────
  // state agora guarda arrays
  // state.servicosIds    = []
  // state.servicosNomes  = []
  // state.servicosDuracoes = []
  // state.servicosPrecos = []
  // state.servicoId  e state.servicoNome continuam como "primeiro" para compatibilidade

  document.querySelectorAll('.servico-card').forEach(card => {
    card.addEventListener('click', async () => {
      const id       = card.dataset.id;
      const nome     = card.dataset.nome;
      const duracao  = parseInt(card.dataset.duracao) || 30;
      const preco    = parseFloat((card.dataset.preco || '0').replace('R$','').replace(',','.').trim()) || 0;
      const sessoes  = card.dataset.sessoes && card.dataset.sessoes !== 'null'
                        ? parseInt(card.dataset.sessoes) : null;

      // Não mistura pacote com serviço normal
      const temPacote  = (state.servicosIds || []).some(sid => {
        const c = document.querySelector(`.servico-card[data-id="${sid}"]`);
        return c && c.dataset.sessoes && c.dataset.sessoes !== 'null';
      });
      if (sessoes && (state.servicosIds || []).length > 0 && !temPacote) {
        alert('Pacotes devem ser agendados sozinhos. Limpe a seleção antes.');
        return;
      }
      if (!sessoes && temPacote) {
        alert('Remova o pacote antes de adicionar serviços avulsos.');
        return;
      }

      // Inicializa arrays se necessário
      if (!state.servicosIds) {
        state.servicosIds = [];
        state.servicosNomes = [];
        state.servicosDuracoes = [];
        state.servicosPrecos = [];
      }

      const idx = state.servicosIds.indexOf(id);
      if (idx === -1) {
        // Adiciona
        state.servicosIds.push(id);
        state.servicosNomes.push(nome);
        state.servicosDuracoes.push(duracao);
        state.servicosPrecos.push(preco);
        card.classList.add('selected');
      } else {
        // Remove (toggle)
        state.servicosIds.splice(idx, 1);
        state.servicosNomes.splice(idx, 1);
        state.servicosDuracoes.splice(idx, 1);
        state.servicosPrecos.splice(idx, 1);
        card.classList.remove('selected');
      }

      // Compat: primeiro serviço como "principal" para slots e conflito
      state.servicoId    = state.servicosIds[0]    || null;
      state.servicoNome  = state.servicosNomes.join(' + ') || null;
      state.servicoPreco = 'R$ ' + state.servicosPrecos
                            .reduce((a,b) => a+b, 0)
                            .toFixed(2).replace('.', ',');
      state.qtdSessoes   = sessoes; // pacote continua igual

      // Atualiza hidden inputs
      document.getElementById('input-servico').value    = state.servicosNomes.join(' + ');
      document.getElementById('input-servico-id').value = state.servicosIds[0] || '';      
      resetHorario();

      if (state.qtdSessoes) {
        document.getElementById('secao-data').style.display = 'none';
        document.querySelector('.calendar-wrapper').style.display = 'none';
        document.getElementById('secao-horario').style.display = 'none';
        document.getElementById('horarios-grid').style.display = 'none';
        document.getElementById('secao-pacote').style.display = '';
        gerarSessoesPacote(state.qtdSessoes);
      } else {
        document.getElementById('secao-data').style.display = '';
        document.querySelector('.calendar-wrapper').style.display = '';
        document.getElementById('secao-horario').style.display = '';
        document.getElementById('horarios-grid').style.display = '';
        document.getElementById('secao-pacote').style.display = 'none';
        if (state.servicosIds.length > 0) await buscarSlots();
      }

      updateResumo();
    });
  });
  // cadastrar combo
  async function gerarSessoesPacote(qtd) {
    state.sessoes = Array(qtd).fill(null).map(() => ({ data: null, horaInicio: null, horaFim: null }));
    const lista = document.getElementById('lista-sessoes-cliente');
    lista.innerHTML = '';

    for (let i = 0; i < qtd; i++) {
      const bloco = document.createElement('div');
      bloco.style.cssText = 'background:#111;border:1px solid #222;border-radius:10px;padding:16px;display:flex;flex-direction:column;gap:12px;';
      bloco.innerHTML = `
              <span style="font-size:10px;letter-spacing:3px;color:#b8860b;text-transform:uppercase;">Sessão ${i + 1}</span>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                  <div>
                      <p style="font-size:10px;letter-spacing:2px;color:#555;text-transform:uppercase;margin-bottom:6px;">Data</p>
                      <input type="date" class="sessao-data-cliente" data-index="${i}" 
                          min="${toDateStr(new Date())}"
                          style="background:#0a0a0a;border:1px solid #222;border-radius:8px;padding:10px 12px;font-family:'DM Sans',sans-serif;font-size:13px;color:#eee;outline:none;width:100%;transition:border-color .2s;"
                          onfocus="this.style.borderColor='#b8860b'" onblur="this.style.borderColor='#222'">
                  </div>
                  <div>
                      <p style="font-size:10px;letter-spacing:2px;color:#555;text-transform:uppercase;margin-bottom:6px;">Horário</p>
                      <select class="sessao-horario-cliente" data-index="${i}"
                          style="background:#0a0a0a;border:1px solid #222;border-radius:8px;padding:10px 12px;font-family:'DM Sans',sans-serif;font-size:13px;color:#eee;outline:none;width:100%;transition:border-color .2s;"
                          onfocus="this.style.borderColor='#b8860b'" onblur="this.style.borderColor='#222'">
                          <option value="">Selecione a data</option>
                      </select>
                  </div>
              </div>
          `;
      lista.appendChild(bloco);

      // Busca slots ao selecionar data
      bloco.querySelector('.sessao-data-cliente').addEventListener('change', async function () {
        const data = this.value;
        const select = bloco.querySelector('.sessao-horario-cliente');
        select.innerHTML = '<option value="">Carregando...</option>';

        try {
          const url = `/slots?profissional_id=${state.profissionalId}&servico_id=${state.servicoId}&data=${data}&token=${TOKEN}`;
          const res = await fetch(url);
          const json = await res.json();
          const slots = (json.slots || []).filter(s => s.status === 'disponivel');

          select.innerHTML = slots.length
            ? '<option value="">Selecione</option>'
            : '<option value="">Nenhum horário disponível</option>';

          slots.forEach(s => {
            const opt = document.createElement('option');
            opt.value = s.hora_inicio;
            opt.dataset.horaFim = s.hora_fim;
            opt.textContent = `${s.hora_inicio.substring(0, 5)} – ${s.hora_fim.substring(0, 5)}`;
            select.appendChild(opt);
          });
        } catch {
          select.innerHTML = '<option value="">Erro ao carregar</option>';
        }

        // Atualiza data no state
        state.sessoes[i].data = data;
        state.sessoes[i].horaInicio = null;
        state.sessoes[i].horaFim = null;
        updateResumo();
      });

      // Salva horário selecionado
      bloco.querySelector('.sessao-horario-cliente').addEventListener('change', function () {
        const opt = this.selectedOptions[0];
        state.sessoes[i].horaInicio = opt?.value || null;
        state.sessoes[i].horaFim = opt?.dataset.horaFim || null;
        updateResumo();
      });
    }
  }
  // ── Resumo ───────────────────────────────────────────────
  function updateResumo() {
    const partes = [];
    if (state.profissionalNome) partes.push(state.profissionalNome);
    if (state.servicoNome) partes.push(state.servicoNome);

    // MULTI-SERVICO — mostra valor total se houver serviços selecionados
    if (state.servicosPrecos && state.servicosPrecos.length) {
      const total = state.servicosPrecos.reduce((a, b) => a + b, 0);
      partes.push('R$ ' + total.toFixed(2).replace('.', ','));
    }

    let tudo = false;

    if (state.qtdSessoes) {
      // Pacote — verifica se todas as sessões estão preenchidas
      const sessoesCompletas = state.sessoes.filter(s => s.data && s.horaInicio).length;
      partes.push(`${sessoesCompletas}/${state.qtdSessoes} sessões selecionadas`);
      tudo = state.profissionalId && state.servicoId && sessoesCompletas === state.qtdSessoes;
    } else {
      // Normal
      if (state.data) partes.push(state.data.toLocaleDateString('pt-BR'));
      if (state.horaInicio) partes.push(`${state.horaInicio.substring(0, 5)} – ${state.horaFim.substring(0, 5)}`);
      // MULTI-SERVICO — tudo exige ao menos 1 serviço selecionado (servicosIds)
      tudo = state.profissionalId
          && state.servicosIds && state.servicosIds.length > 0
          && state.data
          && state.horaInicio;
    }

    const p = document.getElementById('resumo-texto');
    const btn = document.getElementById('btn-submit');
    p.textContent = partes.length ? partes.join(' · ') : 'Selecione profissional, serviço, data e horário';
    p.style.color = tudo ? '#ccc' : '#555';
    btn.disabled = !tudo;
  }

  // ── Submit ───────────────────────────────────────────────
  document.getElementById('form-agendar').addEventListener('submit', async function (e) {
    e.preventDefault();

    const observacao = document.getElementById('input-observacao-agendamento')?.value?.trim() || '';

    if (state.qtdSessoes) {
      const ok = confirm(
        `Confirmar pacote?\n\n` +
        `👤 ${state.profissionalNome}\n` +
        `✂️ ${state.servicoNome} (${state.servicoPreco})\n` +
        `📦 ${state.qtdSessoes} sessões agendadas`
      );
      if (!ok) return;

      const body = new URLSearchParams({
        barbeiro: state.profissionalNome,
        profissional_id: state.profissionalId,
        servico: state.servicoNome,
        servico_id: state.servicoId,
        nome: '{{clienteNome}}',
        telefone: '{{clienteTelefone}}',
        observacao: observacao,
        sessoes: JSON.stringify(state.sessoes.map(s => ({
          data: s.data,
          hora_inicio: s.horaInicio,
          hora_fim: s.horaFim
        })))
      });

      const res = await fetch(`/pacote/${TOKEN}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: body.toString()
      });
      const json = await res.json();
      if (json.sucesso) {
        if (json.whatsappLink) {
          window.location.href = json.whatsappLink;
        } else {
          window.location.reload();
        }
      } else {
        alert('⚠ ' + (json.erro || 'Erro ao salvar pacote.'));
      }

    } else {
      const hora = state.horaInicio
        ? `${state.horaInicio.substring(0, 5)} – ${state.horaFim.substring(0, 5)}`
        : '';
      const ok = confirm(
        `Confirmar agendamento?\n\n` +
        `👤 ${state.profissionalNome}\n` +
        `✂️ ${state.servicoNome} (${state.servicoPreco})\n` +
        `📅 ${state.data?.toLocaleDateString('pt-BR')} às ${hora}`
      );
      if (!ok) return;
      this.submit();
    }
});

// ── Agendamentos abertos do cliente ─────────────────────
async function carregarAgendamentosCliente() {
    try {
        const res = await fetch(`/cliente/agendamentos/${TOKEN}`);
        const json = await res.json();
        
        const lista = document.getElementById('lista-agendamentos-abertos');
        if (!lista) return;

        if (!json.sucesso || !json.agendamentos.length) {
            lista.innerHTML = '<div style="font-size:12px;color:var(--text-muted);padding:8px 0;">Nenhum agendamento futuro.</div>';
            return;
        }

        lista.innerHTML = '';
        json.agendamentos.forEach(a => {
            const card = document.createElement('div');
            card.className = 'card-agend-aberto';
            card.dataset.id = a.id;
            card.style.cssText = `
                background:var(--bg-panel);
                border:1px solid var(--border-color);
                border-left:3px solid var(--accent);
                border-radius:10px;
                padding:14px 16px;
                display:flex;
                align-items:center;
                justify-content:space-between;
                gap:12px;`;
                // Verifica se o agendamento é hoje (bloqueia cancelar/reagendar)
            const hoje = new Date();
            const [diaA, mesA, anoA] = a.data.split('/').map(Number);
            const dataAgend = new Date(anoA, mesA - 1, diaA);
            hoje.setHours(0, 0, 0, 0);
            dataAgend.setHours(0, 0, 0, 0);
            const diffDias = Math.ceil((dataAgend - hoje) / (1000 * 60 * 60 * 24));

            // 0 = sem restrição (só bloqueia se já passou)
            // > 0 = bloqueia se faltar menos que X dias
            const bloqueado = DIAS_CANCELAMENTO === 0 
                ? diffDias < 0   // só bloqueia datas passadas
                : diffDias < DIAS_CANCELAMENTO;
            card.innerHTML = `
            <div style="display:flex;flex-direction:column;gap:4px;flex:1;min-width:0;">
                <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                    <span style="font-family:'Bebas Neue',sans-serif;font-size:18px;
                        color:var(--accent);letter-spacing:1px;">${a.data}</span>
                    <span style="font-size:12px;color:var(--text-muted);">${a.horario}</span>
                </div>
                <div class="agend-servico" style="font-size:13px;color:var(--text-main);
                    font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                    ✂️ ${a.servico}
                </div>
                <div style="font-size:11px;color:var(--text-muted);">
                    👤 ${a.barbeiro}
                </div>
            </div>
            <div style="display:flex;flex-direction:column;gap:10px;flex-shrink:0;">
                ${bloqueado  ? `
                    <div style="font-size:10px;color:var(--text-muted);text-align:center;
                    letter-spacing:1px;line-height:1.6;padding:0 4px;">
                    ${diffDias === 0 ? '📅 Hoje' : DIAS_CANCELAMENTO > 0 ? `⏱ Prazo encerrado` : '📅 Passado'}<br>
                    <span style="color:var(--border-color);">sem alterações</span>
                </div>
                ` : `
                    <button class="btn-reagendar-agend" data-id="${a.id}" 
                        data-servico="${a.servico}" data-barbeiro="${a.barbeiro}"
                        data-profissional-id="${a.profissional_id}"
                        data-servico-id="${a.servico_id}"
                        data-hora-inicio="${a.hora_inicio || ''}"
                        data-hora-fim="${a.hora_fim || ''}"
                        style="background:var(--accent);border:none;color:#000;
                            padding:7px 0;border-radius:7px;font-size:11px;
                            letter-spacing:1px;text-transform:uppercase;cursor:pointer;
                            transition:all .2s;width:100%;
                            font-family:'DM Sans',sans-serif;font-weight:600;">
                        Reagendar
                    </button>
                    <button class="btn-cancelar-agend" data-id="${a.id}"
                        style="background:none;border:1px solid var(--border-color);
                            color:var(--text-muted);padding:7px 0;border-radius:7px;
                            font-size:11px;letter-spacing:1px;text-transform:uppercase;
                            cursor:pointer;transition:all .2s;width:100%;
                            font-family:'DM Sans',sans-serif;"
                        onmouseover="this.style.borderColor='#c0392b';this.style.color='#c0392b'"
                        onmouseout="this.style.borderColor='var(--border-color)';this.style.color='var(--text-muted)'">
                        Cancelar
                    </button>
                `}
            </div>`;
            lista.appendChild(card);
        });

    } catch (e) {
        console.error('Erro ao carregar agendamentos:', e);
    }
}

// ── Cancelar ─────────────────────────────────────────────
document.addEventListener('click', async e => {
    const btn = e.target.closest('.btn-cancelar-agend');
    if (!btn) return;

    const id = btn.dataset.id;
    const card = btn.closest('.card-agend-aberto');
    const servico = card.querySelector('.agend-servico')?.textContent?.trim() || 'este agendamento';

    if (!confirm(`Cancelar ${servico}?`)) return;

    btn.textContent = 'Cancelando...';
    btn.disabled = true;

    try {
        const res = await fetch(`/cliente/cancelar/${id}/${TOKEN}`, { method: 'POST' });
        const json = await res.json();

        if (json.sucesso) {
            card.style.transition = 'opacity .3s, transform .3s';
            card.style.opacity = '0';
            card.style.transform = 'translateX(20px)';
            setTimeout(() => {
                card.remove();
                const lista = document.getElementById('lista-agendamentos-abertos');
                if (lista && !lista.querySelector('.card-agend-aberto')) {
                    lista.innerHTML = '<div style="font-size:12px;color:var(--text-muted);padding:8px 0;">Nenhum agendamento futuro.</div>';
                }
            }, 300);
            if (json.whatsappLink) {
          setTimeout(() => {
              window.open(json.whatsappLink, '_blank');
          }, 400);
      }
        } else {
            alert('⚠ ' + (json.erro || 'Erro ao cancelar.'));
            btn.textContent = 'Cancelar';
            btn.disabled = false;
        }
    } catch {
        alert('⚠ Erro de conexão.');
        btn.textContent = 'Cancelar';
        btn.disabled = false;
    }
});
// ── Reagendar ─────────────────────────────────────────────
let _reagendandoId = null;
let _reagendandoServicoid = null;
let _reagendandoProfId = null;
let _reagendandoDuracao  = null; 

document.addEventListener('click', e => {
    const btn = e.target.closest('.btn-reagendar-agend');
    if (!btn) return;

    _reagendandoId        = btn.dataset.id;
    _reagendandoProfId    = btn.dataset.profissionalId;
    _reagendandoServicoid = btn.dataset.servicoId;
    const hi = btn.dataset.horaInicio;
    const hf = btn.dataset.horaFim;
    if (hi && hf) {
        const toMin = t => { const [h,m] = t.substring(0,5).split(':').map(Number); return h*60+m; };
        _reagendandoDuracao = toMin(hf) - toMin(hi);
    } else {
        _reagendandoDuracao = null;
    }
    // Preenche info do modal
    document.getElementById('reagendar-info').textContent = 
        `✂️ ${btn.dataset.servico} · 👤 ${btn.dataset.barbeiro}`;
    document.getElementById('reagendar-data').value = '';
    document.getElementById('reagendar-horario').innerHTML = '<option value="">Selecione a data</option>';
    document.getElementById('reagendar-erro').textContent = '';

    // Define min date como amanhã
    const amanha = new Date();
    amanha.setDate(amanha.getDate() + 1);
    document.getElementById('reagendar-data').min = toDateStr(amanha);

    // Abre modal
    const overlay = document.getElementById('modal-reagendar-overlay');
    overlay.style.display = 'flex';
});

// Fecha modal
document.getElementById('btn-fechar-reagendar').addEventListener('click', () => {
    document.getElementById('modal-reagendar-overlay').style.display = 'none';
});
document.getElementById('modal-reagendar-overlay').addEventListener('click', e => {
    if (e.target === document.getElementById('modal-reagendar-overlay')) {
        document.getElementById('modal-reagendar-overlay').style.display = 'none';
    }
});

// Busca slots ao selecionar data
document.getElementById('reagendar-data').addEventListener('change', async function() {
    const data = this.value;
    const select = document.getElementById('reagendar-horario');
    select.innerHTML = '<option value="">Carregando...</option>';

    // ← confirma que os três chegam aqui
    console.log('[REAGENDAR SLOTS] profId:', _reagendandoProfId, 'servicoId:', _reagendandoServicoid, 'token:', TOKEN);
    if (!_reagendandoProfId || !_reagendandoServicoid) {
        select.innerHTML = '<option value="">Erro: profissional ou serviço não identificado</option>';
        return;
    }

    try {
        const url = `/slots?profissional_id=${_reagendandoProfId}&servico_id=${_reagendandoServicoid}`
          + `&data=${data}&token=${TOKEN}`
          + `${_reagendandoDuracao ? '&duracao=' + _reagendandoDuracao : ''}`;
        const res = await fetch(url);
        const json = await res.json();
        const slots = (json.slots || []).filter(s => s.status === 'disponivel');

        select.innerHTML = slots.length
            ? '<option value="">Selecione</option>'
            : '<option value="">Nenhum horário disponível</option>';

        slots.forEach(s => {
            const opt = document.createElement('option');
            opt.value = s.hora_inicio;
            opt.dataset.horaFim = s.hora_fim;
            opt.textContent = `${s.hora_inicio.substring(0,5)} – ${s.hora_fim.substring(0,5)}`;
            select.appendChild(opt);
        });
    } catch {
        select.innerHTML = '<option value="">Erro ao carregar</option>';
    }
});

// Confirmar reagendamento
document.getElementById('btn-confirmar-reagendar').addEventListener('click', async () => {
    const data = document.getElementById('reagendar-data').value;
    const select = document.getElementById('reagendar-horario');
    const opt = select.selectedOptions[0];
    const horaInicio = opt?.value;
    const horaFim = opt?.dataset.horaFim;
    const erro = document.getElementById('reagendar-erro');

    if (!data) { erro.textContent = '⚠ Selecione uma data.'; return; }
    if (!horaInicio) { erro.textContent = '⚠ Selecione um horário.'; return; }

    const btn = document.getElementById('btn-confirmar-reagendar');
    btn.textContent = 'Salvando...';
    btn.disabled = true;
    erro.textContent = '';

    try {
        const res = await fetch(`/cliente/reagendar/${_reagendandoId}/${TOKEN}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ data, hora_inicio: horaInicio, hora_fim: horaFim })
        });
        const json = await res.json();

        if (json.sucesso) {
            document.getElementById('modal-reagendar-overlay').style.display = 'none';
            await carregarAgendamentosCliente();

            // ── Abre WhatsApp se tiver link ──
            if (json.whatsappLink) {
                // Pequeno delay para o modal fechar antes de abrir o WhatsApp
                setTimeout(() => {
                    window.open(json.whatsappLink, '_blank');
                }, 400);
            }
        } else {
            erro.textContent = '⚠ ' + (json.erro || 'Erro ao reagendar.');
        }
    } catch {
        erro.textContent = '⚠ Erro de conexão.';
    } finally {
        btn.textContent = 'Confirmar';
        btn.disabled = false;
    }
});

