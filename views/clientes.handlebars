<style>
    :root {
        --gold: #b8860b;
        --gold-light: #d4a012;
        --gold-dim: #b8860b33;
        --bg: #090909;
        --bg2: #111111;
        --bg3: #181818;
        --border: #222222;
        --text: #e8e8e8;
        --muted: #555;
        --danger: #c0392b;
        --danger-dim: #c0392b22;
        --whatsapp: #25d366;
        --whatsapp-dim: #25d36622;
    }

    .clientes-wrap {
        padding: 36px 40px;
        min-height: calc(100vh - 130px);
        background: var(--bg);
    }

    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 32px;
    }

    .page-title {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 22px;
        letter-spacing: 4px;
        color: var(--text);
    }

    .btn-sair-pg {
        background: none;
        border: 1px solid var(--border);
        color: var(--muted);
        padding: 8px 20px;
        border-radius: 6px;
        font-family: 'DM Sans', sans-serif;
        font-size: 12px;
        letter-spacing: 1px;
        text-transform: uppercase;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .btn-sair-pg:hover {
        border-color: var(--danger);
        color: var(--danger);
    }

    .section-titulo {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 13px;
        letter-spacing: 4px;
        color: var(--muted);
        text-transform: uppercase;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* ══ RANKING BARBEIROS ══ */
    .ranking-wrap {
        margin-bottom: 40px;
    }

    .ranking-grid-barbeiros {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 10px;
    }

    .ranking-barb-card {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 16px;
        cursor: pointer;
        transition: border-color 0.2s, background 0.2s;
        position: relative;
        user-select: none;
    }

    .ranking-barb-card:hover {
        border-color: var(--gold);
        background: var(--bg3);
    }

    .ranking-barb-card.active {
        border-color: var(--gold);
        background: var(--gold-dim);
    }

    .ranking-barb-top {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
    }

    .ranking-barb-pos {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 22px;
        color: var(--muted);
        min-width: 28px;
        line-height: 1;
    }

    .ranking-barb-card.pos1 .ranking-barb-pos {
        color: var(--gold);
    }

    .ranking-barb-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, #333, #1a1a1a);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 14px;
        color: #888;
        flex-shrink: 0;
        border: 1px solid var(--border);
        transition: all 0.2s;
    }

    .ranking-barb-card.pos1 .ranking-barb-avatar {
        background: linear-gradient(135deg, var(--gold-light), #6b4c00);
        color: #fff;
        border-color: var(--gold);
    }

    .ranking-barb-nome {
        font-size: 13px;
        font-weight: 600;
        color: var(--text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        flex: 1;
    }

    .ranking-barb-stats {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6px;
    }

    .ranking-barb-stat {
        font-size: 10px;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .ranking-barb-stat span {
        display: block;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 16px;
        color: var(--gold);
        letter-spacing: 1px;
        line-height: 1.2;
    }

    .ranking-barb-card.pos1 .ranking-barb-stat span {
        color: var(--gold-light);
    }

    .ranking-barb-expand-hint {
        font-size: 9px;
        letter-spacing: 1px;
        color: var(--muted);
        text-align: right;
        margin-top: 10px;
        text-transform: uppercase;
        transition: color 0.2s;
    }

    .ranking-barb-card:hover .ranking-barb-expand-hint,
    .ranking-barb-card.active .ranking-barb-expand-hint {
        color: var(--gold);
    }

    .barb-expand-panel {
        display: none;
        background: var(--bg3);
        border: 1px solid var(--gold);
        border-radius: 10px;
        padding: 20px;
        margin-top: 10px;
        grid-column: 1 / -1;
        animation: fadeIn 0.2s ease;
    }

    .barb-expand-panel.open {
        display: block;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(-6px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .barb-expand-title {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 13px;
        letter-spacing: 3px;
        color: var(--gold);
        margin-bottom: 14px;
    }

    .barb-top-clientes {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 10px;
    }

    .barb-top-cli-card {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 12px;
        text-align: center;
    }

    .barb-top-cli-pos {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 11px;
        letter-spacing: 2px;
        color: var(--muted);
        margin-bottom: 6px;
    }

    .barb-top-cli-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--gold), #6b4c00);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 12px;
        color: #fff;
        margin: 0 auto 8px;
    }

    .barb-top-cli-nome {
        font-size: 11px;
        font-weight: 600;
        color: var(--text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-bottom: 4px;
    }

    .barb-top-cli-stat {
        font-size: 10px;
        color: var(--muted);
    }

    .barb-top-cli-stat span {
        color: var(--gold);
        font-weight: 600;
    }

    .barb-expand-empty {
        font-size: 12px;
        color: var(--muted);
        text-align: center;
        padding: 20px;
    }

    /* ══ TOP 5 CLIENTES ══ */
    .top-clientes-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 10px;
        margin-bottom: 40px;
    }

    .top-cliente-card {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 14px;
        text-align: center;
        transition: border-color 0.2s;
    }

    .top-cliente-card:hover {
        border-color: var(--gold);
    }

    .top-cliente-card.primeiro {
        background: var(--gold-dim);
        border-color: var(--gold);
    }

    .top-cliente-pos {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 11px;
        letter-spacing: 2px;
        color: var(--muted);
        margin-bottom: 8px;
    }

    .top-cliente-card.primeiro .top-cliente-pos {
        color: var(--gold);
    }

    .top-cliente-avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: linear-gradient(135deg, #333, #1a1a1a);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 14px;
        color: #888;
        margin: 0 auto 8px;
        border: 1px solid var(--border);
    }

    .top-cliente-card.primeiro .top-cliente-avatar {
        background: linear-gradient(135deg, var(--gold-light), #6b4c00);
        color: #fff;
        border-color: var(--gold);
    }

    .top-cliente-nome {
        font-size: 12px;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 5px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .top-cliente-stat {
        font-size: 10px;
        color: var(--muted);
        margin-bottom: 2px;
    }

    .top-cliente-stat span {
        color: var(--gold);
        font-weight: 600;
    }

    /* ══ TABELA CLIENTES ══ */
    .clientes-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 14px;
        gap: 16px;
        flex-wrap: wrap;
    }

    .clientes-search-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 8px 14px;
        transition: border-color 0.2s;
        min-width: 220px;
    }

    .clientes-search-wrap:focus-within {
        border-color: var(--gold);
    }

    .clientes-search-wrap svg {
        width: 14px;
        height: 14px;
        fill: var(--muted);
        flex-shrink: 0;
    }

    .clientes-search {
        background: none;
        border: none;
        outline: none;
        font-family: 'DM Sans', sans-serif;
        font-size: 12px;
        color: var(--text);
        width: 100%;
    }

    .clientes-search::placeholder {
        color: var(--muted);
    }

    .clientes-count {
        font-size: 11px;
        color: var(--muted);
        letter-spacing: 1px;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .clientes-table-wrap {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
    }

    .clientes-table {
        width: 100%;
        border-collapse: collapse;
    }

    .clientes-table th {
        background: var(--bg3);
        padding: 12px 16px;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 11px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--muted);
        text-align: left;
        border-bottom: 1px solid var(--border);
        white-space: nowrap;
    }

    .clientes-table td {
        padding: 13px 16px;
        font-size: 13px;
        color: var(--text);
        border-bottom: 1px solid var(--border);
        vertical-align: middle;
    }

    .clientes-table tr:last-child td {
        border-bottom: none;
    }

    .clientes-table tbody tr {
        transition: background 0.15s;
    }

    .clientes-table tbody tr:hover td {
        background: var(--bg3);
    }

    .clientes-table tbody tr.hidden {
        display: none;
    }

    .td-nome-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .td-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--gold), #6b4c00);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 12px;
        color: #fff;
        flex-shrink: 0;
    }

    .td-total {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 22px;
        color: var(--gold);
        line-height: 1;
    }

    .td-valor {
        font-size: 13px;
        font-weight: 500;
    }

    .td-muted {
        color: var(--muted);
        font-size: 12px;
    }

    .td-badge {
        font-size: 10px;
        letter-spacing: 1px;
        text-transform: uppercase;
        background: var(--bg3);
        border: 1px solid var(--border);
        color: var(--muted);
        padding: 2px 8px;
        border-radius: 10px;
        white-space: nowrap;
    }

    .btn-cli-edit {
        background: none;
        border: 1px solid var(--border);
        color: var(--muted);
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 11px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-cli-edit:hover {
        border-color: var(--gold);
        color: var(--gold);
    }

    .btn-cli-historico {
        background: none;
        border: 1px solid var(--border);
        color: var(--muted);
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 11px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-cli-historico:hover {
        border-color: var(--gold);
        color: var(--gold);
    }

    /* ══ NOVO: BOTÃO WHATSAPP ══ */
    .btn-cli-whatsapp {
        background: none;
        border: 1px solid var(--border);
        color: var(--muted);
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 11px;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 3px;
    }

    .btn-cli-whatsapp:hover {
        border-color: var(--whatsapp);
        color: var(--whatsapp);
        background: var(--whatsapp-dim);
    }

    .no-results {
        text-align: center;
        padding: 40px;
        color: var(--muted);
        font-size: 13px;
        display: none;
    }

    .clientes-empty {
        text-align: center;
        padding: 80px 20px;
        color: var(--muted);
    }

    .clientes-empty-icon {
        font-size: 40px;
        margin-bottom: 12px;
        opacity: 0.3;
    }

    .clientes-empty p {
        font-size: 13px;
    }

    /* ══ MODAL EDIÇÃO CLIENTE ══ */
    .modal-cli-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: #000000cc;
        backdrop-filter: blur(4px);
        z-index: 300;
        align-items: center;
        justify-content: center;
    }

    .modal-cli-overlay.open {
        display: flex;
    }

    .modal-cli {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 28px;
        width: 100%;
        max-width: 380px;
        position: relative;
        transform: translateY(16px);
        transition: transform 0.25s;
    }

    .modal-cli-overlay.open .modal-cli {
        transform: translateY(0);
    }

    .modal-cli-close {
        position: absolute;
        top: 14px;
        right: 14px;
        background: none;
        border: none;
        color: var(--muted);
        font-size: 18px;
        cursor: pointer;
        transition: color 0.2s;
    }

    .modal-cli-close:hover {
        color: var(--text);
    }

    .modal-cli-title {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 22px;
        letter-spacing: 2px;
        color: var(--text);
        margin-bottom: 4px;
    }

    .modal-cli-sub {
        font-size: 12px;
        color: var(--muted);
        margin-bottom: 20px;
    }

    .modal-cli-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-bottom: 12px;
    }

    .modal-cli-field label {
        font-size: 10px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--muted);
    }

    .modal-cli-field input {
        width: 100%;
        background: var(--bg3);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 10px 12px;
        font-family: 'DM Sans', sans-serif;
        font-size: 13px;
        color: var(--text);
        outline: none;
        transition: border-color 0.2s;
    }

    .modal-cli-field input:focus {
        border-color: var(--gold);
    }

    .modal-cli-erro {
        font-size: 12px;
        color: var(--danger);
        min-height: 16px;
        margin-top: 6px;
    }

    .modal-cli-actions {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }

    .btn-cli-cancelar {
        flex: 1;
        background: none;
        border: 1px solid var(--border);
        color: var(--muted);
        padding: 10px;
        border-radius: 8px;
        font-family: 'DM Sans', sans-serif;
        font-size: 13px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-cli-cancelar:hover {
        border-color: var(--danger);
        color: var(--danger);
    }

    .btn-cli-salvar {
        flex: 2;
        background: var(--gold);
        border: none;
        color: #000;
        padding: 10px;
        border-radius: 8px;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 16px;
        letter-spacing: 2px;
        cursor: pointer;
        transition: background 0.2s;
    }

    .btn-cli-salvar:hover {
        background: var(--gold-light);
    }

    .btn-cli-salvar:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    /* ══ MOBILE ══ */
    @media (max-width: 900px) {
        .clientes-wrap { padding: 16px; }
        .ranking-grid-barbeiros { grid-template-columns: repeat(2, 1fr); }
        .barb-top-clientes { grid-template-columns: repeat(2, 1fr); }
        .top-clientes-grid { grid-template-columns: repeat(2, 1fr); }
        .clientes-table th:nth-child(5),
        .clientes-table td:nth-child(5),
        .clientes-table th:nth-child(6),
        .clientes-table td:nth-child(6) { display: none; }
    }

    @media (max-width: 600px) {
        .ranking-grid-barbeiros { grid-template-columns: 1fr 1fr; }
        .clientes-table th:nth-child(4),
        .clientes-table td:nth-child(4) { display: none; }
        .top-clientes-grid { grid-template-columns: repeat(2, 1fr); }
        .barb-top-clientes { grid-template-columns: repeat(2, 1fr); }
    }
</style>

<div class="clientes-wrap">

    <div class="page-header">
        <div class="page-title">Clientes </div>
        <a href="/admin" class="btn-sair-pg">← Voltar</a>
    </div>

    {{!-- RANKING BARBEIROS --}}
    <div class="ranking-wrap">
        <div class="section-titulo">✂️ Ranking </div>

        {{#if rankingBarbeiros.length}}
        <div class="ranking-grid-barbeiros" id="ranking-barbeiros-grid">

            {{#each rankingBarbeiros}}
            <div class="ranking-barb-card {{#if (eq @index 0)}}pos1{{/if}}" data-id="{{id}}"
                data-clientes='{{json topClientes}}' onclick="toggleBarbeiro(this)">
                <div class="ranking-barb-top">
                    <div class="ranking-barb-pos">#{{add @index 1}}</div>
                    <div class="ranking-barb-avatar">{{substr nome 0 2}}</div>
                    <div class="ranking-barb-nome">{{nome}}</div>
                </div>
                <div class="ranking-barb-stats">
                    <div class="ranking-barb-stat">Atendimentos<span>{{total}}</span></div>
                    <div class="ranking-barb-stat">Faturamento<span>R$ {{faturamento}}</span></div>
                    <div class="ranking-barb-stat">Serviço Top<span>{{servicoTop}}</span></div>
                    {{#if ultimoAtendimento}}
                    <div class="ranking-barb-stat">Último<span>{{ultimoAtendimento}}</span></div>
                    {{/if}}
                </div>
                <div class="ranking-barb-expand-hint">ver clientes ▾</div>
            </div>
            {{/each}}

            <div class="barb-expand-panel" id="barb-expand-panel">
                <div class="barb-expand-title" id="barb-expand-title">Top Clientes</div>
                <div class="barb-top-clientes" id="barb-top-clientes"></div>
                <div class="barb-expand-empty" id="barb-expand-empty" style="display:none">Nenhum cliente encontrado.</div>
            </div>

        </div>
        {{else}}
        <div class="clientes-empty">
            <div class="clientes-empty-icon">✂️</div>
            <p>Nenhum atendente cadastrado.</p>
        </div>
        {{/if}}
    </div>

    {{!-- TOP 5 CLIENTES --}}
    {{#if topClientes.length}}
    <div class="section-titulo">🏆 Top Clientes</div>
    <div class="top-clientes-grid">
        {{#each topClientes}}
        <div class="top-cliente-card {{#if (eq @index 0)}}primeiro{{/if}}">
            <div class="top-cliente-pos">#{{add @index 1}}</div>
            <div class="top-cliente-avatar">{{substr nome 0 2}}</div>
            <div class="top-cliente-nome">{{nome}}</div>
            <div class="top-cliente-stat">Agend: <span>{{total}}</span></div>
            <div class="top-cliente-stat">Gasto: <span>R$ {{valorTotal}}</span></div>
            <div class="top-cliente-stat">Fav: <span>{{servicoFavorito}}</span></div>
        </div>
        {{/each}}
    </div>
    {{/if}}

    {{!-- LISTA COMPLETA --}}
    <div class="clientes-header">
        <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
            <div class="section-titulo" style="margin-bottom:0">👥 Todos os Clientes</div>

            <button id="btn-aniversarios" style="
                background:none;border:1px solid var(--border);color:var(--muted);
                padding:6px 14px;border-radius:6px;font-size:11px;letter-spacing:1px;
                text-transform:uppercase;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:6px;"
                onmouseover="this.style.borderColor='var(--gold)';this.style.color='var(--gold)'"
                onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--muted)'">
                🎂 Aniversários
            </button>

            <!-- ══ NOVO: Inativos ══ -->
            <button id="btn-inativos" style="
                background:none;border:1px solid var(--border);color:var(--muted);
                padding:6px 14px;border-radius:6px;font-size:11px;letter-spacing:1px;
                text-transform:uppercase;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:6px;"
                onmouseover="this.style.borderColor='var(--danger)';this.style.color='var(--danger)'"
                onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--muted)'">
                😴 Inativos
            </button>
            <!-- ══ NOVO: Nunca Agendaram ══ -->
            <button id="btn-nunca-agendou" style="
                background:none;border:1px solid var(--border);color:var(--muted);
                padding:6px 14px;border-radius:6px;font-size:11px;letter-spacing:1px;
                text-transform:uppercase;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:6px;"
                onmouseover="this.style.borderColor='var(--muted)';this.style.color='var(--text)'"
                onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--muted)'"
                onclick="filtrarNuncaAgendou()">
                👻 Nunca Agendaram
            </button>
            <button id="btn-novo-cliente" style="
                background:var(--gold);border:none;color:#000;
                padding:6px 14px;border-radius:6px;font-size:11px;letter-spacing:1px;
                text-transform:uppercase;cursor:pointer;transition:opacity .2s;font-family:'DM Sans',sans-serif;font-weight:600;">
                + Incluir Cliente
            </button>
        </div>
        <div class="clientes-search-wrap">
            <svg viewBox="0 0 20 20"><path d="M13.5 12.5l4 4M8.5 14a5.5 5.5 0 100-11 5.5 5.5 0 000 11z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>
            <input class="clientes-search" id="clientes-search" placeholder="Buscar por nome ou telefone..." />
        </div>
    </div>

    {{#if clientes.length}}
    <div class="clientes-table-wrap">
        <table class="clientes-table" id="clientes-table">
            <thead>
                <tr>
                    <th>Cliente</th>
                    <th>Telefone</th>
                    <th>Agendamentos</th>
                    <th>Nascimento</th>
                    <th>Último Agendamento</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="clientes-tbody">
                {{#each clientes}}
                {{!--
                    IMPORTANTE: data-ultimo deve conter a data ISO do último agendamento (YYYY-MM-DD).
                    Deixe vazio caso o cliente nunca tenha agendado. Ex: data-ultimo="2024-11-10"
                --}}
                <tr data-id="{{id}}" data-nome="{{nome}}" data-telefone="{{telefone}}" data-obs="{{observacao}}"
                    data-nascimento="{{nascimento}}" data-ultimo="{{ultimoAgendamentoISO}}" data-arquivado="0">
                    <td>
                        <div class="td-nome-wrap">
                            <div class="td-avatar">{{substr nome 0 2}}</div>
                            <span id="cli-nome-{{id}}">{{nome}}</span>
                        </div>
                    </td>
                    <td class="td-muted" id="cli-tel-{{id}}">{{telefone}}</td>
                    <td><span class="td-total">{{total}}</span></td>
                    <td class="td-muted">{{#if nascimento}}{{nascimento}}{{else}}—{{/if}}</td>
                    <td class="td-muted">{{ultimoAgendamento}}</td>
                    <td style="display:flex;gap:6px;align-items:center;">
                        <button class="btn-cli-edit" data-id="{{id}}" data-nome="{{nome}}" data-tel="{{telefone}}"
                            data-obs="{{observacao}}" data-nascimento="{{nascimento}}" title="Editar">✎</button>
                        <button class="btn-cli-historico" data-id="{{id}}" data-nome="{{nome}}" data-tel="{{telefone}}"
                            title="Histórico">📋</button>
                        <!-- ══ NOVO: WhatsApp ══ -->
                        <a class="btn-cli-whatsapp"
                            href="https://wa.me/55{{sanitizeTel telefone}}"
                            target="_blank" rel="noopener noreferrer"
                            title="Abrir WhatsApp">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                            </svg>
                            WA
                        </a>
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
        <div class="no-results" id="no-results">Nenhum cliente encontrado para "<span id="search-term"></span>"</div>
    </div>
    {{else}}
    <div class="clientes-empty">
        <div class="clientes-empty-icon">👥</div>
        <p>Nenhum cliente cadastrado ainda.</p>
    </div>
    {{/if}}

</div>

