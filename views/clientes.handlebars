    }
    // ── Modal novo cliente ──────────────────────────────
    const novoCliOverlay = document.getElementById('modal-novo-cli-overlay');

    document.getElementById('btn-novo-cliente').addEventListener('click', () => {
        document.getElementById('novo-cli-nome').value = '';
        document.getElementById('novo-cli-tel').value = '';
        document.getElementById('novo-cli-nascimento').value = '';
        document.getElementById('novo-cli-obs').value = '';
        document.getElementById('novo-cli-erro').textContent = '';
        novoCliOverlay.classList.add('open');
    });

    function fecharNovoCliModal() { novoCliOverlay.classList.remove('open'); }

    document.getElementById('modal-novo-cli-close').addEventListener('click', fecharNovoCliModal);
    document.getElementById('btn-novo-cli-cancelar').addEventListener('click', fecharNovoCliModal);
    novoCliOverlay.addEventListener('click', e => { if (e.target === novoCliOverlay) fecharNovoCliModal(); });

    document.getElementById('btn-novo-cli-salvar').addEventListener('click', async () => {
        const nome = document.getElementById('novo-cli-nome').value.trim();
        const tel = document.getElementById('novo-cli-tel').value.trim();
        const nascimento = document.getElementById('novo-cli-nascimento').value;
        const obs = document.getElementById('novo-cli-obs').value.trim();
        const erro = document.getElementById('novo-cli-erro');
        const btn = document.getElementById('btn-novo-cli-salvar');

        if (!nome || !tel) { erro.textContent = '⚠ Nome e telefone são obrigatórios.'; return; }

        btn.textContent = 'Salvando...';
        btn.disabled = true;
        erro.textContent = '';

        try {
            const res = await fetch('/clientes', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ nome, telefone: tel, nascimento: fmtDataBack(nascimento), observacao: obs || null })
            });
            const json = await res.json();

            if (json.sucesso) {
                fecharNovoCliModal();
                const tbody = document.getElementById('clientes-tbody');
                if (tbody) {
                    const telLimpo = sanitizeTelJS(json.cliente.telefone);
                    const tr = document.createElement('tr');
                    tr.dataset.id = json.cliente.id;
                    tr.dataset.nome = json.cliente.nome;
                    tr.dataset.telefone = json.cliente.telefone;
                    tr.dataset.obs = obs;
                    tr.dataset.nascimento = nascimento;
                    tr.dataset.ultimo = '';
                    tr.innerHTML = `
                        <td>
                            <div class="td-nome-wrap">
                                <div class="td-avatar">${json.cliente.nome.substring(0,2).toUpperCase()}</div>
                                <span id="cli-nome-${json.cliente.id}">${json.cliente.nome}</span>
                            </div>
                        </td>
                        <td class="td-muted" id="cli-tel-${json.cliente.id}">${json.cliente.telefone}</td>
                        <td><span class="td-total">0</span></td>
                        <td class="td-muted">${nascimento || '—'}</td>
                        <td class="td-muted">—</td>
                        <td style="display:flex;gap:6px;align-items:center;">
                            <button class="btn-cli-edit" data-id="${json.cliente.id}" data-nome="${json.cliente.nome}"
                                data-tel="${json.cliente.telefone}" data-obs="${obs}" data-nascimento="${nascimento}" title="Editar">✎</button>
                            <button class="btn-cli-historico" data-id="${json.cliente.id}" data-nome="${json.cliente.nome}"
                                data-tel="${json.cliente.telefone}" title="Histórico">📋</button>
                            <a class="btn-cli-whatsapp"
                                href="https://wa.me/55${telLimpo}"
                                target="_blank" rel="noopener noreferrer" title="Abrir WhatsApp">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                                WA
                            </a>
                        </td>`;
                    tbody.prepend(tr);
                }
            } else {
                erro.textContent = '⚠ ' + (json.erro || 'Erro ao cadastrar.');
            }
        } catch {
            erro.textContent = '⚠ Erro de conexão.';
        } finally {
            btn.textContent = 'Cadastrar';
            btn.disabled = false;
        }
    });

    // ── Máscara de data DD/MM/AAAA ──
    function mascaraData(input) {
        input.addEventListener('input', function () {
            let v = this.value.replace(/\D/g, '').substring(0, 8);
            if (v.length >= 5) v = v.slice(0,2) + '/' + v.slice(2,4) + '/' + v.slice(4);
            else if (v.length >= 3) v = v.slice(0,2) + '/' + v.slice(2);
            this.value = v;
        });
    }
    mascaraData(document.getElementById('novo-cli-nascimento'));
    mascaraData(document.getElementById('cli-edit-nascimento'));
</script>

