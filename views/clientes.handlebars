                </div>
                <div id="drawer-tel" style="font-size:12px;color:var(--muted);margin-top:2px;"></div>
            </div>
            <div style="display:flex;align-items:center;gap:8px;">
                <!-- WhatsApp — sempre visível, útil no mobile -->
                <a id="drawer-wa-btn" href="#" target="_blank" rel="noopener noreferrer"
                    style="display:inline-flex;align-items:center;gap:5px;background:none;border:1px solid var(--whatsapp);color:var(--whatsapp);padding:6px 12px;border-radius:8px;font-size:11px;font-family:'DM Sans',sans-serif;font-weight:600;text-decoration:none;white-space:nowrap;transition:all .2s;letter-spacing:.5px;"
                    onmouseover="this.style.background='var(--whatsapp-dim)'"
                    onmouseout="this.style.background='none'">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    WA
                </a>
                <button onclick="fecharDrawer()"
                    style="background:none;border:1px solid var(--border);color:var(--muted);width:32px;height:32px;border-radius:8px;cursor:pointer;font-size:16px;transition:all .2s;"
                    onmouseover="this.style.borderColor='var(--danger)';this.style.color='var(--danger)'"
                    onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--muted)'">✕</button>
            </div>
        </div>

        <div id="drawer-obs-wrap"
            style="display:none;background:var(--bg3);border:1px solid var(--gold-dim);border-radius:8px;padding:10px 14px;margin-bottom:16px;">
            <div style="font-size:9px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;margin-bottom:4px;">
                📌 Observação do cliente</div>
            <div id="drawer-obs" style="font-size:13px;color:var(--text);"></div>
        </div>

        <!-- Banner "nunca agendou" com botão arquivar -->
        <div id="drawer-nunca-wrap" style="display:none;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px 14px;margin-bottom:16px;display:none;align-items:center;justify-content:space-between;gap:10px;">
            <div style="font-size:12px;color:var(--muted);">😶 Nunca realizou um agendamento</div>
