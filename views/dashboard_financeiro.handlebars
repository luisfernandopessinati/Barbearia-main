<style>
    @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap');

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
        --gold: #c9950f; --gold-light: #dba813; --gold-dim: #c9950f33;
        --bg: #090909; --bg2: #111111; --bg3: #1c1c1c;
        --border: #2e2e2e; --text: #f0f0f0; --muted: #8a8a8a;
        --danger: #e74c3c; --danger-dim: #e74c3c22;
        --green: #27ae60; --green-dim: #27ae6022;
        --red: #e74c3c; --red-dim: #e74c3c22;
        --blue: #3b82f6;
    }

    body { background: var(--bg); font-family: 'DM Sans', sans-serif; color: var(--text); min-height: 100vh; }

    /* ── Header ── */
    .dash-header { display: flex; align-items: center; justify-content: space-between; padding: 20px 40px; border-bottom: 1px solid var(--border); background: var(--bg2); position: sticky; top: 0; z-index: 100; }
    .dash-header-left { display: flex; align-items: center; gap: 20px; }
    .dash-back { color: var(--muted); text-decoration: none; font-size: 18px; transition: color 0.2s; }
    .dash-back:hover { color: var(--gold); }
    .dash-logo { font-family: 'Bebas Neue', sans-serif; font-size: 20px; letter-spacing: 3px; color: var(--gold); text-decoration: none; }
    .dash-header-center { font-family: 'Bebas Neue', sans-serif; font-size: 13px; letter-spacing: 4px; color: var(--text); text-transform: uppercase; }

    /* ── Body ── */
    .dash-body { padding: 36px 40px; max-width: 1400px; margin: 0 auto; }

    /* ── Período ── */
    .periodo-bar { display: flex; align-items: center; gap: 12px; margin-bottom: 32px; flex-wrap: wrap; }
    .periodo-bar label { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); }
    .periodo-bar input[type="date"] { background: var(--bg2); border: 1px solid var(--border); border-radius: 8px; padding: 9px 14px; font-family: 'DM Sans', sans-serif; font-size: 13px; color: var(--text); outline: none; transition: border-color 0.2s; }
    .periodo-bar input[type="date"]:focus { border-color: var(--gold); }
    .btn-filtrar { background: var(--gold); border: none; color: #000; padding: 9px 24px; border-radius: 8px; font-family: 'Bebas Neue', sans-serif; font-size: 18px; letter-spacing: 2px; cursor: pointer; transition: background 0.2s; }
    .btn-filtrar:hover { background: var(--gold-light); }
    .periodo-sep { width: 1px; height: 28px; background: var(--border); }
    .btn-periodo { background: var(--bg2); border: 1px solid var(--border); color: var(--muted); padding: 8px 16px; border-radius: 8px; font-family: 'DM Sans', sans-serif; font-size: 12px; letter-spacing: 1px; cursor: pointer; transition: all 0.2s; text-transform: uppercase; }
    .btn-periodo:hover, .btn-periodo.active { border-color: var(--gold); color: var(--gold); }

    /* ── KPIs ── */
    .kpis { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; margin-bottom: 32px; }
    .kpi-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; padding: 20px 24px; position: relative; overflow: hidden; transition: border-color 0.2s; }
    .kpi-card:hover { border-color: #3a3a3a; }
    .kpi-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: var(--gold); opacity: 0.4; }
    .kpi-card.c-green::before  { background: var(--green); opacity: 1; }
    .kpi-card.c-red::before    { background: var(--red); opacity: 1; }
    .kpi-card.c-gold::before   { background: var(--gold); opacity: 1; }
    .kpi-card.c-blue::before   { background: var(--blue); opacity: 1; }
    .kpi-label { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); margin-bottom: 8px; }
    .kpi-value { font-family: 'Bebas Neue', sans-serif; font-size: 32px; color: var(--text); line-height: 1; margin-bottom: 4px; }
    .kpi-value.gold  { color: var(--gold); }
    .kpi-value.green { color: var(--green); }
    .kpi-value.red   { color: var(--red); }
    .kpi-value.blue  { color: var(--blue); }
    .kpi-sub { font-size: 11px; color: var(--muted); }

    /* ── Resultado badge ── */
    .resultado-badge { display: inline-flex; align-items: center; gap: 6px; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 500; margin-top: 6px; }
    .resultado-badge.lucro   { background: var(--green-dim); color: var(--green); }
    .resultado-badge.prejuizo { background: var(--red-dim); color: var(--red); }

    /* ── Grid gráficos ── */
    .charts-grid { display: grid; grid-template-columns: 1fr; gap: 24px; }
    .charts-row  { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }

    .chart-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; padding: 28px; }
    .chart-card-header { display: flex; align-items: baseline; gap: 12px; margin-bottom: 24px; }
    .chart-card-title { font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 1px; color: var(--text); }
    .chart-card-sub { font-size: 11px; color: var(--muted); }

    .chart-wrap { position: relative; width: 100%; }
    .chart-wrap.line  { height: 300px; }
    .chart-wrap.bar   { height: 320px; }
    .chart-wrap.hbar  { height: 280px; }

    /* ── Tabela despesas ── */
    .desp-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .desp-table th { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); padding: 0 12px 12px; text-align: left; border-bottom: 1px solid var(--border); }
    .desp-table td { padding: 12px; border-bottom: 1px solid #1a1a1a; color: var(--text); }
    .desp-table tr:last-child td { border-bottom: none; }
    .desp-table tr:hover td { background: #161616; }
    .desp-tag { display: inline-flex; align-items: center; padding: 2px 8px; border-radius: 4px; font-size: 10px; letter-spacing: 1px; text-transform: uppercase; background: var(--bg3); color: var(--muted); border: 1px solid var(--border); }
    .desp-valor { font-weight: 500; color: var(--red); }
    .desp-total-row td { font-weight: 600; color: var(--red); border-top: 1px solid var(--border); padding-top: 14px; }

    /* ── Margem barra ── */
    .margem-bar-wrap { margin-top: 8px; }
    .margem-bar-track { height: 6px; background: var(--bg3); border-radius: 4px; overflow: hidden; margin-top: 6px; }
    .margem-bar-fill { height: 100%; border-radius: 4px; transition: width 0.6s ease; }

    /* Loading / erro */
    .dash-loading { display: flex; align-items: center; justify-content: center; padding: 80px; color: var(--muted); gap: 12px; font-size: 13px; }
    .dash-loading::before { content: ''; width: 20px; height: 20px; border: 2px solid var(--border); border-top-color: var(--gold); border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .dash-erro { text-align: center; padding: 80px; color: var(--danger); font-size: 13px; }

    @media (max-width: 1100px) { .kpis { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 900px) {
        .dash-body { padding: 20px 16px; }
        .dash-header { padding: 14px 16px; }
        .dash-header-center { display: none; }
        .kpis { grid-template-columns: 1fr 1fr; gap: 10px; }
        .kpi-value { font-size: 26px; }
        .charts-row { grid-template-columns: 1fr; }
    }
    @media (max-width: 500px) { .kpis { grid-template-columns: 1fr 1fr; } }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<div class="dash-header">
    <div class="dash-header-left">
        <a href="/admin" class="dash-back"><i class="fa-solid fa-arrow-left"></i></a>
        <a href="/" class="dash-logo">Barbearia</a>
    </div>
    <div class="dash-header-center">Análise Financeira</div>
</div>

<div class="dash-body">

    <!-- Período -->
    <div class="periodo-bar">
        <label>De</label>
        <input type="date" id="input-inicio">
        <label>Até</label>
        <input type="date" id="input-fim">
        <button class="btn-filtrar" id="btn-filtrar">Filtrar</button>
        <div class="periodo-sep"></div>
        <button class="btn-periodo" data-dias="7">7 dias</button>
        <button class="btn-periodo active" data-dias="30">30 dias</button>
        <button class="btn-periodo" data-dias="90">90 dias</button>
    </div>

    <!-- KPIs -->
    <div class="kpis" id="kpis">
        <div class="dash-loading" style="grid-column:1/-1"></div>
    </div>

    <!-- Gráficos -->
    <div class="charts-grid" id="charts-grid">
        <div class="dash-loading"></div>
    </div>

</div>

<script>
(function () {

    let chartLinha  = null;
    let chartBarras = null;
    let chartDesp   = null;

    function hoje() { return new Date().toISOString().split('T')[0]; }
    function diasAtras(n) {
        const d = new Date();
        d.setDate(d.getDate() - n);
        return d.toISOString().split('T')[0];
    }

    const inputInicio = document.getElementById('input-inicio');
    const inputFim    = document.getElementById('input-fim');
    inputInicio.value = diasAtras(30);
    inputFim.value    = hoje();

    document.querySelectorAll('.btn-periodo').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.btn-periodo').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            inputInicio.value = diasAtras(parseInt(btn.dataset.dias));
            inputFim.value    = hoje();
            carregar();
        });
    });

    document.getElementById('btn-filtrar').addEventListener('click', () => {
        document.querySelectorAll('.btn-periodo').forEach(b => b.classList.remove('active'));
        carregar();
    });

    function fmtBRL(v) {
        return parseFloat(v || 0).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
    }
    function fmtPct(v) {
        return parseFloat(v || 0).toLocaleString('pt-BR', { minimumFractionDigits: 1, maximumFractionDigits: 1 }) + '%';
    }

    /* ── Carregar ─────────────────────────────────────── */
    async function carregar() {
        const inicio = inputInicio.value;
        const fim    = inputFim.value;

        document.getElementById('kpis').innerHTML        = '<div class="dash-loading" style="grid-column:1/-1"></div>';
        document.getElementById('charts-grid').innerHTML = '<div class="dash-loading"></div>';

        try {
            /*
             * Faz três fetches em paralelo:
             *   1. /admin/dashboard/vendas/dados    → vendas de produtos
             *   2. /admin/dashboard/dados           → agendamentos/serviços
             *   3. /admin/dashboard/despesas/dados  → despesas lançadas
             *
             * Se a sua rota de despesas tiver outro caminho, ajuste abaixo.
             */
            const [resVendas, resServicos, resDespesas] = await Promise.all([
                fetch(`/admin/dashboard/vendas/dados?inicio=${inicio}&fim=${fim}`),
                fetch(`/admin/dashboard/dados?inicio=${inicio}&fim=${fim}`),
                fetch(`/admin/dashboard/despesas/dados?inicio=${inicio}&fim=${fim}`)
            ]);

            const [vendas, servicos, despesas] = await Promise.all([
                resVendas.json(),
                resServicos.json(),
                resDespesas.json()
            ]);

            if (!resVendas.ok)    throw new Error(vendas.erro    || 'Erro vendas');
            if (!resServicos.ok)  throw new Error(servicos.erro  || 'Erro serviços');
            if (!resDespesas.ok)  throw new Error(despesas.erro  || 'Erro despesas');

            const dados = consolidar(vendas, servicos, despesas);
            renderKPIs(dados);
            renderGraficos(dados, despesas);

        } catch (e) {
            document.getElementById('kpis').innerHTML        = `<div class="dash-erro" style="grid-column:1/-1">⚠ ${e.message}</div>`;
            document.getElementById('charts-grid').innerHTML = '';
        }
    }

    /* ── Consolidar dados das 3 fontes ────────────────── */
    function consolidar(vendas, servicos, despesas) {
        const receitaVendas    = parseFloat(vendas.kpis?.faturamentoTotal   || 0);
        const receitaServicos  = parseFloat(servicos.kpis?.faturamentoTotal || 0);
        const receitaBruta     = receitaVendas + receitaServicos;

        /*
         * Esperado de /admin/dashboard/despesas/dados:
         * {
         *   totalDespesas: 1200.00,
         *   categorias: { "Aluguel": 600, "Produtos": 300, ... },
         *   evolucao: { "2025-01-01": 150, "2025-01-02": 0, ... },
         *   lista: [ { descricao, categoria, valor, data }, ... ]
         * }
         */
        const totalDespesas = parseFloat(despesas.totalDespesas || 0);
        const lucroLiquido  = receitaBruta - totalDespesas;
        const margem        = receitaBruta > 0 ? (lucroLiquido / receitaBruta) * 100 : 0;

        /* Evolução diária unificada */
        const todasDatas = new Set([
            ...Object.keys(vendas.evolucao    || {}),
            ...Object.keys(servicos.evolucao  || {}),
            ...Object.keys(despesas.evolucao  || {})
        ]);

        const evolucao = {};
        todasDatas.forEach(d => {
            const rv = parseFloat(vendas.evolucao?.[d]?.faturamento   || vendas.evolucao?.[d]   || 0);
            const rs = parseFloat(servicos.evolucao?.[d]?.faturamento || servicos.evolucao?.[d] || 0);
            const de = parseFloat(despesas.evolucao?.[d] || 0);
            evolucao[d] = { receita: rv + rs, despesa: de };
        });

        return { receitaVendas, receitaServicos, receitaBruta, totalDespesas, lucroLiquido, margem, evolucao };
    }

    /* ── KPIs ─────────────────────────────────────────── */
    function renderKPIs(d) {
        const isLucro = d.lucroLiquido >= 0;
        const badge   = isLucro
            ? `<span class="resultado-badge lucro">▲ Lucro</span>`
            : `<span class="resultado-badge prejuizo">▼ Prejuízo</span>`;

        const margemCor   = d.margem >= 0 ? 'var(--green)' : 'var(--red)';
        const margemFill  = Math.min(Math.abs(d.margem), 100);

        document.getElementById('kpis').innerHTML = `
            <div class="kpi-card c-green">
                <div class="kpi-label">Receita Bruta</div>
                <div class="kpi-value green">${fmtBRL(d.receitaBruta)}</div>
                <div class="kpi-sub">vendas + serviços</div>
            </div>
            <div class="kpi-card c-gold">
                <div class="kpi-label">Vendas de Produtos</div>
                <div class="kpi-value gold">${fmtBRL(d.receitaVendas)}</div>
                <div class="kpi-sub">do dashboard de vendas</div>
            </div>
            <div class="kpi-card c-blue">
                <div class="kpi-label">Receita de Serviços</div>
                <div class="kpi-value blue">${fmtBRL(d.receitaServicos)}</div>
                <div class="kpi-sub">do dashboard de serviços</div>
            </div>
            <div class="kpi-card c-red">
                <div class="kpi-label">Despesas</div>
                <div class="kpi-value red">${fmtBRL(d.totalDespesas)}</div>
                <div class="kpi-sub">lançadas no período</div>
            </div>
            <div class="kpi-card ${isLucro ? 'c-green' : 'c-red'}">
                <div class="kpi-label">Resultado</div>
                <div class="kpi-value ${isLucro ? 'green' : 'red'}">${fmtBRL(Math.abs(d.lucroLiquido))}</div>
                ${badge}
                <div class="margem-bar-wrap">
                    <div style="font-size:10px;color:var(--muted);margin-top:8px;">Margem: ${fmtPct(d.margem)}</div>
                    <div class="margem-bar-track">
                        <div class="margem-bar-fill" style="width:${margemFill}%;background:${margemCor}"></div>
                    </div>
                </div>
            </div>`;
    }

    /* ── Gráficos ─────────────────────────────────────── */
    function renderGraficos(dados, despesas) {
        const grid = document.getElementById('charts-grid');
        grid.innerHTML = '';

        const dias = Object.keys(dados.evolucao).sort();

        /* ── 1. Linha: Receita vs Despesa por dia ── */
        const lineCard = document.createElement('div');
        lineCard.className = 'chart-card';
        lineCard.innerHTML = `
            <div class="chart-card-header">
                <span class="chart-card-title">Receita vs Despesa</span>
                <span class="chart-card-sub">evolução diária no período</span>
            </div>
            <div class="chart-wrap line"><canvas id="chart-linha"></canvas></div>`;
        grid.appendChild(lineCard);

        if (chartLinha) chartLinha.destroy();
        chartLinha = new Chart(document.getElementById('chart-linha').getContext('2d'), {
            type: 'line',
            data: {
                labels: dias.map(d => { const [,m,dia] = d.split('-'); return `${dia}/${m}`; }),
                datasets: [
                    {
                        label: 'Receita (R$)',
                        data: dias.map(d => dados.evolucao[d].receita),
                        borderColor: '#27ae60',
                        backgroundColor: '#27ae6018',
                        borderWidth: 2, pointRadius: 3, pointHoverRadius: 5,
                        tension: 0.4, fill: true
                    },
                    {
                        label: 'Despesas (R$)',
                        data: dias.map(d => dados.evolucao[d].despesa),
                        borderColor: '#e74c3c',
                        backgroundColor: '#e74c3c18',
                        borderWidth: 2, pointRadius: 3, pointHoverRadius: 5,
                        tension: 0.4, fill: true
                    }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: { labels: { color: '#8a8a8a', font: { family: 'DM Sans', size: 12 }, boxWidth: 12, padding: 16 } },
                    tooltip: {
                        backgroundColor: '#1a1a1a', borderColor: '#333', borderWidth: 1,
                        titleColor: '#f0f0f0', bodyColor: '#8a8a8a', padding: 10,
                        callbacks: { label: ctx => ` ${fmtBRL(ctx.parsed.y)}` }
                    }
                },
                scales: {
                    x: { ticks: { color: '#8a8a8a', font: { family: 'DM Sans', size: 11 }, maxTicksLimit: 14 }, grid: { color: '#1a1a1a' } },
                    y: { beginAtZero: true, ticks: { color: '#8a8a8a', font: { family: 'DM Sans', size: 11 }, callback: v => 'R$' + v.toLocaleString('pt-BR') }, grid: { color: '#1a1a1a' } }
                }
            }
        });

        /* ── 2. Row: Barras por categoria + Tabela despesas ── */
        const row = document.createElement('div');
        row.className = 'charts-row';
        grid.appendChild(row);

        /* Barras — categorias de despesa */
        const cats   = Object.keys(despesas.categorias || {});
        const catVals = cats.map(c => parseFloat(despesas.categorias[c] || 0));

        const barCard = document.createElement('div');
        barCard.className = 'chart-card';
        barCard.innerHTML = `
            <div class="chart-card-header">
                <span class="chart-card-title">Despesas por Categoria</span>
                <span class="chart-card-sub">total no período</span>
            </div>
            <div class="chart-wrap hbar"><canvas id="chart-barras"></canvas></div>`;
        row.appendChild(barCard);

        if (chartBarras) chartBarras.destroy();
        if (cats.length > 0) {
            const CORES_CAT = ['#e74c3c','#e67e22','#f39c12','#c0392b','#d35400','#e74c3caa','#c9950f','#8b5cf6'];
            chartBarras = new Chart(document.getElementById('chart-barras').getContext('2d'), {
                type: 'bar',
                data: {
                    labels: cats,
                    datasets: [{
                        label: 'Despesa (R$)',
                        data: catVals,
                        backgroundColor: cats.map((_, i) => CORES_CAT[i % CORES_CAT.length] + 'cc'),
                        borderColor:     cats.map((_, i) => CORES_CAT[i % CORES_CAT.length]),
                        borderWidth: 1, borderRadius: 4
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    indexAxis: 'y',
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#1a1a1a', borderColor: '#333', borderWidth: 1,
                            titleColor: '#f0f0f0', bodyColor: '#8a8a8a', padding: 10,
                            callbacks: { label: ctx => ` ${fmtBRL(ctx.parsed.x)}` }
                        }
                    },
                    scales: {
                        x: { beginAtZero: true, ticks: { color: '#8a8a8a', font: { family: 'DM Sans', size: 11 }, callback: v => 'R$' + v.toLocaleString('pt-BR') }, grid: { color: '#1a1a1a' } },
                        y: { ticks: { color: '#f0f0f0', font: { family: 'DM Sans', size: 11 } }, grid: { display: false } }
                    }
                }
            });
        } else {
            barCard.querySelector('.chart-wrap').innerHTML =
                '<div style="color:var(--muted);font-size:13px;text-align:center;padding:60px 0;">Sem despesas lançadas no período</div>';
        }

        /* Tabela — lista de despesas */
        const lista = (despesas.lista || []).slice(0, 20); // limita a 20 itens
        const totalTabela = lista.reduce((s, i) => s + parseFloat(i.valor || 0), 0);

        const tabelaCard = document.createElement('div');
        tabelaCard.className = 'chart-card';
        tabelaCard.innerHTML = `
            <div class="chart-card-header">
                <span class="chart-card-title">Lançamentos</span>
                <span class="chart-card-sub">últimas despesas do período</span>
            </div>
            <div style="overflow-x:auto;">
                <table class="desp-table">
                    <thead>
                        <tr>
                            <th>Data</th>
                            <th>Descrição</th>
                            <th>Categoria</th>
                            <th style="text-align:right">Valor</th>
                        </tr>
                    </thead>
                    <tbody id="desp-tbody"></tbody>
                </table>
            </div>`;
        row.appendChild(tabelaCard);

        const tbody = tabelaCard.querySelector('#desp-tbody');

        if (lista.length === 0) {
            tbody.innerHTML = '<tr><td colspan="4" style="color:var(--muted);text-align:center;padding:40px 0;">Nenhuma despesa lançada</td></tr>';
        } else {
            lista.forEach(item => {
                const [y, m, dia] = (item.data || '').split('-');
                const dataFmt = dia ? `${dia}/${m}` : '—';
                tbody.innerHTML += `
                    <tr>
                        <td style="color:var(--muted);white-space:nowrap">${dataFmt}</td>
                        <td>${item.descricao || '—'}</td>
                        <td><span class="desp-tag">${item.categoria || 'outro'}</span></td>
                        <td style="text-align:right" class="desp-valor">${fmtBRL(item.valor)}</td>
                    </tr>`;
            });
            tbody.innerHTML += `
                <tr class="desp-total-row">
                    <td colspan="3">Total no período</td>
                    <td style="text-align:right">${fmtBRL(totalTabela)}</td>
                </tr>`;
        }
    }

    carregar();

})();
</script>