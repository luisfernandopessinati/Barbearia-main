<style>
    @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap');

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
        --gold: #c9950f; --gold-light: #dba813; --gold-dim: #c9950f33;
        --bg: #090909; --bg2: #111111; --bg3: #1c1c1c;
        --border: #2e2e2e; --text: #f0f0f0; --muted: #8a8a8a;
        --danger: #e74c3c; --danger-dim: #e74c3c22;
        --green: #27ae60; --blue: #3b82f6;
    }

    body { background: var(--bg); font-family: 'DM Sans', sans-serif; color: var(--text); min-height: 100vh; }

    /* ── Header ── */
    .dash-header { display: flex; align-items: center; justify-content: space-between; padding: 20px 40px; border-bottom: 1px solid var(--border); background: var(--bg2); position: sticky; top: 0; z-index: 100; }
    .dash-header-left { display: flex; align-items: center; gap: 20px; }
    .dash-back { color: var(--muted); text-decoration: none; font-size: 18px; transition: color 0.2s; }
    .dash-back:hover { color: var(--gold); }
    .dash-logo { font-family: 'Bebas Neue', sans-serif; font-size: 20px; letter-spacing: 3px; color: var(--gold); text-decoration: none; }
    .dash-header-center { font-family: 'Bebas Neue', sans-serif; font-size: 13px; letter-spacing: 4px; color: var(--text); text-transform: uppercase; }

    /* ── Body ── */
    .dash-body { padding: 36px 40px; max-width: 1400px; margin: 0 auto; }

    /* ── Período ── */
    .periodo-bar { display: flex; align-items: center; gap: 12px; margin-bottom: 32px; flex-wrap: wrap; }
    .periodo-bar label { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); }
    .periodo-bar input[type="date"] { background: var(--bg2); border: 1px solid var(--border); border-radius: 8px; padding: 9px 14px; font-family: 'DM Sans', sans-serif; font-size: 13px; color: var(--text); outline: none; transition: border-color 0.2s; }
    .periodo-bar input[type="date"]:focus { border-color: var(--gold); }
    .btn-filtrar { background: var(--gold); border: none; color: #000; padding: 9px 24px; border-radius: 8px; font-family: 'Bebas Neue', sans-serif; font-size: 18px; letter-spacing: 2px; cursor: pointer; transition: background 0.2s; }
    .btn-filtrar:hover { background: var(--gold-light); }
    .periodo-sep { width: 1px; height: 28px; background: var(--border); }
    .btn-periodo { background: var(--bg2); border: 1px solid var(--border); color: var(--muted); padding: 8px 16px; border-radius: 8px; font-family: 'DM Sans', sans-serif; font-size: 12px; letter-spacing: 1px; cursor: pointer; transition: all 0.2s; text-transform: uppercase; }
    .btn-periodo:hover, .btn-periodo.active { border-color: var(--gold); color: var(--gold); }

    /* ── KPIs ── */
    .kpis { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 32px; }
    .kpi-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; padding: 20px 24px; position: relative; overflow: hidden; transition: border-color 0.2s; }
    .kpi-card:hover { border-color: #3a3a3a; }
    .kpi-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: var(--gold); opacity: 0.4; }
    .kpi-card.destaque::before { opacity: 1; }
    .kpi-card.verde::before { background: var(--green); opacity: 1; }
    .kpi-card.azul::before  { background: var(--blue); opacity: 1; }
    .kpi-label { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); margin-bottom: 8px; }
    .kpi-value { font-family: 'Bebas Neue', sans-serif; font-size: 36px; color: var(--text); line-height: 1; margin-bottom: 4px; }
    .kpi-value.gold  { color: var(--gold); }
    .kpi-value.green { color: var(--green); }
    .kpi-value.blue  { color: var(--blue); }
    .kpi-sub { font-size: 11px; color: var(--muted); }

    /* ── Grid gráficos ── */
    .charts-grid { display: grid; grid-template-columns: 1fr; gap: 24px; }
    .charts-row  { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }

    .chart-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; padding: 28px; }
    .chart-card-header { display: flex; align-items: baseline; gap: 12px; margin-bottom: 24px; }
    .chart-card-title { font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 1px; color: var(--text); }
    .chart-card-sub { font-size: 11px; color: var(--muted); }

    .chart-wrap { position: relative; width: 100%; }
    .chart-wrap.line { height: 300px; }
    .chart-wrap.bar  { height: 320px; }
    .chart-wrap.donut { height: 260px; display: flex; align-items: center; justify-content: center; }

    /* Legenda formas pagamento */
    .pagto-legend { display: flex; flex-direction: column; gap: 10px; margin-top: 20px; }
    .pagto-legend-item { display: flex; align-items: center; gap: 10px; font-size: 13px; }
    .pagto-legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .pagto-legend-label { flex: 1; color: var(--muted); text-transform: capitalize; }
    .pagto-legend-val { font-weight: 600; color: var(--text); }
    .pagto-legend-pct { font-size: 11px; color: var(--muted); min-width: 36px; text-align: right; }

    /* Loading / erro */
    .dash-loading { display: flex; align-items: center; justify-content: center; padding: 80px; color: var(--muted); gap: 12px; font-size: 13px; }
    .dash-loading::before { content: ''; width: 20px; height: 20px; border: 2px solid var(--border); border-top-color: var(--gold); border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .dash-erro { text-align: center; padding: 80px; color: var(--danger); font-size: 13px; }

    @media (max-width: 900px) {
        .dash-body { padding: 20px 16px; }
        .dash-header { padding: 14px 16px; }
        .dash-header-center { display: none; }
        .kpis { grid-template-columns: 1fr 1fr; gap: 10px; }
        .kpi-value { font-size: 28px; }
        .charts-row { grid-template-columns: 1fr; }
    }
    @media (max-width: 500px) {
        .kpis { grid-template-columns: 1fr 1fr; }
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<div class="dash-header">
    <div class="dash-header-left">
        <a href="/admin" class="dash-back"><i class="fa-solid fa-arrow-left"></i></a>
        <a href="/" class="dash-logo">Barbearia</a>
    </div>
    <div class="dash-header-center">Dashboard de Vendas</div>
</div>

<div class="dash-body">

    <!-- Período -->
    <div class="periodo-bar">
        <label>De</label>
        <input type="date" id="input-inicio">
        <label>Até</label>
        <input type="date" id="input-fim">
        <button class="btn-filtrar" id="btn-filtrar">Filtrar</button>
        <div class="periodo-sep"></div>
        <button class="btn-periodo" data-dias="7">7 dias</button>
        <button class="btn-periodo active" data-dias="30">30 dias</button>
        <button class="btn-periodo" data-dias="90">90 dias</button>
    </div>

    <!-- KPIs -->
    <div class="kpis" id="kpis">
        <div class="dash-loading" style="grid-column:1/-1"></div>
    </div>

    <!-- Gráficos -->
    <div class="charts-grid" id="charts-grid">
        <div class="dash-loading"></div>
    </div>

</div>

<script>
(function () {

    const CORES_PAGTO = {
        pix:            '#27ae60',
        dinheiro:       '#c9950f',
        cartao_credito: '#3b82f6',
        cartao_debito:  '#8b5cf6',
        outro:          '#6b7280'
    };
    const LABEL_PAGTO = {
        pix:            'Pix',
        dinheiro:       'Dinheiro',
        cartao_credito: 'Cartão Crédito',
        cartao_debito:  'Cartão Débito',
        outro:          'Outro'
    };
    const CORES_BAR = [
        '#c9950f','#dba813','#f59e0b','#3b82f6','#10b981',
        '#8b5cf6','#ef4444','#06b6d4','#ec4899','#6366f1'
    ];

    let chartLine  = null;
    let chartDonut = null;
    let chartBar   = null;

    function hoje()    { return new Date().toISOString().split('T')[0]; }
    function diasAtras(n) {
        const d = new Date();
        d.setDate(d.getDate() - n);
        return d.toISOString().split('T')[0];
    }

    const inputInicio = document.getElementById('input-inicio');
    const inputFim    = document.getElementById('input-fim');
    inputInicio.value = diasAtras(30);
    inputFim.value    = hoje();

    document.querySelectorAll('.btn-periodo').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.btn-periodo').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            inputInicio.value = diasAtras(parseInt(btn.dataset.dias));
            inputFim.value    = hoje();
            carregar();
        });
    });

    document.getElementById('btn-filtrar').addEventListener('click', () => {
        document.querySelectorAll('.btn-periodo').forEach(b => b.classList.remove('active'));
        carregar();
    });

    function fmtBRL(v) {
        return parseFloat(v).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
    }

    async function carregar() {
        const inicio = inputInicio.value;
        const fim    = inputFim.value;

        document.getElementById('kpis').innerHTML        = '<div class="dash-loading" style="grid-column:1/-1"></div>';
        document.getElementById('charts-grid').innerHTML = '<div class="dash-loading"></div>';

        try {
            const res  = await fetch(`/admin/dashboard/vendas/dados?inicio=${inicio}&fim=${fim}`);
            const json = await res.json();
            if (!res.ok) throw new Error(json.erro || 'Erro desconhecido');
            renderKPIs(json.kpis);
            renderGraficos(json);
        } catch (e) {
            document.getElementById('kpis').innerHTML        = `<div class="dash-erro" style="grid-column:1/-1">⚠ ${e.message}</div>`;
            document.getElementById('charts-grid').innerHTML = '';
        }
    }

    function renderKPIs(kpis) {
        document.getElementById('kpis').innerHTML = `
            <div class="kpi-card destaque">
                <div class="kpi-label">Total de Vendas</div>
                <div class="kpi-value gold">${kpis.totalVendas}</div>
                <div class="kpi-sub">no período</div>
            </div>
            <div class="kpi-card verde">
                <div class="kpi-label">Faturamento</div>
                <div class="kpi-value green">${fmtBRL(kpis.faturamentoTotal)}</div>
                <div class="kpi-sub">total no período</div>
            </div>
            <div class="kpi-card azul">
                <div class="kpi-label">Ticket Médio</div>
                <div class="kpi-value blue">${fmtBRL(kpis.ticketMedio)}</div>
                <div class="kpi-sub">por venda</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-label">Produto Destaque</div>
                <div class="kpi-value" style="font-size:20px;">${kpis.topProduto ? kpis.topProduto.nome : '—'}</div>
                <div class="kpi-sub">${kpis.topProduto ? fmtBRL(kpis.topProduto.faturamento) + ' em vendas' : ''}</div>
            </div>`;
    }

    function renderGraficos(dados) {
        const grid = document.getElementById('charts-grid');
        grid.innerHTML = '';

        // ── LINHA: faturamento + quantidade por dia ───────
        const dias = Object.keys(dados.evolucao).sort();
        const lineCard = document.createElement('div');
        lineCard.className = 'chart-card';
        lineCard.innerHTML = `
            <div class="chart-card-header">
                <span class="chart-card-title">Faturamento Diário</span>
                <span class="chart-card-sub">R$ acumulado por dia</span>
            </div>
            <div class="chart-wrap line"><canvas id="chart-line"></canvas></div>`;
        grid.appendChild(lineCard);

        if (chartLine) chartLine.destroy();
        chartLine = new Chart(document.getElementById('chart-line').getContext('2d'), {
            type: 'line',
            data: {
                labels: dias.map(d => { const [y,m,dia] = d.split('-'); return `${dia}/${m}`; }),
                datasets: [
                    {
                        label: 'Faturamento (R$)',
                        data: dias.map(d => dados.evolucao[d]?.faturamento || 0),
                        borderColor: '#c9950f',
                        backgroundColor: '#c9950f22',
                        borderWidth: 2,
                        pointRadius: 3,
                        pointHoverRadius: 5,
                        tension: 0.4,
                        fill: true,
                        yAxisID: 'y'
                    },
                    {
                        label: 'Qtd. Vendas',
                        data: dias.map(d => dados.evolucao[d]?.quantidade || 0),
                        borderColor: '#3b82f6',
                        backgroundColor: 'transparent',
                        borderWidth: 2,
                        pointRadius: 3,
                        pointHoverRadius: 5,
                        tension: 0.4,
                        borderDash: [4, 3],
                        yAxisID: 'y2'
                    }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: { labels: { color: '#8a8a8a', font: { family: 'DM Sans', size: 12 }, boxWidth: 12, padding: 16 } },
                    tooltip: {
                        backgroundColor: '#1a1a1a', borderColor: '#333', borderWidth: 1,
                        titleColor: '#f0f0f0', bodyColor: '#8a8a8a', padding: 10,
                        callbacks: {
                            label: ctx => ctx.datasetIndex === 0
                                ? ` ${fmtBRL(ctx.parsed.y)}`
                                : ` ${ctx.parsed.y} venda${ctx.parsed.y !== 1 ? 's' : ''}`
                        }
                    }
                },
                scales: {
                    x:  { ticks: { color: '#8a8a8a', font: { family: 'DM Sans', size: 11 }, maxTicksLimit: 14 }, grid: { color: '#1a1a1a' } },
                    y:  { beginAtZero: true, ticks: { color: '#8a8a8a', font: { family: 'DM Sans', size: 11 }, callback: v => 'R$ ' + v.toLocaleString('pt-BR') }, grid: { color: '#1a1a1a' } },
                    y2: { beginAtZero: true, position: 'right', ticks: { color: '#3b82f6', font: { family: 'DM Sans', size: 11 }, stepSize: 1 }, grid: { display: false } }
                }
            }
        });

        // ── LINHA 2: formas de pagamento + top produtos ───
        const row = document.createElement('div');
        row.className = 'charts-row';
        grid.appendChild(row);

        // Donut — formas de pagamento
        const donutCard = document.createElement('div');
        donutCard.className = 'chart-card';
        donutCard.innerHTML = `
            <div class="chart-card-header">
                <span class="chart-card-title">Formas de Pagamento</span>
                <span class="chart-card-sub">distribuição no período</span>
            </div>
            <div class="chart-wrap donut"><canvas id="chart-donut" style="max-width:200px;max-height:200px;"></canvas></div>
            <div class="pagto-legend" id="pagto-legend"></div>`;
        row.appendChild(donutCard);

        const formas  = Object.keys(dados.formasPagamento);
        const totalPg = formas.reduce((s, f) => s + dados.formasPagamento[f].count, 0);

        if (chartDonut) chartDonut.destroy();
        if (formas.length > 0) {
            chartDonut = new Chart(document.getElementById('chart-donut').getContext('2d'), {
                type: 'doughnut',
                data: {
                    labels: formas.map(f => LABEL_PAGTO[f] || f),
                    datasets: [{
                        data: formas.map(f => dados.formasPagamento[f].count),
                        backgroundColor: formas.map(f => CORES_PAGTO[f] || '#6b7280'),
                        borderColor: '#111', borderWidth: 2, hoverOffset: 6
                    }]
                },
                options: {
                    responsive: false, cutout: '62%',
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#1a1a1a', borderColor: '#333', borderWidth: 1,
                            titleColor: '#f0f0f0', bodyColor: '#8a8a8a', padding: 10,
                            callbacks: { label: ctx => ` ${ctx.parsed} venda${ctx.parsed !== 1 ? 's' : ''} (${((ctx.parsed/totalPg)*100).toFixed(0)}%)` }
                        }
                    }
                }
            });

            const legendEl = document.getElementById('pagto-legend');
            formas.forEach(f => {
                const item = dados.formasPagamento[f];
                const pct  = ((item.count / totalPg) * 100).toFixed(0);
                legendEl.innerHTML += `
                    <div class="pagto-legend-item">
                        <span class="pagto-legend-dot" style="background:${CORES_PAGTO[f] || '#6b7280'}"></span>
                        <span class="pagto-legend-label">${LABEL_PAGTO[f] || f}</span>
                        <span class="pagto-legend-val">${fmtBRL(item.valor)}</span>
                        <span class="pagto-legend-pct">${pct}%</span>
                    </div>`;
            });
        } else {
            document.getElementById('pagto-legend').innerHTML =
                '<div style="color:var(--muted);font-size:13px;text-align:center;padding:40px 0;">Sem vendas no período</div>';
        }

        // Barras — top produtos
        const barCard = document.createElement('div');
        barCard.className = 'chart-card';
        barCard.innerHTML = `
            <div class="chart-card-header">
                <span class="chart-card-title">Top Produtos</span>
                <span class="chart-card-sub">faturamento por produto</span>
            </div>
            <div class="chart-wrap bar"><canvas id="chart-bar"></canvas></div>`;
        row.appendChild(barCard);

        if (chartBar) chartBar.destroy();
        if (dados.topProdutos.length > 0) {
            chartBar = new Chart(document.getElementById('chart-bar').getContext('2d'), {
                type: 'bar',
                data: {
                    labels: dados.topProdutos.map(p => p.nome.length > 18 ? p.nome.slice(0,16)+'…' : p.nome),
                    datasets: [{
                        label: 'Faturamento (R$)',
                        data: dados.topProdutos.map(p => parseFloat(p.faturamento)),
                        backgroundColor: dados.topProdutos.map((_, i) => CORES_BAR[i % CORES_BAR.length] + 'cc'),
                        borderColor:     dados.topProdutos.map((_, i) => CORES_BAR[i % CORES_BAR.length]),
                        borderWidth: 1,
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    indexAxis: 'y',
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#1a1a1a', borderColor: '#333', borderWidth: 1,
                            titleColor: '#f0f0f0', bodyColor: '#8a8a8a', padding: 10,
                            callbacks: { label: ctx => ` ${fmtBRL(ctx.parsed.x)}` }
                        }
                    },
                    scales: {
                        x: { beginAtZero: true, ticks: { color: '#8a8a8a', font: { family: 'DM Sans', size: 11 }, callback: v => 'R$' + v.toLocaleString('pt-BR') }, grid: { color: '#1a1a1a' } },
                        y: { ticks: { color: '#f0f0f0', font: { family: 'DM Sans', size: 11 } }, grid: { display: false } }
                    }
                }
            });
        } else {
            barCard.querySelector('.chart-wrap').innerHTML =
                '<div style="color:var(--muted);font-size:13px;text-align:center;padding:40px 0;">Sem produtos vendidos no período</div>';
        }
    }

    carregar();

})();
</script>
