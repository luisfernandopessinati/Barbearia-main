<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold: #D4AF37; --gold-glow: rgba(212,175,55,.18);
            --bg: #0d0d0d; --surface: #161616; --card: #1a1a1a;
            --card-border: rgba(212,175,55,.15); --text: #e8e8e8;
            --muted: #666; --danger: #e05454; --success: #4caf7d;
            --radius: 12px; --font-main: 'Rajdhani', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;
            --entrada: #4caf7d; --entrada-bg: rgba(76,175,125,.12);
            --saida: #e05454;   --saida-bg: rgba(224,84,84,.12);
            --ajuste: #D4AF37;  --ajuste-bg: rgba(212,175,55,.12);

            --header-h: 56px;   /* header */
            --topbar-h: 58px;   /* tipo-bar */
            --tabs-h:   46px;   /* abas */
            --topo-h: calc(var(--header-h) + var(--topbar-h) + var(--tabs-h)); /* total topo */
            --right-w: 260px;   /* largura painel direito */
            --right-h: 230px;   /* altura painel direito no mobile */
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        html, body { background: var(--bg); color: var(--text); font-family: var(--font-main); }

        /* ── HEADER fixo ── */
        header {
            position: fixed; top: 0; left: 0; right: 0; height: var(--header-h);
            background: #000; border-bottom: 1px solid var(--card-border);
            padding: 0 20px; z-index: 100;
            display: flex; align-items: center; justify-content: space-between;
        }
        .btn-back { text-decoration: none; color: var(--gold); display: flex; align-items: center; gap: 5px; font-weight: 600; font-size: 14px; }

        /* ── TIPO BAR fixo ── */
        .tipo-bar {
            position: fixed; top: var(--header-h); left: 0; right: 0; height: var(--topbar-h);
            display: flex; gap: 10px; padding: 10px 16px;
            background: var(--surface); border-bottom: 1px solid var(--card-border); z-index: 99;
        }
        .tipo-btn {
            flex: 1; padding: 15px 10px; border-radius: 6px; border: 1px solid transparent;
            font-family: var(--font-main); font-size: 15px; font-weight: 700;
            letter-spacing: 1px; text-transform: uppercase; cursor: pointer;
            transition: all .2s; background: var(--card);
            display: flex; align-items: center; justify-content: center; /* 👈 */
            line-height: 1; /* 👈 evita espaço extra do line-height */
        }
        .tipo-btn.entrada { color: var(--entrada); }
        .tipo-btn.saida   { color: var(--saida); }
        .tipo-btn.ajuste  { color: var(--ajuste); }
        .tipo-btn.entrada.ativo { background: var(--entrada-bg); border-color: var(--entrada); box-shadow: none; }
        .tipo-btn.saida.ativo   { background: var(--saida-bg);   border-color: var(--saida);   box-shadow: none; }
        .tipo-btn.ajuste.ativo  { background: var(--ajuste-bg);  border-color: var(--ajuste);  box-shadow: none; }
        /* ── ABAS fixas ── */
        .tabs {
            position: fixed; top: calc(var(--header-h) + var(--topbar-h)); left: 0; right: 0; height: var(--tabs-h);
            display: flex; background: var(--surface); border-bottom: 1px solid var(--card-border); z-index: 98;
        }
        .tab-btn {
            flex: 1; padding: 12px; background: none; border: none; color: var(--muted);
            font-family: var(--font-main); font-size: 14px; font-weight: 600;
            letter-spacing: 1px; text-transform: uppercase; cursor: pointer;
            border-bottom: 2px solid transparent; transition: all .2s;
            display: flex; align-items: center; justify-content: center; /* 👈 */
            line-height: 1; /* 👈 */
        }
        .tab-btn.ativo { color: var(--gold); border-bottom-color: var(--gold); }

        /* ── LANÇAMENTO: área de busca+lista (esquerda) ── */
        .area-busca {
            position: fixed;
            top: var(--topo-h); left: 0; right: var(--right-w); bottom: 0;
            display: flex; flex-direction: column; overflow: hidden;
            border-right: 1px solid var(--card-border);
        }
        .area-busca.hidden { display: none; }

        .search-area { padding: 14px 16px; background: var(--surface); border-bottom: 1px solid var(--card-border); flex-shrink: 0; }
        .search-row  { display: flex; gap: 10px; align-items: flex-end; }
        .input-group { position: relative; flex: 1; }
        .input-group label { display: block; color: var(--gold); font-size: 11px; text-transform: uppercase; margin-bottom: 5px; font-weight: 600; letter-spacing: 1px; }

        input, select, textarea {
            width: 100%; background: var(--card); border: 1px solid var(--card-border);
            border-radius: 8px; color: #fff; padding: 10px 12px;
            font-family: var(--font-main); font-size: 15px; outline: none; transition: border-color .2s;
        }
        input:focus, select:focus, textarea:focus { border-color: var(--gold); }
        textarea { resize: none; height: 42px; font-size: 14px; }

        .items-list { flex: 1; overflow-y: auto; padding: 14px 16px; }

        /* ── PAINEL DIREITO (desktop): fixo à direita ── */
        .area-direita {
            position: fixed;
            top: var(--topo-h); right: 0; width: var(--right-w); bottom: 0;
            background: #050505; border-left: 1px solid var(--card-border);
            display: flex; flex-direction: column; padding: 16px; gap: 12px;
            overflow: hidden;
        }
        .area-direita.hidden { display: none; }

        .panel-spacer { flex: 1; }

        .obs-group label { color: var(--gold); font-size: 11px; text-transform: uppercase; font-weight: 600; letter-spacing: 1px; display: block; margin-bottom: 5px; }

        .counter-box { background: var(--card); padding: 12px; border-radius: var(--radius); border: 1px solid var(--card-border); text-align: center; }
        .counter-label { color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: 1px; }
        .counter-value { font-family: var(--font-mono); font-size: 26px; font-weight: 600; margin-top: 4px; color: var(--gold); }
        .counter-value.entrada-cor { color: var(--entrada); }
        .counter-value.saida-cor   { color: var(--saida); }

        .btn-finish {
            background: var(--gold); color: #000; border: none; padding: 14px;
            border-radius: var(--radius); font-weight: 700; font-size: 15px; cursor: pointer;
            text-transform: uppercase; letter-spacing: 1px; flex-shrink: 0;
            display: flex; align-items: center; justify-content: center; gap: 8px; transition: opacity .2s;
        }
        .btn-finish.entrada-btn { background: var(--entrada); }
        .btn-finish.saida-btn   { background: var(--saida); }
        .btn-finish:hover    { opacity: .88; }
        .btn-finish:disabled { opacity: .4; cursor: not-allowed; }

        /* ── CONSULTA: área fixa entre topo e base ── */
        .area-consulta {
            position: fixed;
            top: var(--topo-h); left: 0; right: 0; bottom: 0;
            overflow-y: auto; padding: 16px;
        }
        .area-consulta.hidden { display: none; }

        .consulta-filtro { display: flex; gap: 10px; align-items: flex-end; margin-bottom: 16px; flex-wrap: wrap; }
        .consulta-filtro .input-group input[type="date"] { color-scheme: dark; }

        .btn-buscar-c { background: var(--gold); color: #000; border: none; padding: 10px 18px; border-radius: 8px; font-weight: 700; font-size: 14px; cursor: pointer; white-space: nowrap; display: flex; align-items: center; gap: 6px; transition: opacity .2s; }
        .btn-buscar-c:hover    { opacity: .85; }
        .btn-buscar-c:disabled { opacity: .4; cursor: not-allowed; }

        /* cards lançamento */
        .lanc-card { background: var(--card); border: 1px solid var(--card-border); border-radius: var(--radius); margin-bottom: 10px; overflow: hidden; cursor: pointer; transition: border-color .2s; }
        .lanc-card:hover { border-color: rgba(212,175,55,.4); }
        .lanc-card.cancelado { opacity: .45; }
        .lanc-card-header { padding: 14px 16px; display: flex; align-items: center; justify-content: space-between; gap: 12px; }
        .lanc-card-left { display: flex; align-items: center; gap: 12px; min-width: 0; }
        .lanc-icon { font-size: 20px; flex-shrink: 0; }
        .lanc-id   { font-weight: 700; font-size: 15px; }
        .lanc-meta { font-size: 12px; color: var(--muted); margin-top: 2px; }
        .lanc-badge { font-size: 10px; font-weight: 700; letter-spacing: 1px; padding: 2px 8px; border-radius: 20px; text-transform: uppercase; flex-shrink: 0; }
        .badge-E { background: var(--entrada-bg); color: var(--entrada); border: 1px solid var(--entrada); }
        .badge-S { background: var(--saida-bg);   color: var(--saida);   border: 1px solid var(--saida); }
        .badge-A { background: var(--ajuste-bg);  color: var(--ajuste);  border: 1px solid var(--ajuste); }
        .badge-F { background: rgba(76,175,125,.12); color: var(--success); }
        .badge-C { background: rgba(224,84,84,.12);  color: var(--danger); }
        .lanc-card-right { text-align: right; flex-shrink: 0; }
        .lanc-qtd-total  { font-family: var(--font-mono); font-weight: 700; font-size: 14px; }
        .btn-cancelar-lanc { background: none; border: none; color: var(--danger); font-size: 12px; cursor: pointer; padding: 4px 8px; border-radius: 6px; transition: background .2s; margin-top: 4px; display: block; margin-left: auto; }
        .btn-cancelar-lanc:hover { background: rgba(224,84,84,.12); }
        .lanc-itens { display: none; padding: 0 16px 14px; border-top: 1px solid var(--card-border); }
        .lanc-itens.open { display: block; }
        .item-linha { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,.04); font-size: 14px; }
        .item-linha:last-child { border-bottom: none; }
        .item-qtd-detalhe { font-family: var(--font-mono); font-size: 13px; color: var(--muted); }

        /* ── ITENS DO ESTOQUE ── */
        .est-item { background: var(--card); padding: 12px 14px; margin-bottom: 10px; border-radius: 8px; animation: fadeIn .2s ease; border-left: 4px solid var(--gold); }
        .est-item.entrada-item { border-left-color: var(--entrada); }
        .est-item.saida-item   { border-left-color: var(--saida); }
        @keyframes fadeIn { from { opacity:0; transform:translateY(-4px); } to { opacity:1; transform:none; } }
        .est-item-top { display: flex; justify-content: space-between; align-items: center; gap: 10px; }
        .est-item-name { font-weight: bold; font-size: 14px; }
        .est-item-info { font-size: 11px; color: var(--muted); margin-top: 2px; }
        .est-item-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
        .est-item-qtd { font-family: var(--font-mono); font-weight: bold; font-size: 16px; }

        .btn-remove { background: none; border: none; color: var(--danger); cursor: pointer; font-size: 14px; padding: 2px 5px; border-radius: 4px; transition: background .2s; }
        .btn-remove:hover { background: rgba(224,84,84,.15); }

        .edit-row { display: none; gap: 8px; align-items: center; margin-top: 8px; padding-top: 8px; border-top: 1px solid var(--card-border); }
        .edit-row.open { display: flex; }
        .edit-row input { background: var(--surface); border: 1px solid var(--gold); color: #fff; padding: 5px 8px; border-radius: 6px; font-size: 13px; font-family: var(--font-mono); }
        .edit-row label { font-size: 10px; color: var(--muted); white-space: nowrap; }
        .edit-field { display: flex; flex-direction: column; gap: 2px; flex: 1; }
        .btn-ok { background: var(--gold); color: #000; border: none; padding: 6px 12px; border-radius: 6px; font-weight: 700; font-size: 12px; cursor: pointer; white-space: nowrap; flex-shrink: 0; }

        /* ── EMPTY ── */
        .empty-state { text-align: center; margin-top: 50px; opacity: .25; pointer-events: none; }
        .empty-state span { font-size: 44px; display: block; margin-bottom: 8px; }
        .empty-consulta { text-align: center; padding: 60px 20px; opacity: .3; }
        .empty-consulta span { font-size: 48px; display: block; margin-bottom: 10px; }

        /* ── TOAST ── */
        #toast { position: fixed; top: 70px; right: 16px; z-index: 9999; background: var(--success); color: #fff; padding: 12px 20px; border-radius: 8px; font-size: 15px; font-weight: 600; display: none; align-items: center; gap: 8px; box-shadow: 0 4px 20px rgba(0,0,0,.5); max-width: 320px; }
        #toast.error { background: var(--danger); }
        #toast.show  { display: flex; }

        /* ── SUGESTÕES ── */
        #suggestsEst { position: absolute; top: 100%; left: 0; right: 0; background: #222; z-index: 200; border-radius: 0 0 8px 8px; max-height: 260px; overflow-y: auto; box-shadow: 0 10px 30px rgba(0,0,0,.6); border: 1px solid var(--card-border); border-top: none; }
        .sug-item { padding: 11px 14px; border-bottom: 1px solid var(--card-border); cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 10px; font-size: 14px; transition: background .15s; }
        .sug-item:last-child  { border-bottom: none; }
        .sug-item:hover       { background: var(--gold-glow); }
        .sug-item.sem-result  { color: var(--muted); justify-content: center; cursor: default; }
        .sug-item.loading     { color: var(--muted); justify-content: center; font-style: italic; }
        .sug-estoque { font-size: 11px; color: var(--muted); margin-top: 2px; }
        .sug-right   { text-align: right; flex-shrink: 0; }
        .sug-qtd     { color: var(--gold); font-family: var(--font-mono); font-weight: 600; }

        /* ── SPINNER ── */
        .spinner { width: 15px; height: 15px; border: 2px solid rgba(0,0,0,.2); border-top-color: #000; border-radius: 50%; animation: spin .6s linear infinite; display: inline-block; }
        .spinner.light { border-color: rgba(255,255,255,.2); border-top-color: var(--gold); }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* ── CÂMERA ── */
        .btn-camera-est { background: var(--card); border: 1px solid var(--card-border); color: var(--gold); width: 44px; height: 44px; border-radius: 8px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; transition: border-color .2s; }
        .btn-camera-est:hover { border-color: var(--gold); }
        .scanner-est { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.95); z-index: 500; flex-direction: column; align-items: center; justify-content: center; gap: 16px; }
        .scanner-est.open { display: flex; }
        .scanner-est-box { position: relative; width: 100%; max-width: 380px; border-radius: 12px; overflow: hidden; border: 2px solid var(--gold); background: #000; }
        .scanner-est video { width: 100%; max-height: 280px; object-fit: cover; display: block; }
        .scanner-est-line { position: absolute; left: 0; right: 0; top: 50%; height: 2px; background: var(--gold); opacity: .8; animation: scanest 1.8s ease-in-out infinite; }
        @keyframes scanest { 0%{top:15%} 50%{top:85%} 100%{top:15%} }
        .scanner-est-msg { color: rgba(255,255,255,.6); font-size: 13px; text-align: center; }
        .btn-fechar-scanner-est { background: var(--card); border: 1px solid var(--card-border); color: var(--text); padding: 12px 32px; border-radius: 8px; font-size: 15px; font-weight: 600; cursor: pointer; font-family: var(--font-main); }
        .btn-fechar-scanner-est:hover { border-color: var(--danger); color: var(--danger); }

        /* ════════════════════════════════
           MOBILE
        ════════════════════════════════ */
        @media (max-width: 640px) {
            /* área de busca ocupa tudo, sem coluna direita */
            .area-busca {
                right: 0;
                bottom: var(--right-h);
                border-right: none;
            }
            /* painel direito vira footer fixo */
            .area-direita {
                top: auto;
                width: 100%;
                height: var(--right-h);
                border-left: none;
                border-top: 1px solid var(--card-border);
                flex-direction: row;
                flex-wrap: wrap;
                padding: 10px 14px;
                gap: 8px;
                align-items: center;
            }
            .obs-group { width: 100%; }
            .obs-group textarea { height: 34px; font-size: 13px; }
            .counter-box { flex: 1; padding: 8px; }
            .counter-value { font-size: 20px; }
            .counter-label { font-size: 10px; }
            .btn-finish { flex: 2; padding: 10px; font-size: 13px; min-width: 120px; }
            .panel-spacer { display: none; }
        }
    </style>
</head>
<body>

<div id="toast"></div>

<!-- Scanner câmera -->
<div class="scanner-est" id="scannerEst">
    <div class="scanner-est-box">
        <video id="scannerEstVideo" playsinline muted></video>
        <div class="scanner-est-line"></div>
    </div>
    <div class="scanner-est-msg">Aponte para o c&#243;digo de barras</div>
    <button type="button" class="btn-fechar-scanner-est" onclick="fecharScannerEst()">&#215; Fechar C&#226;mera</button>
</div>

<!-- HEADER -->
<header>
    <a href="/admin" class="btn-back">&#8592; VOLTAR</a>
    <span style="color:var(--gold);font-weight:700;font-size:15px;letter-spacing:2px;text-transform:uppercase;">Estoque</span>
    <div style="width:60px;"></div>
</header>

<!-- TIPO BAR -->
<div class="tipo-bar">
    <button class="tipo-btn entrada ativo" id="btnEntrada" onclick="setTipo('E')">&#9650; Entrada</button>
    <button class="tipo-btn saida"         id="btnSaida"   onclick="setTipo('S')">&#9660; Sa&#237;da</button>
    <button class="tipo-btn ajuste"        id="btnAjuste"  onclick="setTipo('A')">&#9632; Ajuste</button>
</div>

<!-- ABAS -->
<div class="tabs">
    <button class="tab-btn ativo" id="tabLanc"     onclick="setTab('lanc')">&#43; Lan&#231;amento</button>
    <button class="tab-btn"       id="tabConsulta" onclick="setTab('consulta')">&#128196; Consulta</button>
</div>

<!-- ÁREA BUSCA + LISTA (aba lançamento) -->
<div class="area-busca" id="areaBusca">
    <div class="search-area">
        <div class="search-row">
            <div class="input-group">
                <label>Buscar Produto</label>
                <input type="text" id="buscaEst" placeholder="Toque para listar ou filtre..." autocomplete="off">
                <div id="suggestsEst"></div>
            </div>
            <div class="input-group" style="max-width:72px;">
                <label>Qtd</label>
                <input type="number" id="qtdEst" value="1" min="1" step="0.001">
            </div>
            <button type="button" class="btn-camera-est" id="btnCameraEst">&#128247;</button>
        </div>
    </div>
    <div class="items-list" id="listaEst">
        <div class="empty-state"><span>&#128230;</span><p>Nenhum item adicionado</p></div>
    </div>
</div>

<!-- PAINEL DIREITO (obs + contadores + botão) -->
<div class="area-direita" id="areaDireita">
    <div class="obs-group">
        <label>Observa&#231;&#227;o</label>
        <textarea id="obsEst" placeholder="Opcional..."></textarea>
    </div>
    <div class="panel-spacer"></div>
    <div class="counter-box">
        <div class="counter-label">Itens</div>
        <div class="counter-value" id="totalItensDisplay">0</div>
    </div>
    <div class="counter-box">
        <div class="counter-label">Pe&#231;as</div>
        <div class="counter-value" id="totalPecasDisplay">0</div>
    </div>
    <button class="btn-finish entrada-btn" id="btnFinalizar" onclick="finalizar()">
        &#10004; Finalizar
    </button>
</div>

<!-- ÁREA CONSULTA -->
<div class="area-consulta hidden" id="areaConsulta">
    <div class="consulta-filtro">
        <div class="input-group" style="max-width:200px;">
            <label>Data</label>
            <input type="date" id="filtroDataEst">
        </div>
        <div class="input-group" style="max-width:150px;">
            <label>Tipo</label>
            <select id="filtroTipoEst">
                <option value="">Todos</option>
                <option value="E">Entrada</option>
                <option value="S">Sa&#237;da</option>
                <option value="A">Ajuste</option>
            </select>
        </div>
        <button class="btn-buscar-c" id="btnBuscarC" onclick="buscarLancamentos()">&#8635; Buscar</button>
    </div>
    <div id="listaLancamentos">
        <div class="empty-consulta"><span>&#128196;</span><p>Selecione uma data e busque</p></div>
    </div>
</div>

<script>
    var itensEst = [], tipoAtual = 'E', debTimer = null;
    var buscaEst  = document.getElementById('buscaEst');
    var suggestsEl = document.getElementById('suggestsEst');

    /* ── TOAST ── */
    function toast(msg, tipo) {
        var el = document.getElementById('toast');
        el.textContent = msg; el.className = 'show' + (tipo === 'error' ? ' error' : '');
        clearTimeout(el._t); el._t = setTimeout(function(){ el.className = ''; }, 3500);
    }

    /* ── ABAS ── */
    function setTab(tab) {
        var isLanc = tab === 'lanc';
        document.getElementById('tabLanc').classList.toggle('ativo',     isLanc);
        document.getElementById('tabConsulta').classList.toggle('ativo', !isLanc);
        document.getElementById('areaBusca').classList.toggle('hidden',    !isLanc);
        document.getElementById('areaDireita').classList.toggle('hidden',  !isLanc);
        document.getElementById('areaConsulta').classList.toggle('hidden', isLanc);
        if (!isLanc) buscarLancamentos();
    }

    /* ── TIPO ── */
    function setTipo(tipo) {
        tipoAtual = tipo;
        ['E','S','A'].forEach(function(t) {
            var id = t==='E'?'btnEntrada':t==='S'?'btnSaida':'btnAjuste';
            document.getElementById(id).classList.toggle('ativo', t === tipo);
        });
        var btnF = document.getElementById('btnFinalizar');
        var c1   = document.getElementById('totalItensDisplay');
        var c2   = document.getElementById('totalPecasDisplay');
        btnF.className = 'btn-finish ' + (tipo==='E'?'entrada-btn':tipo==='S'?'saida-btn':'');
        c1.className = 'counter-value ' + (tipo==='E'?'entrada-cor':tipo==='S'?'saida-cor':'');
        c2.className = 'counter-value ' + (tipo==='E'?'entrada-cor':tipo==='S'?'saida-cor':'');
        renderItensEst();
    }

    /* ── BUSCA ── */
    buscaEst.addEventListener('focus', function() { if (!suggestsEl.innerHTML) buscarProdutosEst(''); });
    buscaEst.addEventListener('input', function(e) {
        clearTimeout(debTimer);
        var t = e.target.value.trim();
        debTimer = setTimeout(function(){ buscarProdutosEst(t); }, /^\d{6,}$/.test(t) ? 200 : 350);
    });

    function buscarProdutosEst(termo) {
        suggestsEl.innerHTML = '<div class="sug-item loading"><span class="spinner light"></span>&nbsp;Buscando...</div>';
        fetch('/admin/estoque/produtos' + (termo ? '?busca=' + encodeURIComponent(termo) : ''), { credentials: 'include' })
            .then(function(res) {
                var ct = res.headers.get('content-type') || '';
                if (!ct.includes('application/json')) { suggestsEl.innerHTML = '<div class="sug-item sem-result">Sess\u00e3o expirada</div>'; return; }
                return res.json().then(function(json) {
                    if (!res.ok) throw new Error(json.message || 'Erro');
                    var lista = json.data || [];
                    if (/^\d{6,}$/.test(termo)) {
                        for (var k = 0; k < lista.length; k++) {
                            if (String(lista[k].codbarras) === termo) { adicionarItem(lista[k]); fecharSugsEst(); buscaEst.value=''; return; }
                        }
                    }
                    renderSugsEst(lista);
                });
            })
            .catch(function(err) { suggestsEl.innerHTML = '<div class="sug-item sem-result">&#9888; ' + err.message + '</div>'; });
    }

    function renderSugsEst(lista) {
        if (!lista.length) { suggestsEl.innerHTML = '<div class="sug-item sem-result">Nenhum produto encontrado</div>'; return; }
        suggestsEl._cache = lista;
        var html = '';
        for (var i = 0; i < lista.length; i++) {
            var p = lista[i];
            html += '<div class="sug-item" data-idx="' + i + '"><div><div>' + p.descricao + '</div><div class="sug-estoque">Estoque: ' + (p.estoque != null ? p.estoque : '&mdash;') + '</div></div>'
                  + '<div class="sug-right"><div class="sug-qtd">' + (p.estoque != null ? p.estoque : '&mdash;') + '</div><div style="font-size:10px;color:var(--muted)">atual</div></div></div>';
        }
        suggestsEl.innerHTML = html;
        suggestsEl.querySelectorAll('[data-idx]').forEach(function(el) {
            el.addEventListener('click', function() {
                var prod = (suggestsEl._cache || [])[parseInt(el.dataset.idx)];
                if (prod) { adicionarItem(prod); fecharSugsEst(); }
            });
        });
    }

    function fecharSugsEst() { suggestsEl.innerHTML = ''; suggestsEl._cache = null; }
    document.addEventListener('click', function(e) {
        if (!e.target.closest('#suggestsEst') && !e.target.closest('#buscaEst')) fecharSugsEst();
    });

    /* ── ITENS ── */
    function adicionarItem(produto) {
        var qtd = Math.max(0.001, parseFloat(document.getElementById('qtdEst').value) || 1);
        var existente = null;
        for (var i = 0; i < itensEst.length; i++) { if (itensEst[i].produto_id === produto.id) { existente = itensEst[i]; break; } }
        if (existente) { existente.quantidade += qtd; }
        else { itensEst.push({ produto_id: produto.id, descricao: produto.descricao, estoque_atual: parseFloat(produto.estoque) || 0, quantidade: qtd }); }
        document.getElementById('qtdEst').value = 1;
        buscaEst.value = '';
        renderItensEst();
        setTimeout(function(){ buscaEst.focus(); buscarProdutosEst(''); }, 120);
    }

    function renderItensEst() {
        var c = document.getElementById('listaEst');
        if (!itensEst.length) { c.innerHTML = '<div class="empty-state"><span>&#128230;</span><p>Nenhum item adicionado</p></div>'; atualizarContadores(); return; }
        var cor = tipoAtual==='E'?'entrada-item':tipoAtual==='S'?'saida-item':'';
        var html = '';
        for (var i = 0; i < itensEst.length; i++) {
            var it = itensEst[i];
            html += '<div class="est-item ' + cor + '"><div class="est-item-top"><div><div class="est-item-name">' + it.descricao + '</div><div class="est-item-info">Estoque atual: ' + it.estoque_atual + '</div></div>'
                  + '<div class="est-item-right"><div class="est-item-qtd">' + fmtQtd(it.quantidade) + '</div>'
                  + '<button class="btn-remove btn-edit-est" data-idx="' + i + '">&#9998;</button>'
                  + '<button class="btn-remove btn-del-est"  data-idx="' + i + '">&#x2715;</button>'
                  + '</div></div>'
                  + '<div class="edit-row" id="er' + i + '"><div class="edit-field"><label>Quantidade</label><input type="number" class="eq" value="' + it.quantidade + '" min="0.001" step="0.001" style="width:100px;"></div>'
                  + '<button class="btn-ok bok" data-idx="' + i + '">OK</button></div></div>';
        }
        c.innerHTML = html;
        c.querySelectorAll('.btn-edit-est').forEach(function(b) { b.addEventListener('click', function(e){ e.stopPropagation(); document.getElementById('er'+b.dataset.idx).classList.toggle('open'); }); });
        c.querySelectorAll('.btn-del-est').forEach(function(b)  { b.addEventListener('click', function(){ itensEst.splice(parseInt(b.dataset.idx),1); renderItensEst(); }); });
        c.querySelectorAll('.bok').forEach(function(b) {
            b.addEventListener('click', function() {
                var idx = parseInt(b.dataset.idx);
                var q = Math.max(0.001, parseFloat(document.getElementById('er'+idx).querySelector('.eq').value) || 0.001);
                itensEst[idx].quantidade = q; renderItensEst();
            });
        });
        atualizarContadores();
    }

    function atualizarContadores() {
        var total = 0; for (var i = 0; i < itensEst.length; i++) total += itensEst[i].quantidade;
        document.getElementById('totalItensDisplay').textContent = itensEst.length;
        document.getElementById('totalPecasDisplay').textContent = fmtQtd(total);
    }

    /* ── FINALIZAR ── */
    function finalizar() {
        if (!itensEst.length) { toast('Adicione pelo menos um item!', 'error'); return; }
        var btn = document.getElementById('btnFinalizar');
        btn.disabled = true; btn.innerHTML = '<span class="spinner"></span>';
        fetch('/admin/estoque', {
            method: 'POST', credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tipo: tipoAtual, observacao: document.getElementById('obsEst').value.trim(), itens: itensEst.map(function(i){ return { produto_id: i.produto_id, quantidade: i.quantidade }; }) })
        })
        .then(function(res) {
            var ct = res.headers.get('content-type') || '';
            if (!ct.includes('application/json')) throw new Error('Sess\u00e3o expirada');
            return res.json().then(function(json) {
                if (!res.ok) throw new Error(json.message || 'Erro');
                toast('Lan\u00e7amento #' + json.data.id + ' registrado! \u2714');
                itensEst = []; document.getElementById('obsEst').value = '';
                renderItensEst();
                setTimeout(function(){ buscaEst.focus(); buscarProdutosEst(''); }, 120);
            });
        })
        .catch(function(err){ toast('Erro: ' + err.message, 'error'); })
        .finally(function(){
            btn.disabled = false;
            var t = tipoAtual==='E'?'entrada-btn':tipoAtual==='S'?'saida-btn':'';
            btn.className = 'btn-finish ' + t;
            btn.innerHTML = '&#10004; Finalizar';
        });
    }

    /* ── CONSULTA ── */
    var hoje = new Date();
    document.getElementById('filtroDataEst').value = hoje.getFullYear() + '-' + String(hoje.getMonth()+1).padStart(2,'0') + '-' + String(hoje.getDate()).padStart(2,'0');

    function buscarLancamentos() {
        var btn  = document.getElementById('btnBuscarC');
        var data = document.getElementById('filtroDataEst').value;
        var tipo = document.getElementById('filtroTipoEst').value;
        if (!data) { toast('Selecione uma data', 'error'); return; }
        btn.disabled = true; btn.innerHTML = '<span class="spinner dark"></span>';
        fetch('/admin/estoque/consulta/dados?data=' + data, { credentials: 'include' })
            .then(function(res){ return res.json(); })
            .then(function(json) {
                var lista = json.data || [];
                if (tipo) lista = lista.filter(function(l){ return l.tipo === tipo; });
                renderLancamentos(lista);
            })
            .catch(function(err){ toast('Erro: ' + err.message, 'error'); })
            .finally(function(){ btn.disabled = false; btn.innerHTML = '&#8635; Buscar'; });
    }

    function renderLancamentos(lista) {
        var c = document.getElementById('listaLancamentos');
        if (!lista.length) { c.innerHTML = '<div class="empty-consulta"><span>&#128196;</span><p>Nenhum lan\u00e7amento encontrado</p></div>'; return; }
        var nT = {E:'Entrada',S:'Sa\u00edda',A:'Ajuste'}, nS = {F:'Finalizado',C:'Cancelado',A:'Aberto'};
        var html = '';
        for (var i = 0; i < lista.length; i++) {
            var l = lista[i], cancelado = l.status==='C', itens = l.Itens||[], totalPecas = 0;
            for (var j = 0; j < itens.length; j++) totalPecas += parseFloat(itens[j].quantidade)||0;
            var itensHtml = '';
            for (var k = 0; k < itens.length; k++) {
                var it = itens[k], nome = (it.Produto&&it.Produto.descricao)?it.Produto.descricao:'Produto #'+it.produto_id;
                itensHtml += '<div class="item-linha"><div>' + nome + '</div><div class="item-qtd-detalhe">' + fmtQtd(parseFloat(it.quantidade)) + '</div></div>';
            }
            var dtStr = ''; try { var d = new Date(l.data); dtStr = d.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'}); } catch(e){}
            var btnC = cancelado ? '' : '<button class="btn-cancelar-lanc" onclick="event.stopPropagation();cancelarLanc('+l.id+')">&#128465; Cancelar</button>';
            html += '<div class="lanc-card'+(cancelado?' cancelado':'')+'" id="lancCard'+l.id+'">'
                  + '<div class="lanc-card-header" onclick="toggleLancItens('+l.id+')">'
                  + '<div class="lanc-card-left"><span class="lanc-icon">'+(l.tipo==='E'?'&#9650;':l.tipo==='S'?'&#9660;':'&#9632;')+'</span>'
                  + '<div><div class="lanc-id">Lan\u00e7amento #'+l.id+'</div><div class="lanc-meta">'+(nT[l.tipo]||l.tipo)+' &bull; '+itens.length+' produto(s) &bull; '+dtStr+(l.observacao?' &bull; '+l.observacao:'')+'</div></div></div>'
                  + '<div class="lanc-card-right"><span class="lanc-badge badge-'+l.tipo+'">'+(nT[l.tipo]||l.tipo)+'</span> <span class="lanc-badge badge-'+l.status+'">'+(nS[l.status]||l.status)+'</span>'
                  + '<div class="lanc-qtd-total">'+fmtQtd(totalPecas)+' pe\u00e7as</div>'+btnC+'</div></div>'
                  + '<div class="lanc-itens" id="lancItens'+l.id+'">'+itensHtml+'</div></div>';
        }
        c.innerHTML = html;
    }

    function toggleLancItens(id) { var el = document.getElementById('lancItens'+id); if(el) el.classList.toggle('open'); }

    function cancelarLanc(id) {
        if (!confirm('Cancelar lan\u00e7amento #'+id+'? O estoque ser\u00e1 estornado.')) return;
        fetch('/admin/estoque/'+id+'/cancelar', { method:'PATCH', credentials:'include' })
            .then(function(res){ return res.json().then(function(json){ if(!res.ok) throw new Error(json.message||'Erro'); toast('Lan\u00e7amento #'+id+' cancelado'); buscarLancamentos(); }); })
            .catch(function(err){ toast('Erro: '+err.message,'error'); });
    }

    /* ── CÂMERA ── */
    var estStream = null, estLoop = null;
    document.getElementById('btnCameraEst').addEventListener('click', function() {
        document.getElementById('scannerEst').classList.contains('open') ? fecharScannerEst() : abrirScannerEst();
    });
    function abrirScannerEst() {
        var video = document.getElementById('scannerEstVideo');
        document.getElementById('scannerEst').classList.add('open');
        navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } })
            .then(function(stream) {
                estStream = stream; video.srcObject = stream; video.play();
                if ('BarcodeDetector' in window) {
                    var det = new BarcodeDetector({ formats: ['ean_13','ean_8','code_128','code_39','upc_a','upc_e','qr_code'] });
                    estLoop = setInterval(function(){ det.detect(video).then(function(r){ if(r.length) codigoLidoEst(r[0].rawValue); }).catch(function(){}); }, 400);
                } else {
                    var s = document.createElement('script'); s.src = 'https://cdnjs.cloudflare.com/ajax/libs/zxing-js/0.20.0/zxing.min.js';
                    s.onload = function(){ try { var reader = new ZXing.BrowserMultiFormatReader(); reader.decodeFromVideoElement(video, function(result){ if(result){ codigoLidoEst(result.getText()); reader.reset(); } }); if(estStream) estStream._zxing = reader; } catch(e){} };
                    if (!document.querySelector('script[src*="zxing"]')) document.head.appendChild(s); else if (typeof ZXing !== 'undefined') s.onload();
                }
            })
            .catch(function(err){ alert('C\u00e2mera n\u00e3o dispon\u00edvel: '+err.message); fecharScannerEst(); });
    }
    function codigoLidoEst(codigo) { fecharScannerEst(); buscaEst.value = codigo; if(navigator.vibrate) navigator.vibrate(120); buscarProdutosEst(codigo); }
    function fecharScannerEst() {
        document.getElementById('scannerEst').classList.remove('open');
        if (estLoop) { clearInterval(estLoop); estLoop = null; }
        if (estStream) { if(estStream._zxing){ try{estStream._zxing.reset();}catch(e){} } estStream.getTracks().forEach(function(t){t.stop();}); estStream = null; }
        document.getElementById('scannerEstVideo').srcObject = null;
    }

    function fmtQtd(n) { var v = parseFloat(n)||0; return v%1===0 ? v.toFixed(0) : v.toFixed(3).replace('.',','); }
</script>
</body>
</html>