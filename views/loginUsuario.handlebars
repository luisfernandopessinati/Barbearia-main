<style>
  :root {
    {{#if empresa.feminino}}
    --secundario:   #c0395a;
    --secundario-1: #d4547a;
    --secundario1:  #c0395a;
    --background:   #fafafa;
    --background1:  #f0f0f0;
    --light:        #1a1a1a;
    {{else}}
    --secundario:   #eb9c2d;
    --secundario-1: #e7ab57;
    --secundario1:  #e6891200;
    --background:   #1e1e20;
    --background1:  rgb(19, 19, 19);
    --light:        #fff;
    {{/if}}
  }

  {{#if empresa.feminino}}
  body { background-color: #fafafa; }
  .titulo { color: #1a1a1a; }
  .form-login { border-color: var(--secundario); background: #fff; box-shadow: 0 4px 24px #c0395a18; }
  .form-login label { color: #1a1a1a; }
  .form-login a { color: #555; }
  .form-login a:hover { color: var(--secundario); }
  .btn-login { background-color: var(--secundario); color: #fff; }
  .btn-login:hover { background-color: var(--secundario-1); }
  {{/if}}
</style>

<div class="login login2">
  <h1 class="titulo">Agende seu horário!</h1>
  <form action="/loginUsuario/{{token}}" method="post" class="form-login">
    {{#if logo}}
      <img src="{{logo}}" alt="Logo da empresa" class="login-logo">
    {{else}}
      <img src="/img/logo2.svg" alt="Logo da barbearia" class="login-logo">
    {{/if}}

    <label for="nome">Nome / Apelido:</label>
    <input type="text" name="nome" id="nome" placeholder="Como te chamam?" required autocomplete="off">

    <label for="telefone">Celular:</label>
    {{!<input type="tel" name="telefone" id="telefone" placeholder="(00) 00000-0000" required autocomplete="tel">}}
    <input type="text" name="telefone" id="telefone" placeholder="Digite seu celular com DDD" required
      autocomplete="off">

    <input type="submit" value="Entrar" class="btn-login">
    <a href="/loginAdmin">Administrador</a>
    <a href="/">Sair.</a>
  </form>