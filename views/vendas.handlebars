<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold: #D4AF37; --gold-glow: rgba(212,175,55,.18);
            --bg: #0d0d0d; --surface: #161616; --card: #1a1a1a;
            --card-border: rgba(212,175,55,.15); --text: #e8e8e8;
            --muted: #666; --danger: #e05454; --success: #4caf7d;
            --radius: 12px;
            --font-main: 'Rajdhani', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;
            --header-h: 56px;
            --footer-collapsed: 60px;
            --footer-expanded:  410px;
        }
        @media (max-width: 640px) { :root { --footer-expanded: 450px; } }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        html, body { height: 100%; background: var(--bg); color: var(--text); font-family: var(--font-main); overflow: hidden; }

        /* ── Header ── */
        header {
            position: fixed; top: 0; left: 0; right: 0; height: var(--header-h);
            background: #000; border-bottom: 1px solid var(--card-border);
            padding: 0 20px; z-index: 100;
            display: flex; align-items: center; justify-content: space-between;
        }

        /* ────────────────────────────────────────────────────────
           LAYOUT DESKTOP vs MOBILE
           No desktop (>= 768px) usamos flexbox side-by-side:
           coluna esquerda = lista de itens | coluna direita = painel pagamento
           No mobile mantemos o comportamento original com footer deslizante.
        ───────────────────────────────────────────────────────── */

        /* ── MOBILE: comportamento original ── */
        .area-itens {
            position: fixed;
            top: var(--header-h); left: 0; right: 0;
            bottom: var(--footer-collapsed);
            display: flex; flex-direction: column; overflow: hidden;
            transition: bottom .32s cubic-bezier(.4,0,.2,1);
        }
        .area-itens.expanded { bottom: var(--footer-expanded); }

        .area-footer {
            position: fixed; bottom: 0; left: 0; right: 0;
            background: #050505; border-top: 1px solid var(--card-border);
            z-index: 100; overflow: hidden;
            height: var(--footer-collapsed);
            transition: height .32s cubic-bezier(.4,0,.2,1);
        }
        .area-footer.expanded { height: var(--footer-expanded); }

        /* ── DESKTOP (>= 768px): layout lado a lado ── */
        @media (min-width: 768px) {
            /* Desativa o comportamento de footer deslizante */
            .area-itens {
                position: fixed;
                top: var(--header-h); left: 0;
                /* ocupa apenas a metade esquerda */
                right: 400px;
                bottom: 0 !important; /* sem footer flutuante */
                transition: none;
            }
            .area-itens.expanded { bottom: 0 !important; }

            .area-footer {
                position: fixed;
                top: var(--header-h); right: 0;
                left: auto;
                bottom: 0;
                width: 400px;
                height: auto !important; /* altura total */
                border-top: none;
                border-left: 1px solid var(--card-border);
                display: flex;
                flex-direction: column;
                overflow-y: auto;
            }
            .area-footer.expanded { height: auto !important; }

            /* Esconde a barra de toggle no desktop */
            .footer-bar { display: none !important; }

            /* Painel sempre visível no desktop */
            .footer-panel {
                flex: 1;
                height: auto !important;
                overflow-y: auto;
                padding: 16px;
            }

            /* Botão câmera fica inline no desktop */
            .search-area { padding: 16px; }
        }

        @media (min-width: 1100px) {
            .area-itens { right: 460px; }
            .area-footer { width: 460px; }
        }

        /* ── Search area ── */
        .search-area {
            background: var(--surface); border-bottom: 1px solid var(--card-border);
            padding: 14px 16px; flex-shrink: 0;
        }
        .search-row { display: flex; gap: 10px; align-items: flex-end; }
        .input-group { position: relative; flex: 1; }
        .input-group label { display: block; color: var(--gold); font-size: 11px; text-transform: uppercase; margin-bottom: 5px; font-weight: 600; letter-spacing: 1px; }

        input, select {
            width: 100%; background: var(--card); border: 1px solid var(--card-border);
            border-radius: 8px; color: #fff; padding: 10px 12px;
            font-family: var(--font-main); font-size: 15px; outline: none; transition: border-color .2s;
        }
        input:focus { border-color: var(--gold); }

        .items-list { flex: 1; overflow-y: auto; padding: 14px 16px; }

        /* ── Footer bar (mobile only) ── */
        .footer-bar {
            height: var(--footer-collapsed);
            display: flex; align-items: center;
            padding: 0 14px; gap: 12px; flex-shrink: 0;
            cursor: pointer; user-select: none;
            border-bottom: 1px solid transparent; transition: border-color .2s;
        }
        .area-footer.expanded .footer-bar { border-color: var(--card-border); }

        .footer-bar-total { flex: 1; }
        .footer-bar-label { color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: 1px; }
        .footer-bar-value { font-family: var(--font-mono); font-size: 22px; color: var(--gold); font-weight: 600; line-height: 1.1; }

        .footer-bar-btn {
            background: var(--gold); color: #000; border: none;
            padding: 9px 16px; border-radius: var(--radius);
            font-weight: 700; font-size: 14px; letter-spacing: .5px;
            display: flex; align-items: center; gap: 8px; white-space: nowrap;
            pointer-events: none;
        }
        .footer-bar-arrow { font-size: 14px; transition: transform .32s ease; display: inline-block; }
        .area-footer.expanded .footer-bar-arrow { transform: rotate(180deg); }

        /* ── Footer panel ── */
        .footer-panel {
            padding: 12px 14px;
            display: flex; flex-direction: column; gap: 9px;
            height: calc(var(--footer-expanded) - var(--footer-collapsed));
            overflow: hidden;
        }

        /* Desktop: título do painel */
        .footer-panel-title {
            display: none;
            color: var(--gold); font-size: 13px; font-weight: 700;
            text-transform: uppercase; letter-spacing: 1.5px;
            padding-bottom: 10px; border-bottom: 1px solid var(--card-border);
            flex-shrink: 0;
        }
        @media (min-width: 768px) {
            .footer-panel { height: auto; overflow-y: auto; }
            .footer-panel-title { display: block; }
        }

        .pag-add-row { display: flex; gap: 8px; align-items: flex-end; flex-shrink: 0; }
        .pag-add-row .input-group { flex: 1; }
        .btn-add-pag {
            background: var(--gold); color: #000; border: none;
            width: 44px; height: 44px; border-radius: 8px; font-size: 24px; line-height: 1;
            cursor: pointer; flex-shrink: 0; align-self: flex-end; transition: opacity .2s;
        }
        .btn-add-pag:hover { opacity: .85; }

        .pag-lista-wrap {
            flex-shrink: 0; height: 84px; overflow-y: auto;
            border: 1px solid var(--card-border); border-radius: 8px;
            background: var(--card); padding: 4px 6px;
        }
        .pag-lista-empty { height: 100%; display: flex; align-items: center; justify-content: center; color: var(--muted); font-size: 12px; }
        .pag-item {
            display: flex; align-items: center; justify-content: space-between;
            padding: 5px 8px; border-radius: 6px; margin-bottom: 3px;
            border-left: 3px solid var(--gold); background: var(--surface); font-size: 13px;
        }
        .pag-item:last-child { margin-bottom: 0; }
        .pag-item-forma { color: var(--gold); font-weight: 600; text-transform: uppercase; font-size: 10px; letter-spacing: .5px; }
        .pag-item-valor { font-family: var(--font-mono); font-weight: 600; font-size: 13px; }
        .btn-remove-pag { background: none; border: none; color: var(--danger); cursor: pointer; font-size: 13px; padding: 2px 5px; border-radius: 4px; }
        .btn-remove-pag:hover { background: rgba(224,84,84,.15); }

        .desconto-row { display: flex; gap: 8px; flex-shrink: 0; }
        .desconto-row .input-group { max-width: 170px; }

        .total-box {
            background: var(--card); padding: 8px 14px;
            border-radius: var(--radius); border: 1px solid var(--card-border);
            display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;
        }
        .total-box.danger { border-color: rgba(224,84,84,.35); }
        .total-label { color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: 1px; }
        .total-value { font-family: var(--font-mono); font-size: 22px; color: var(--gold); font-weight: 600; }
        .total-value.sm { font-size: 16px; color: var(--danger); }

        .footer-actions { display: flex; gap: 10px; flex-shrink: 0; }
        .btn-finish {
            flex: 1; background: var(--gold); color: #000; border: none;
            padding: 11px; border-radius: var(--radius); font-weight: 700; font-size: 15px;
            cursor: pointer; text-transform: uppercase; letter-spacing: 1px; transition: opacity .2s;
            display: flex; align-items: center; justify-content: center; gap: 8px;
        }
        .btn-finish:hover { opacity: .88; }
        .btn-finish:disabled { opacity: .4; cursor: not-allowed; }
        .link-fechamento {
            display: flex; align-items: center; justify-content: center; gap: 6px;
            color: var(--muted); font-size: 12px; text-decoration: none;
            padding: 11px 14px; border-radius: var(--radius);
            border: 1px solid var(--card-border); transition: color .2s, border-color .2s; white-space: nowrap;
        }
        .link-fechamento:hover { color: var(--gold); border-color: var(--gold); }

        /* ── Cards de item ── */
        .sale-item {
            background: var(--card); border-left: 4px solid var(--gold);
            padding: 10px 12px; margin-bottom: 8px; border-radius: 0 8px 8px 0;
            animation: fadeIn .2s ease;
            display: flex; gap: 10px; align-items: flex-start;
        }
        @keyframes fadeIn { from { opacity:0; transform:translateY(-4px); } to { opacity:1; transform:none; } }

        .item-thumb {
            width: 48px; height: 48px; border-radius: 6px; flex-shrink: 0;
            background: var(--surface); border: 1px solid var(--card-border);
            overflow: hidden; cursor: pointer; position: relative;
            transition: border-color .2s;
        }
        .item-thumb:hover { border-color: var(--gold); }
        .item-thumb img {
            width: 48px; height: 48px;
            object-fit: cover; display: block; flex-shrink: 0;
        }
        .item-thumb-placeholder {
            width: 48px; height: 48px;
            display: flex; align-items: center; justify-content: center;
            color: var(--muted); font-size: 22px;
        }

        .item-body { flex: 1; min-width: 0; }
        .sale-item-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 8px; }
        .sale-item-name { font-weight: bold; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 180px; }
        .sale-item-qty  { font-size: 11px; color: var(--gold); margin-top: 2px; }
        .sale-item-right { display: flex; align-items: center; gap: 6px; flex-shrink: 0; font-family: var(--font-mono); font-weight: bold; font-size: 14px; white-space: nowrap; }

        .btn-edit-item { background: none; border: none; color: var(--gold); cursor: pointer; font-size: 14px; padding: 2px 4px; border-radius: 4px; transition: background .2s; }
        .btn-edit-item:hover { background: var(--gold-glow); }
        .btn-remove { background: none; border: none; color: var(--danger); cursor: pointer; font-size: 14px; padding: 2px 4px; border-radius: 4px; }
        .btn-remove:hover { background: rgba(224,84,84,.15); }

        .edit-row { display: none; gap: 8px; align-items: center; margin-top: 8px; padding-top: 8px; border-top: 1px solid var(--card-border); }
        .edit-row.open { display: flex; }
        .edit-row input { background: var(--surface); border: 1px solid var(--gold); color: #fff; padding: 5px 8px; border-radius: 6px; font-size: 13px; font-family: var(--font-mono); }
        .edit-row label { font-size: 10px; color: var(--muted); white-space: nowrap; }
        .edit-field { display: flex; flex-direction: column; gap: 2px; flex: 1; }
        .btn-ok { background: var(--gold); color: #000; border: none; padding: 6px 12px; border-radius: 6px; font-weight: 700; font-size: 12px; cursor: pointer; white-space: nowrap; flex-shrink: 0; }

        .empty-state { text-align: center; margin-top: 50px; opacity: .25; pointer-events: none; }
        .empty-state span { font-size: 44px; display: block; margin-bottom: 8px; }

        /* ── Câmera ── */
        .btn-camera-pdv {
            background: var(--card); border: 1px solid var(--card-border); color: var(--gold);
            width: 44px; height: 44px; border-radius: 8px; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0; font-size: 20px; transition: border-color .2s;
        }
        .btn-camera-pdv:hover { border-color: var(--gold); }

        .scanner-pdv {
            display: none;
            position: fixed; inset: 0;
            background: rgba(0,0,0,.96);
            z-index: 900;
            flex-direction: column;
            align-items: center; justify-content: center; gap: 20px;
        }
        .scanner-pdv.open { display: flex; }

        .scanner-pdv-box {
            position: relative; width: 90%; max-width: 400px;
            border-radius: 12px; overflow: hidden;
            border: 2px solid var(--gold); background: #000;
        }
        .scanner-pdv-box video {
            width: 100%; height: 300px;
            object-fit: cover; display: block;
        }
        .scanner-pdv-line {
            position: absolute; left: 0; right: 0; top: 50%;
            height: 2px; background: var(--gold); opacity: .85;
            animation: scanpdv 1.8s ease-in-out infinite;
        }
        @keyframes scanpdv { 0%{top:15%} 50%{top:85%} 100%{top:15%} }

        .scanner-pdv-msg { color: rgba(255,255,255,.55); font-size: 14px; text-align: center; }

        .btn-fechar-scanner-pdv {
            background: var(--card); border: 1px solid var(--card-border);
            color: var(--text); padding: 13px 36px; border-radius: 8px;
            font-size: 15px; font-weight: 600; cursor: pointer; font-family: var(--font-main);
            transition: color .2s, border-color .2s;
        }
        .btn-fechar-scanner-pdv:hover { border-color: var(--danger); color: var(--danger); }

        /* ── Modal imagem ── */
        .img-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,.92); z-index: 800;
            align-items: center; justify-content: center; flex-direction: column; gap: 16px;
        }
        .img-overlay.open { display: flex; }
        .img-overlay-nome { color: var(--text); font-size: 16px; font-weight: 600; text-align: center; padding: 0 24px; }
        .img-overlay-close {
            background: var(--card); border: 1px solid var(--card-border); color: var(--muted);
            padding: 10px 28px; border-radius: 8px; font-size: 14px; font-weight: 600;
            cursor: pointer; font-family: var(--font-main); transition: color .2s, border-color .2s;
        }
        .img-overlay-close:hover { color: var(--danger); border-color: var(--danger); }
        .img-overlay-sem { color: var(--muted); font-size: 48px; }

        /* ── Autocomplete ── */
        #suggestions {
            position: absolute; top: 100%; left: 0; right: 0;
            background: #222; z-index: 200;
            border-radius: 0 0 8px 8px; max-height: 260px; overflow-y: auto;
            box-shadow: 0 10px 30px rgba(0,0,0,.6);
            border: 1px solid var(--card-border); border-top: none;
        }
        .sugestao-item { padding: 11px 14px; border-bottom: 1px solid var(--card-border); cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 10px; font-size: 14px; transition: background .15s; }
        .sugestao-item:last-child { border-bottom: none; }
        .sugestao-item:hover { background: var(--gold-glow); }
        .sugestao-item.sem-result { color: var(--muted); justify-content: center; cursor: default; }
        .sugestao-item.loading { color: var(--muted); justify-content: center; font-style: italic; }
        .sugestao-price { color: var(--gold); font-family: var(--font-mono); font-weight: 600; white-space: nowrap; }
        .sugestao-estoque { font-size: 11px; color: var(--muted); margin-top: 2px; }

        /* ── Toast ── */
        #toast { position: fixed; top: 70px; right: 16px; z-index: 9999; background: var(--success); color: #fff; padding: 12px 20px; border-radius: 8px; font-size: 15px; font-weight: 600; display: none; align-items: center; gap: 8px; box-shadow: 0 4px 20px rgba(0,0,0,.5); max-width: 320px; }
        #toast.error { background: var(--danger); }
        #toast.show  { display: flex; }

        .spinner { width: 15px; height: 15px; border: 2px solid rgba(0,0,0,.2); border-top-color: #000; border-radius: 50%; animation: spin .6s linear infinite; display: inline-block; }
        .spinner.light { border-color: rgba(255,255,255,.2); border-top-color: var(--gold); }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* ── Modal impressão ── */
        .print-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.85); z-index: 1000; align-items: center; justify-content: center; }
        .print-overlay.open { display: flex; }
        .print-modal { background: #161616; border: 1px solid rgba(212,175,55,.25); border-radius: 16px; padding: 32px 28px; width: 90%; max-width: 380px; text-align: center; }
        .print-modal-icon { font-size: 36px; margin-bottom: 12px; }
        .print-modal-title { font-size: 20px; font-weight: 700; color: var(--gold); letter-spacing: 1px; margin-bottom: 6px; }
        .print-modal-sub { font-size: 13px; color: var(--muted); margin-bottom: 28px; }
        .print-modal-btns { display: flex; flex-direction: column; gap: 10px; }
        .btn-print-venda { background: var(--gold); color: #000; border: none; padding: 13px; border-radius: 10px; font-weight: 700; font-size: 15px; cursor: pointer; transition: opacity .2s; }
        .btn-print-venda:hover { opacity: .85; }
        .btn-print-presente { background: none; color: var(--text); border: 1px solid rgba(212,175,55,.4); padding: 13px; border-radius: 10px; font-weight: 600; font-size: 15px; cursor: pointer; transition: border-color .2s, color .2s; }
        .btn-print-presente:hover { border-color: var(--gold); color: var(--gold); }
        .btn-print-skip { background: none; color: var(--muted); border: none; padding: 10px; font-size: 13px; cursor: pointer; transition: color .2s; }
        .btn-print-skip:hover { color: var(--text); }
    </style>
</head>
<body>

<div id="toast"></div>

<!-- Modal imagem -->
<div class="img-overlay" id="imgOverlay">
    <div id="imgOverlayConteudo"></div>
    <div class="img-overlay-nome" id="imgOverlayNome"></div>
    <button class="img-overlay-close" onclick="fecharImagem()">&#215; Fechar</button>
</div>

<!-- Modal impressão -->
<div class="print-overlay" id="printOverlay">
    <div class="print-modal">
        <div class="print-modal-icon">🧾</div>
        <div class="print-modal-title" id="printModalVendaNum"></div>
        <div class="print-modal-sub">Deseja imprimir o comprovante?</div>
        <div class="print-modal-btns">
            <button class="btn-print-venda"    onclick="imprimirRecibo('venda')">🖨️ Imprimir Venda</button>
            <button class="btn-print-presente" onclick="imprimirRecibo('presente')">🎁 Imprimir Presente</button>
            <button class="btn-print-skip"     onclick="fecharPrintModal()">✕ Não imprimir</button>
        </div>
    </div>
</div>

<!-- Scanner -->
<div class="scanner-pdv" id="scannerPdv">
    <div class="scanner-pdv-box">
        <video id="scannerPdvVideo" playsinline muted autoplay width="400" height="300"></video>
        <div class="scanner-pdv-line"></div>
    </div>
    <div class="scanner-pdv-msg">Aponte para o c&#243;digo de barras</div>
    <button type="button" class="btn-fechar-scanner-pdv" onclick="fecharScannerPdv()">&#215; Fechar C&#226;mera</button>
</div>

<!-- Header -->
<header>
    <a href="/admin" style="text-decoration:none;color:var(--gold);display:flex;align-items:center;gap:5px;font-weight:600;font-size:14px;">&#8592; VOLTAR</a>
</header>

<!-- Área central -->
<div class="area-itens" id="areaItens">
    <div class="search-area">
        <div class="search-row">
            <div class="input-group">
                <label>Buscar Produto</label>
                <input type="text" id="buscaInput" placeholder="Toque para listar ou filtre..." autocomplete="off">
                <div id="suggestions"></div>
            </div>
            <div class="input-group" style="max-width:72px;">
                <label>Qtd</label>
                <input type="number" id="qtdInput" value="1" min="1">
            </div>
            <button type="button" class="btn-camera-pdv" id="btnCameraPdv">&#128247;</button>
        </div>
    </div>

    <div class="items-list" id="listaItens">
        <div class="empty-state"><span>&#128717;</span><p>Carrinho vazio</p></div>
    </div>
</div>

<!-- Footer / Painel de Pagamento -->
<div class="area-footer" id="areaFooter">
    <!-- Barra de toggle (mobile apenas) -->
    <div class="footer-bar" id="footerBar" onclick="toggleFooter()">
        <div class="footer-bar-total">
            <div class="footer-bar-label">Total</div>
            <div class="footer-bar-value" id="totalBarDisplay">R$ 0,00</div>
        </div>
        <div class="footer-bar-btn">
            <span class="footer-bar-arrow" id="footerArrow">&#9650;</span>
            Pagamento
        </div>
    </div>

    <!-- Painel sempre visível no desktop, colapsável no mobile -->
    <div class="footer-panel">
        <div class="footer-panel-title">&#128179; Pagamento</div>

        <div class="pag-add-row">
            <div class="input-group">
                <label>Forma de Pagamento</label>
                <select id="formaPagamento">
                    <option value="dinheiro">Dinheiro</option>
                    <option value="pix">Pix</option>
                    <option value="cartao_debito">Cart&#227;o D&#233;bito</option>
                    <option value="cartao_credito">Cart&#227;o Cr&#233;dito</option>
                </select>
            </div>
            <div class="input-group" style="max-width:120px;">
                <label>Valor (R$)</label>
                <input type="number" id="pagValor" step="0.01" min="0" placeholder="Total">
            </div>
            <button type="button" class="btn-add-pag" onclick="adicionarPagamento()">+</button>
        </div>

        <div class="pag-lista-wrap" id="pagListaWrap">
            <div class="pag-lista-empty">Nenhum pagamento adicionado</div>
        </div>

        <div class="desconto-row">
            <div class="input-group">
                <label>Desconto (R$)</label>
                <input type="number" id="descontoInput" value="0" step="0.01" min="0">
            </div>
        </div>

        <div class="total-box">
            <span class="total-label">Total a Pagar</span>
            <span class="total-value" id="totalGeralDisplay">R$ 0,00</span>
        </div>

        <div class="total-box danger" id="saldoBox" style="display:none;">
            <span class="total-label" style="color:var(--danger)">Falta cobrir</span>
            <span class="total-value sm" id="saldoDisplay">R$ 0,00</span>
        </div>

        <div class="footer-actions">
            <button class="btn-finish" id="btnFinalizar" onclick="finalizarVenda()">&#10004; Finalizar Venda</button>
            <a href="/admin/fechamento" class="link-fechamento">&#128196; Caixa</a>
        </div>
    </div>
</div>

<script>
    var itensVenda      = [];
    var pagamentosVenda = [];
    var debounceTimer   = null;
    var _ultimaVenda    = null;
    var footerAberto    = false;
    var EMPRESA_NOME    = '{{empresaNome}}';
    var IMG_BASE        = '';

    var buscaInput    = document.getElementById('buscaInput');
    var suggestionsEl = document.getElementById('suggestions');

    var FORMA_LABELS = {
        dinheiro: 'Dinheiro', pix: 'Pix',
        cartao_debito: 'Cartão Débito', cartao_credito: 'Cartão Crédito',
    };

    /* ── Detecta se é desktop ── */
    function isDesktop() { return window.innerWidth >= 768; }

    /* ── Footer toggle (mobile only) ── */
    function toggleFooter() {
        if (isDesktop()) return; // no desktop não faz nada
        footerAberto = !footerAberto;
        document.getElementById('areaFooter').classList.toggle('expanded', footerAberto);
        document.getElementById('areaItens').classList.toggle('expanded', footerAberto);
    }

    /* ── Toast ── */
    function toast(msg, tipo) {
        var el = document.getElementById('toast');
        el.textContent = msg;
        el.className = 'show' + (tipo === 'error' ? ' error' : '');
        clearTimeout(el._t);
        el._t = setTimeout(function(){ el.className = ''; }, 3500);
    }

    /* ── Autocomplete ── */
    function fecharSugestoes() { suggestionsEl.innerHTML = ''; suggestionsEl._cache = null; }

    buscaInput.addEventListener('focus', function() { if (!suggestionsEl.innerHTML) buscarProdutos(''); });
    buscaInput.addEventListener('input', function(e) {
        clearTimeout(debounceTimer);
        var t = e.target.value.trim();
        debounceTimer = setTimeout(function(){ buscarProdutos(t); }, /^\d{6,}$/.test(t) ? 200 : 350);
    });

    function buscarProdutos(termo) {
        suggestionsEl.innerHTML = '<div class="sugestao-item loading"><span class="spinner light"></span>&nbsp;Buscando...</div>';
        fetch('/admin/vendas/produtos' + (termo ? '?busca=' + encodeURIComponent(termo) : ''), { credentials: 'include' })
            .then(function(res) {
                var ct = res.headers.get('content-type') || '';
                if (!ct.includes('application/json')) { suggestionsEl.innerHTML = '<div class="sugestao-item sem-result">Sess&#227;o expirada</div>'; return; }
                return res.json().then(function(json) {
                    if (!res.ok) throw new Error(json.message || 'Erro');
                    var lista = json.data || [];
                    if (/^\d{6,}$/.test(termo)) {
                        for (var k = 0; k < lista.length; k++) {
                            if (String(lista[k].codbarras) === termo) { adicionarProduto(lista[k]); fecharSugestoes(); return; }
                        }
                    }
                    renderSugestoes(lista);
                });
            })
            .catch(function(err) { suggestionsEl.innerHTML = '<div class="sugestao-item sem-result">&#9888; ' + err.message + '</div>'; });
    }

    function renderSugestoes(lista) {
        if (!lista.length) { suggestionsEl.innerHTML = '<div class="sugestao-item sem-result">Nenhum produto encontrado</div>'; return; }
        suggestionsEl._cache = lista;
        var html = '';
        for (var i = 0; i < lista.length; i++) {
            var p = lista[i];
            html += '<div class="sugestao-item" data-idx="' + i + '">'
                + '<div><div>' + p.descricao + '</div><div class="sugestao-estoque">Estoque: ' + (p.estoque != null ? p.estoque : '&mdash;') + '</div></div>'
                + '<span class="sugestao-price">R$ ' + fmtNum(p.preco) + '</span>'
                + '</div>';
        }
        suggestionsEl.innerHTML = html;
        suggestionsEl.querySelectorAll('[data-idx]').forEach(function(el) {
            el.addEventListener('click', function() {
                var prod = (suggestionsEl._cache || [])[parseInt(el.dataset.idx)];
                if (prod) { adicionarProduto(prod); fecharSugestoes(); }
            });
        });
    }

    document.addEventListener('click', function(e) {
        if (!e.target.closest('#suggestions') && !e.target.closest('#buscaInput')) fecharSugestoes();
    });

    /* ── Carrinho ── */
    function adicionarProduto(produto) {
        var qtd = Math.max(1, parseInt(document.getElementById('qtdInput').value) || 1);
        var existente = null;
        for (var i = 0; i < itensVenda.length; i++) {
            if (itensVenda[i].produto_id === produto.id) { existente = itensVenda[i]; break; }
        }
        if (existente) {
            existente.quantidade += qtd;
            existente.subtotal = existente.preco_unitario * existente.quantidade;
        } else {
            itensVenda.push({
                produto_id:     produto.id,
                descricao:      produto.descricao,
                preco_unitario: parseFloat(produto.preco),
                quantidade:     qtd,
                subtotal:       parseFloat(produto.preco) * qtd,
                imagem:         produto.imagem || null,
            });
        }
        document.getElementById('qtdInput').value = 1;
        buscaInput.value = '';
        renderItens();
        setTimeout(function() { buscaInput.focus(); buscarProdutos(''); }, 120);
    }

    function renderItens() {
        var c = document.getElementById('listaItens');
        if (!itensVenda.length) {
            c.innerHTML = '<div class="empty-state"><span>&#128717;</span><p>Carrinho vazio</p></div>';
            atualizarTotal(); return;
        }
        var html = '';
        for (var i = 0; i < itensVenda.length; i++) {
            var it  = itensVenda[i];
            var src = it.imagem ? (IMG_BASE + it.imagem) : '';
            var thumbInner = src
                ? '<img src="' + src + '" alt="" style="width:48px;height:48px;object-fit:cover;display:block;" onload="this.style.opacity=1" onerror="this.style.display=\'none\';this.parentNode.querySelector(\'.item-thumb-placeholder\').style.display=\'flex\'">'
                  + '<span class="item-thumb-placeholder" style="display:none;width:48px;height:48px;align-items:center;justify-content:center;">&#128247;</span>'
                : '<span class="item-thumb-placeholder" style="display:flex;width:48px;height:48px;align-items:center;justify-content:center;">&#128247;</span>';

            html +=
                '<div class="sale-item">' +
                    '<div class="item-thumb" data-src="' + src + '" data-nome="' + it.descricao.replace(/"/g,'') + '" onclick="abrirImagem(this)">' +
                        thumbInner +
                    '</div>' +
                    '<div class="item-body">' +
                        '<div class="sale-item-top">' +
                            '<div>' +
                                '<div class="sale-item-name">' + it.descricao + '</div>' +
                                '<div class="sale-item-qty">' + it.quantidade + 'x &nbsp;R$ ' + fmtNum(it.preco_unitario) + '</div>' +
                            '</div>' +
                            '<div class="sale-item-right">' +
                                'R$ ' + fmtNum(it.subtotal) +
                                '<button class="btn-edit-item" data-idx="' + i + '">&#9998;</button>' +
                                '<button class="btn-remove"    data-idx="' + i + '">&#x2715;</button>' +
                            '</div>' +
                        '</div>' +
                        '<div class="edit-row" id="er' + i + '">' +
                            '<div class="edit-field"><label>Qtd</label><input type="number" class="eq" value="' + it.quantidade + '" min="1" style="width:75px;"></div>' +
                            '<div class="edit-field"><label>Pre&#231;o R$</label><input type="number" class="ep" value="' + it.preco_unitario.toFixed(2) + '" step="0.01" min="0" style="width:100px;"></div>' +
                            '<button class="btn-ok" data-idx="' + i + '">OK</button>' +
                        '</div>' +
                    '</div>' +
                '</div>';
        }
        c.innerHTML = html;
        c.querySelectorAll('.btn-edit-item').forEach(function(b) {
            b.addEventListener('click', function() { document.getElementById('er' + b.dataset.idx).classList.toggle('open'); });
        });
        c.querySelectorAll('.btn-remove').forEach(function(b) {
            b.addEventListener('click', function() { itensVenda.splice(parseInt(b.dataset.idx), 1); renderItens(); });
        });
        c.querySelectorAll('.btn-ok').forEach(function(b) {
            b.addEventListener('click', function() {
                var idx = parseInt(b.dataset.idx), row = document.getElementById('er' + idx);
                var q = Math.max(1, parseFloat(row.querySelector('.eq').value) || 1);
                var p = Math.max(0, parseFloat(row.querySelector('.ep').value) || 0);
                itensVenda[idx].quantidade = q; itensVenda[idx].preco_unitario = p; itensVenda[idx].subtotal = q * p;
                renderItens();
            });
        });
        atualizarTotal();
    }

    /* ── Modal imagem ── */
    function abrirImagem(el) {
        var src  = el.dataset.src;
        var nome = el.dataset.nome;
        var conteudo = document.getElementById('imgOverlayConteudo');
        if (src) {
            conteudo.innerHTML = '<img src="' + src + '" alt="' + nome
                + '" style="max-width:88vw;max-height:70vh;border-radius:12px;border:1px solid var(--card-border);object-fit:contain;"'
                + ' onerror="this.parentNode.innerHTML=\'<div class=img-overlay-sem>&#128247;</div>\'">';
        } else {
            conteudo.innerHTML = '<div class="img-overlay-sem">&#128247;</div>';
        }
        document.getElementById('imgOverlayNome').textContent = nome;
        document.getElementById('imgOverlay').classList.add('open');
    }
    document.getElementById('imgOverlay').addEventListener('click', function(e) {
        if (e.target === this) fecharImagem();
    });
    function fecharImagem() { document.getElementById('imgOverlay').classList.remove('open'); }

    /* ── Pagamentos ── */
    function adicionarPagamento() {
        var forma    = document.getElementById('formaPagamento').value;
        var valorEl  = document.getElementById('pagValor');
        var sub      = calcSubtotal();
        var desc     = parseFloat(document.getElementById('descontoInput').value) || 0;
        var total    = Math.max(0, sub - desc);
        var somaPaga = pagamentosVenda.reduce(function(s,p){ return s + p.valor; }, 0);
        var restante = Math.max(0, total - somaPaga);
        var valor    = parseFloat(valorEl.value);
        if (!valor || valor <= 0) valor = restante > 0 ? restante : total;
        pagamentosVenda.push({ forma_pagamento: forma, valor: parseFloat(valor.toFixed(2)) });
        valorEl.value = '';
        renderPagamentos();
    }

    function removerPagamento(idx) { pagamentosVenda.splice(idx, 1); renderPagamentos(); }

    function renderPagamentos() {
        var wrap = document.getElementById('pagListaWrap');
        if (!pagamentosVenda.length) {
            wrap.innerHTML = '<div class="pag-lista-empty">Nenhum pagamento adicionado</div>';
            atualizarTotal(); return;
        }
        var html = '';
        pagamentosVenda.forEach(function(p, i) {
            html += '<div class="pag-item">'
                + '<div><div class="pag-item-forma">' + (FORMA_LABELS[p.forma_pagamento] || p.forma_pagamento) + '</div></div>'
                + '<div style="display:flex;align-items:center;gap:10px;">'
                +   '<span class="pag-item-valor">R$ ' + fmtNum(p.valor) + '</span>'
                +   '<button class="btn-remove-pag" onclick="removerPagamento(' + i + ')">&#x2715;</button>'
                + '</div></div>';
        });
        wrap.innerHTML = html;
        atualizarTotal();
    }

    /* ── Totais ── */
    function calcSubtotal() {
        var s = 0; for (var i = 0; i < itensVenda.length; i++) s += itensVenda[i].subtotal; return s;
    }
    function atualizarTotal() {
        var sub   = calcSubtotal();
        var desc  = parseFloat(document.getElementById('descontoInput').value) || 0;
        var total = Math.max(0, sub - desc);
        document.getElementById('totalBarDisplay').textContent   = 'R$ ' + fmtNum(sub);
        document.getElementById('totalGeralDisplay').textContent = 'R$ ' + fmtNum(total);
        var somaPaga = pagamentosVenda.reduce(function(s,p){ return s + p.valor; }, 0);
        var saldo    = Math.max(0, total - somaPaga);
        var saldoBox = document.getElementById('saldoBox');
        if (saldo > 0.009 && pagamentosVenda.length > 0) {
            saldoBox.style.display = 'flex';
            document.getElementById('saldoDisplay').textContent = 'R$ ' + fmtNum(saldo);
        } else { saldoBox.style.display = 'none'; }
    }
    document.getElementById('descontoInput').addEventListener('input', atualizarTotal);

    /* ── Finalizar ── */
    function finalizarVenda() {
        if (!itensVenda.length) { toast('Adicione pelo menos um item!', 'error'); return; }
        var pagsFinal = pagamentosVenda.slice();
        if (!pagsFinal.length) {
            var sub  = calcSubtotal();
            var desc = parseFloat(document.getElementById('descontoInput').value) || 0;
            pagsFinal = [{ forma_pagamento: document.getElementById('formaPagamento').value, valor: Math.max(0, sub - desc) }];
        }
        var btn = document.getElementById('btnFinalizar');
        btn.disabled = true; btn.innerHTML = '<span class="spinner"></span>&nbsp;Salvando...';
        var desconto   = parseFloat(document.getElementById('descontoInput').value) || 0;
        var itensCopia = itensVenda.slice();
        fetch('/admin/vendas', {
            method: 'POST', credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                pagamentos: pagsFinal, desconto: desconto,
                itens: itensCopia.map(function(i){ return { produto_id: i.produto_id, quantidade: i.quantidade, preco_unitario: i.preco_unitario }; })
            })
        })
        .then(function(res) {
            var ct = res.headers.get('content-type') || '';
            if (!ct.includes('application/json')) throw new Error('Sess\u00e3o expirada');
            return res.json().then(function(json) {
                if (!res.ok) throw new Error(json.message || 'Erro ao salvar');
                _ultimaVenda = { id: json.data.id, total_final: json.data.total_final, pagamentos: pagsFinal, desconto: desconto, itens: itensCopia, data: new Date() };
                itensVenda = []; pagamentosVenda = [];
                document.getElementById('descontoInput').value = 0;
                if (footerAberto) toggleFooter();
                renderItens(); renderPagamentos();
                abrirPrintModal(_ultimaVenda.id);
            });
        })
        .catch(function(err){ toast('Erro: ' + err.message, 'error'); })
        .finally(function(){ btn.disabled = false; btn.innerHTML = '&#10004; Finalizar Venda'; });
    }

    /* ── Modal impressão ── */
    function abrirPrintModal(vendaId) {
        document.getElementById('printModalVendaNum').textContent = 'Venda #' + vendaId + ' registrada ✔';
        document.getElementById('printOverlay').classList.add('open');
    }
    function fecharPrintModal() {
        document.getElementById('printOverlay').classList.remove('open');
        setTimeout(function(){ buscaInput.focus(); buscarProdutos(''); }, 120);
    }
    function imprimirRecibo(tipo) {
        fecharPrintModal();
        var v = _ultimaVenda; if (!v) return;
        var agora = v.data;
        var dataFmt = String(agora.getDate()).padStart(2,'0') + '/' + String(agora.getMonth()+1).padStart(2,'0') + '/' + agora.getFullYear();
        var horaFmt = String(agora.getHours()).padStart(2,'0') + ':' + String(agora.getMinutes()).padStart(2,'0');
        var linhasItens = '', subtotal = 0;
        v.itens.forEach(function(it) {
            subtotal += it.subtotal;
            if (tipo === 'venda') linhasItens += '<tr><td>' + it.descricao + '</td><td style="text-align:center">' + it.quantidade + 'x</td><td style="text-align:right">R$ ' + fmtNum(it.preco_unitario) + '</td><td style="text-align:right"><strong>R$ ' + fmtNum(it.subtotal) + '</strong></td></tr>';
            else linhasItens += '<tr><td>' + it.descricao + '</td><td style="text-align:center">' + it.quantidade + 'x</td></tr>';
        });
        var FORMA_PT = { dinheiro:'Dinheiro', pix:'Pix', cartao_debito:'Cartão Débito', cartao_credito:'Cartão Crédito' };
        var rodape = '';
        if (tipo === 'venda') {
            rodape += '<tr><td colspan="3" style="text-align:right;padding-top:6px;color:#666">Subtotal</td><td style="text-align:right">R$ ' + fmtNum(subtotal) + '</td></tr>';
            if (v.desconto > 0) rodape += '<tr><td colspan="3" style="text-align:right;color:#c0392b">Desconto</td><td style="text-align:right;color:#c0392b">- R$ ' + fmtNum(v.desconto) + '</td></tr>';
            rodape += '<tr><td colspan="3" style="text-align:right;padding-top:8px;font-size:16px;font-weight:700">TOTAL</td><td style="text-align:right;padding-top:8px;font-size:16px;font-weight:700">R$ ' + fmtNum(v.total_final) + '</td></tr>';
            v.pagamentos.forEach(function(p) { rodape += '<tr><td colspan="4" style="padding-top:6px;color:#666;font-size:12px">Pagamento: <strong>' + (FORMA_PT[p.forma_pagamento] || p.forma_pagamento) + '</strong> — R$ ' + fmtNum(p.valor) + '</td></tr>'; });
        }
        var thHeader = tipo === 'venda' ? '<tr style="border-bottom:1px solid #ddd"><th style="text-align:left">Produto</th><th style="text-align:center">Qtd</th><th style="text-align:right">Unit.</th><th style="text-align:right">Total</th></tr>' : '<tr style="border-bottom:1px solid #ddd"><th style="text-align:left">Produto</th><th style="text-align:center">Qtd</th></tr>';
        var titulo   = tipo === 'venda' ? 'COMPROVANTE DE VENDA' : 'COMPROVANTE DE PRESENTE';
        var msgFinal = tipo === 'venda' ? '<p style="font-size:12px;color:#666">Guarde este comprovante para poss&#237;veis trocas.</p>' : '<p style="font-size:13px;color:#333">&#127873; Com carinho!</p><p style="margin-top:8px;font-size:11px;color:#888">Troc&#225;vel em at&#233; 30 dias.</p>';
        var html = '<!DOCTYPE html><html><head><meta charset="UTF-8"><title>' + titulo + '</title><style>body{font-family:Arial,sans-serif;font-size:13px;color:#222;max-width:420px;margin:20px auto;padding:0 16px}.header{text-align:center;border-bottom:2px solid #222;padding-bottom:12px;margin-bottom:14px}.header h1{font-size:18px;margin:0 0 4px}.sub{font-size:11px;color:#666}.info{display:flex;justify-content:space-between;font-size:11px;color:#555;margin-bottom:14px}table{width:100%;border-collapse:collapse}td,th{padding:5px 4px;font-size:12px}hr{border:none;border-top:1px dashed #999;margin:12px 0}.footer{text-align:center;margin-top:20px;border-top:1px dashed #999;padding-top:12px}@media print{body{margin:0}}</style></head><body><div class="header"><h1>' + EMPRESA_NOME + '</h1><div class="sub">' + titulo + '</div></div><div class="info"><span>Venda n&#186; <strong>' + v.id + '</strong></span><span>' + dataFmt + ' &#224;s ' + horaFmt + '</span></div><table>' + thHeader + linhasItens + '<tr><td colspan="4"><hr></td></tr>' + rodape + '</table><div class="footer">' + msgFinal + '</div></body></html>';
        var frame = document.getElementById('printFrame');
        if (!frame) { frame = document.createElement('iframe'); frame.id = 'printFrame'; frame.style.cssText = 'position:fixed;width:0;height:0;border:0;left:-9999px;top:-9999px;'; document.body.appendChild(frame); }
        frame.onload = function() { try { frame.contentWindow.focus(); frame.contentWindow.print(); } catch(e) { var w = window.open('','_blank'); if (w) { w.document.write(html); w.document.close(); } else toast('Permita pop-ups para imprimir.','error'); } };
        frame.srcdoc = html;
    }

    function fmtNum(n) { return parseFloat(n).toFixed(2).replace('.', ','); }

    /* ── Scanner ── */
    var pdvStream = null, pdvLoop = null;

    document.getElementById('btnCameraPdv').addEventListener('click', function() {
        document.getElementById('scannerPdv').classList.contains('open') ? fecharScannerPdv() : abrirScannerPdv();
    });

    function abrirScannerPdv() {
        var video = document.getElementById('scannerPdvVideo');
        document.getElementById('scannerPdv').classList.add('open');
        navigator.mediaDevices.getUserMedia({ video: { facingMode: { ideal: 'environment' } } })
            .then(function(stream) {
                pdvStream = stream;
                video.srcObject = stream;
                var p = video.play(); if (p) p.catch(function(){});
                if ('BarcodeDetector' in window) {
                    var det = new BarcodeDetector({ formats: ['ean_13','ean_8','code_128','code_39','upc_a','upc_e','qr_code'] });
                    pdvLoop = setInterval(function() {
                        if (video.readyState >= 2) {
                            det.detect(video).then(function(r){ if (r.length) codigoLidoPdv(r[0].rawValue); }).catch(function(){});
                        }
                    }, 400);
                } else {
                    var s = document.createElement('script');
                    s.src = 'https://cdnjs.cloudflare.com/ajax/libs/zxing-js/0.20.0/zxing.min.js';
                    s.onload = function() {
                        try {
                            var reader = new ZXing.BrowserMultiFormatReader();
                            reader.decodeFromVideoElement(video, function(result, err){
                                if (result) { codigoLidoPdv(result.getText()); reader.reset(); }
                            });
                            if (pdvStream) pdvStream._zxing = reader;
                        } catch(e){ console.error('ZXing erro:', e); }
                    };
                    if (!document.querySelector('script[src*="zxing"]')) document.head.appendChild(s);
                    else if (typeof ZXing !== 'undefined') s.onload();
                }
            })
            .catch(function(err) {
                document.getElementById('scannerPdv').classList.remove('open');
                toast('Câmera não disponível: ' + err.message, 'error');
            });
    }

    function codigoLidoPdv(codigo) {
        fecharScannerPdv();
        buscaInput.value = codigo;
        if (navigator.vibrate) navigator.vibrate(120);
        buscarProdutos(codigo);
    }

    function fecharScannerPdv() {
        document.getElementById('scannerPdv').classList.remove('open');
        if (pdvLoop) { clearInterval(pdvLoop); pdvLoop = null; }
        if (pdvStream) {
            if (pdvStream._zxing) { try { pdvStream._zxing.reset(); } catch(e){} }
            pdvStream.getTracks().forEach(function(t){ t.stop(); });
            pdvStream = null;
        }
        var video = document.getElementById('scannerPdvVideo');
        video.srcObject = null;
        video.load();
    }
</script>
</body>
</html>